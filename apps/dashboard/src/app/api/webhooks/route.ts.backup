import { NextRequest, NextResponse } from 'next/server';
import { database } from '../../../infrastructure/database';

interface WebhookConfig {
  name: string;
  url: string;
  type: 'slack' | 'discord' | 'teams' | 'generic';
  events: string[];
  enabled: boolean;
  headers?: Record<string, string>;
}

export async function POST(req: NextRequest) {
  // Get tenant ID from middleware-injected headers
  const tenantId = req.headers.get('x-tenant-id');
  if (!tenantId) {
    return NextResponse.json({ error: 'Authentication required' }, { status: 401 });
  }

  try {
    const { name, url, type, events = ['security_scan', 'vulnerability_found'], headers } = await req.json();
    
    if (!name || !url) {
      return NextResponse.json({ error: 'Name and URL are required' }, { status: 400 });
    }

    // Validate URL format
    try {
      new URL(url);
    } catch {
      return NextResponse.json({ error: 'Invalid URL format' }, { status: 400 });
    }

    const webhook = await database.queryOne(
      `INSERT INTO webhooks (tenant_id, name, url, type, events, enabled, headers, created_at)
       VALUES ($1, $2, $3, $4, $5, $6, $7, NOW())
       RETURNING *`,
      [tenantId, name, url, type, JSON.stringify(events), true, JSON.stringify(headers || {})]
    );

    return NextResponse.json({
      success: true,
      webhook
    });

  } catch (error: any) {
    console.error('Webhook creation error:', error);
    return NextResponse.json({
      error: 'Failed to create webhook',
      details: error.message
    }, { status: 500 });
  }
}

export async function GET(req: NextRequest) {
  // Get tenant ID from middleware-injected headers
  const tenantId = req.headers.get('x-tenant-id');
  if (!tenantId) {
    return NextResponse.json({ error: 'Authentication required' }, { status: 401 });
  }

  try {
    const webhooks = await database.queryMany(
      'SELECT * FROM webhooks WHERE tenant_id = $1 ORDER BY created_at DESC',
      [tenantId]
    );

    return NextResponse.json({
      success: true,
      webhooks: webhooks || []
    });

  } catch (error: any) {
    console.error('Webhooks GET error:', error);
    return NextResponse.json({
      error: 'Failed to retrieve webhooks',
      details: error.message
    }, { status: 500 });
  }
}

export async function DELETE(req: NextRequest) {
  // Get tenant ID from middleware-injected headers
  const tenantId = req.headers.get('x-tenant-id');
  if (!tenantId) {
    return NextResponse.json({ error: 'Authentication required' }, { status: 401 });
  }

  try {
    const { webhook_id } = await req.json();
    
    if (!webhook_id) {
      return NextResponse.json({ error: 'webhook_id required' }, { status: 400 });
    }

    // Verify webhook belongs to authenticated tenant before deleting
    const result = await database.queryOne(
      'DELETE FROM webhooks WHERE id = $1 AND tenant_id = $2 RETURNING id',
      [webhook_id, tenantId]
    );

    if (!result) {
      return NextResponse.json({ error: 'Webhook not found or unauthorized' }, { status: 404 });
    }

    return NextResponse.json({
      success: true,
      message: 'Webhook deleted'
    });

  } catch (error: any) {
    console.error('Webhook deletion error:', error);
    return NextResponse.json({
      error: 'Failed to delete webhook',
      details: error.message
    }, { status: 500 });
  }
}

export async function PATCH(req: NextRequest) {
  // Get tenant ID from middleware-injected headers
  const tenantId = req.headers.get('x-tenant-id');
  if (!tenantId) {
    return NextResponse.json({ error: 'Authentication required' }, { status: 401 });
  }

  try {
    const { webhook_id, enabled } = await req.json();
    
    if (!webhook_id || enabled === undefined) {
      return NextResponse.json({ error: 'webhook_id and enabled required' }, { status: 400 });
    }

    // Update webhook only if it belongs to authenticated tenant
    const webhook = await database.queryOne(
      `UPDATE webhooks 
       SET enabled = $1, updated_at = NOW() 
       WHERE id = $2 AND tenant_id = $3 
       RETURNING *`,
      [enabled, webhook_id, tenantId]
    );

    if (!webhook) {
      return NextResponse.json({ error: 'Webhook not found or unauthorized' }, { status: 404 });
    }

    return NextResponse.json({
      success: true,
      webhook
    });

  } catch (error: any) {
    console.error('Webhook update error:', error);
    return NextResponse.json({
      error: 'Failed to update webhook',
      details: error.message
    }, { status: 500 });
  }
}
