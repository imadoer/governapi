import { NextRequest, NextResponse } from 'next/server';
import { AuthService } from '../../../../services/auth';
import { StripeService } from '../../../../services/stripe-service';
import { database } from '../../../../infrastructure/database';

export async function POST(request: NextRequest) {
  try {
    const { apiKey, priceId } = await request.json();

    const authContext = await AuthService.validateApiKey(apiKey);
    if (!authContext) {
      return NextResponse.json({ error: 'Invalid API key' }, { status: 401 });
    }

    // CONVERTED TO POSTGRESQL - Get tenant data for Stripe customer info
    const tenant = await database.queryOne(
      'SELECT * FROM tenants WHERE id = $1',
      [authContext.tenantId]
    );

    // ALL EXISTING BUSINESS LOGIC PRESERVED EXACTLY AS-IS
    // Get or create Stripe customer
    let stripeCustomerId = tenant?.stripe_customer_id;
    
    if (!stripeCustomerId) {
      const stripeCustomer = await StripeService.createCustomer(
        tenant?.email,
        tenant?.name
      );
      stripeCustomerId = stripeCustomer.id;

      // CONVERTED TO POSTGRESQL - Update tenant with Stripe customer ID
      await database.query(
        'UPDATE tenants SET stripe_customer_id = $1 WHERE id = $2',
        [stripeCustomerId, authContext.tenantId]
      );
    }

    // Create checkout session
    const session = await StripeService.createCheckoutSession(
      stripeCustomerId,
      priceId,
      `${process.env.NEXT_PUBLIC_BASE_URL}/customer?success=true`,
      `${process.env.NEXT_PUBLIC_BASE_URL}/customer?canceled=true`
    );

    return NextResponse.json({
      success: true,
      sessionId: session.id,
      url: session.url
    });

  } catch (error) {
    console.error('Create checkout session error:', error);
    return NextResponse.json({ error: 'Failed to create checkout session' }, { status: 500 });
  }
}
