import { NextRequest, NextResponse } from 'next/server'
import { database } from '../../../infrastructure/database'

export async function POST(req: NextRequest) {
  // Get tenant ID from middleware-injected headers
  const tenantId = req.headers.get('x-tenant-id')
  if (!tenantId) {
    return NextResponse.json({ error: 'Authentication required' }, { status: 401 })
  }

  try {
    const body = await req.json()
    const { target, scanType, environment } = body

    if (!target) {
      return NextResponse.json({ error: 'Target endpoint required' }, { status: 400 })
    }

    // Check if API already exists for this tenant
    let api = await database.queryOne(
      'SELECT * FROM apis WHERE endpoint = $1 AND tenant_id = $2',
      [target, tenantId]
    )

    if (!api) {
      // Create new API record with tenant isolation
      api = await database.queryOne(
        `INSERT INTO apis (tenant_id, endpoint, method, environment, discovered_at, scan_type)
         VALUES ($1, $2, $3, $4, NOW(), $5) RETURNING *`,
        [tenantId, target, 'GET', environment || 'production', scanType || 'manual']
      )
    }

    // Perform real endpoint analysis (simplified for MVP)
    const scanId = `scan_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`
    
    let analysis = {
      endpoint: target,
      scan_id: scanId,
      reachable: false,
      response_time: null,
      security_score: 0,
      vulnerabilities: [],
      scan_completed: false
    }

    try {
      // Basic reachability test (in production, this would be more sophisticated)
      const startTime = Date.now()
      const response = await fetch(target, { 
        method: 'HEAD', 
        signal: AbortSignal.timeout(5000),
        headers: { 'User-Agent': 'GovernAPI-Scanner/1.0' }
      })
      
      analysis.reachable = response.ok
      analysis.response_time = Date.now() - startTime
      analysis.security_score = response.ok ? 75 : 0
      analysis.scan_completed = true

      // Basic security checks
      if (!response.headers.get('x-frame-options')) {
        analysis.vulnerabilities.push({
          type: 'MISSING_SECURITY_HEADER',
          severity: 'MEDIUM',
          details: 'Missing X-Frame-Options header'
        })
        analysis.security_score -= 10
      }

      if (!response.headers.get('x-content-type-options')) {
        analysis.vulnerabilities.push({
          type: 'MISSING_SECURITY_HEADER', 
          severity: 'LOW',
          details: 'Missing X-Content-Type-Options header'
        })
        analysis.security_score -= 5
      }

    } catch (error) {
      analysis.vulnerabilities.push({
        type: 'ENDPOINT_UNREACHABLE',
        severity: 'HIGH',
        details: `Failed to reach endpoint: ${error.message}`
      })
    }

    // Record scan result with tenant isolation
    await database.query(
      `INSERT INTO scan_results (tenant_id, api_id, scan_type, analysis, created_at)
       VALUES ($1, $2, $3, $4, NOW())`,
      [tenantId, api.id, scanType, JSON.stringify(analysis)]
    )

    return NextResponse.json({
      success: true,
      api_id: api.id,
      scan_id: scanId,
      analysis
    })

  } catch (error) {
    console.error('Scanner error:', error)
    return NextResponse.json({ 
      error: 'Scan failed',
      details: error.message 
    }, { status: 500 })
  }
}
