import { NextRequest, NextResponse } from 'next/server';
import { extendedDatabase } from '../../../infrastructure/database-extended';

interface AlertConfig {
  email: string;
  severity_threshold: 'LOW' | 'MEDIUM' | 'HIGH' | 'CRITICAL';
  enabled: boolean;
  tenant_id: string;
}

export async function POST(req: NextRequest) {
  try {
    const { email, severity_threshold = 'HIGH', tenant_id } = await req.json();

    if (!email || !tenant_id) {
      return NextResponse.json({ error: 'Email and tenant_id required' }, { status: 400 });
    }

    // Check if config exists
    const { data: existing } = await extendedDatabase.supabase
      .from('alert_configurations')
      .select('id')
      .eq('tenant_id', tenant_id)
      .eq('email', email)
      .single();

    if (existing) {
      // Update existing config
      const { error } = await extendedDatabase.supabase
        .from('alert_configurations')
        .update({
          severity_threshold,
          enabled: true,
          updated_at: new Date().toISOString()
        })
        .eq('id', existing.id);

      if (error) throw error;
    } else {
      // Create new config
      const { error } = await extendedDatabase.supabase
        .from('alert_configurations')
        .insert({
          tenant_id,
          email,
          severity_threshold,
          enabled: true,
          alert_on_critical: severity_threshold === 'CRITICAL',
          alert_on_high: ['CRITICAL', 'HIGH'].includes(severity_threshold),
          alert_on_medium: ['CRITICAL', 'HIGH', 'MEDIUM'].includes(severity_threshold),
          created_at: new Date().toISOString()
        });

      if (error) throw error;
    }

    return NextResponse.json({
      success: true,
      message: 'Alert configuration saved'
    });

  } catch (error: any) {
    console.error('Alert config POST error:', error);
    return NextResponse.json({
      error: 'Failed to save alert configuration',
      details: error.message
    }, { status: 500 });
  }
}

export async function GET(req: NextRequest) {
  try {
    const url = new URL(req.url);
    const tenant_id = url.searchParams.get('tenant_id');

    if (!tenant_id) {
      return NextResponse.json({ error: 'tenant_id required' }, { status: 400 });
    }

    const { data: configs, error } = await extendedDatabase.supabase
      .from('alert_configurations')
      .select('*')
      .eq('tenant_id', tenant_id);

    if (error) throw error;

    return NextResponse.json({
      success: true,
      configs: configs || []
    });

  } catch (error: any) {
    console.error('Alert config GET error:', error);
    return NextResponse.json({
      error: 'Failed to retrieve alert configurations',
      details: error.message
    }, { status: 500 });
  }
}

export async function DELETE(req: NextRequest) {
  try {
    const { email, tenant_id } = await req.json();

    if (!email || !tenant_id) {
      return NextResponse.json({ error: 'Email and tenant_id required' }, { status: 400 });
    }

    const { error } = await extendedDatabase.supabase
      .from('alert_configurations')
      .delete()
      .eq('tenant_id', tenant_id)
      .eq('email', email);

    if (error) throw error;

    return NextResponse.json({
      success: true,
      message: 'Alert configuration deleted'
    });

  } catch (error: any) {
    console.error('Alert config DELETE error:', error);
    return NextResponse.json({
      error: 'Failed to delete alert configuration',
      details: error.message
    }, { status: 500 });
  }
}
