import { NextResponse } from 'next/server';
import { extendedDatabase } from '../../../../infrastructure/database-extended';

interface Vulnerability {
  severity: 'CRITICAL' | 'HIGH' | 'MEDIUM' | 'LOW';
  title: string;
  description: string;
}

interface ScanResults {
  id: string;
  tenant_id: string;
  target: string;
  overall_risk: string;
  findings: {
    vulnerabilities: Vulnerability[];
  };
  created_at: string;
}

async function sendEmailAlert(email: string, scanResults: ScanResults) {
  const vulnerabilities = scanResults.findings?.vulnerabilities || [];
  const criticalVulns = vulnerabilities.filter((v: Vulnerability) => v.severity === 'CRITICAL').length;
  const highVulns = vulnerabilities.filter((v: Vulnerability) => v.severity === 'HIGH').length;
  const mediumVulns = vulnerabilities.filter((v: Vulnerability) => v.severity === 'MEDIUM').length;
  const lowVulns = vulnerabilities.filter((v: Vulnerability) => v.severity === 'LOW').length;

  const emailContent = {
    to: email,
    subject: `GovernAPI Security Alert - ${vulnerabilities.length} vulnerabilities found`,
    body: `
Security Scan Alert for ${scanResults.target}

Critical: ${criticalVulns}
High: ${highVulns}
Medium: ${mediumVulns}
Low: ${lowVulns}

Overall Risk: ${scanResults.overall_risk}

View full report at: ${process.env.NEXT_PUBLIC_APP_URL}/dashboard/security-scans/${scanResults.id}
    `.trim()
  };

  // In production, integrate with SendGrid, AWS SES, etc.
  console.log('EMAIL ALERT:', {
    to: email,
    subject: emailContent.subject,
    vulnerabilityCount: vulnerabilities.length
  });

  // Store notification record
  await extendedDatabase.supabase
    .from('notifications')
    .insert({
      tenant_id: scanResults.tenant_id,
      type: 'security_alert',
      title: emailContent.subject,
      message: emailContent.body,
      severity: criticalVulns > 0 ? 'critical' : highVulns > 0 ? 'high' : 'medium',
      sent_to: email,
      created_at: new Date().toISOString()
    });

  return true;
}

export async function POST() {
  try {
    // Get recent security scans that haven't been notified
    const { data: recentScans, error: scansError } = await extendedDatabase.supabase
      .from('security_scans')
      .select('*')
      .eq('notification_sent', false)
      .gte('created_at', new Date(Date.now() - 60 * 60 * 1000).toISOString()) // Last hour
      .order('created_at', { ascending: false });

    if (scansError) throw scansError;

    if (!recentScans || recentScans.length === 0) {
      return NextResponse.json({ message: 'No new scans to process' });
    }

    // Get alert configurations for affected tenants
    const tenantIds = Array.from(new Set(recentScans.map((scan: any) => scan.tenant_id)));
    const { data: alertConfigs } = await extendedDatabase.supabase
      .from('alert_configurations')
      .select('*')
      .in('tenant_id', tenantIds)
      .eq('enabled', true);

    let sentCount = 0;

    for (const scan of recentScans) {
      const vulnerabilities = scan.findings?.vulnerabilities || [];
      const hasCritical = vulnerabilities.some((v: Vulnerability) => v.severity === 'CRITICAL');
      const hasHigh = vulnerabilities.some((v: Vulnerability) => v.severity === 'HIGH');
      const hasMedium = vulnerabilities.some((v: Vulnerability) => v.severity === 'MEDIUM');

      // Find alert config for this tenant
      const config = alertConfigs?.find((c: any) => c.tenant_id === scan.tenant_id);

      if (!config) continue;

      // Check if severity threshold is met
      const shouldAlert = 
        (config.alert_on_critical && hasCritical) ||
        (config.alert_on_high && hasHigh) ||
        (config.alert_on_medium && hasMedium);

      if (shouldAlert) {
        await sendEmailAlert(config.email, scan);
        sentCount++;

        // Mark scan as notified
        await extendedDatabase.supabase
          .from('security_scans')
          .update({ notification_sent: true })
          .eq('id', scan.id);
      }
    }

    return NextResponse.json({
      success: true,
      scansProcessed: recentScans.length,
      alertsSent: sentCount
    });

  } catch (error: any) {
    console.error('Notification monitor error:', error);
    return NextResponse.json({
      error: 'Failed to process notifications',
      details: error.message
    }, { status: 500 });
  }
}
