import { NextRequest, NextResponse } from 'next/server'
import { database } from '../../../../infrastructure/database'

export async function POST(req: NextRequest) {
  // Get tenant ID from middleware-injected headers
  const tenantId = req.headers.get('x-tenant-id')
  if (!tenantId) {
    return NextResponse.json({ error: 'Authentication required' }, { status: 401 })
  }

  try {
    const formData = await req.formData()
    const file = formData.get('file') as File

    if (!file) {
      return NextResponse.json({ error: 'File is required' }, { status: 400 })
    }

    // Validate file type and size
    if (!file.name.toLowerCase().endsWith('.json') && !file.name.toLowerCase().endsWith('.yaml')) {
      return NextResponse.json({ error: 'Only JSON and YAML files are supported' }, { status: 400 })
    }

    if (file.size > 5 * 1024 * 1024) { // 5MB limit
      return NextResponse.json({ error: 'File size must be less than 5MB' }, { status: 400 })
    }

    const content = await file.text()
    
    // Limit content size to prevent memory exhaustion
    if (content.length > 1024 * 1024) { // 1MB text limit
      return NextResponse.json({ error: 'File content too large' }, { status: 400 })
    }

    let spec
    try {
      spec = JSON.parse(content)
    } catch (parseError) {
      return NextResponse.json({ error: 'Invalid JSON format' }, { status: 400 })
    }

    // Validate OpenAPI spec structure
    if (!spec.openapi && !spec.swagger) {
      return NextResponse.json({ error: 'Not a valid OpenAPI specification' }, { status: 400 })
    }

    if (!spec.paths || typeof spec.paths !== 'object') {
      return NextResponse.json({ error: 'OpenAPI spec must contain paths' }, { status: 400 })
    }

    // Parse OpenAPI spec and create APIs with tenant isolation
    const apis = []
    const baseUrl = spec.servers?.[0]?.url || 'https://api.example.com'
    const importId = `import_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`

    for (const [path, methods] of Object.entries(spec.paths || {})) {
      for (const [method, details] of Object.entries(methods as Record<string, any>)) {
        if (['get', 'post', 'put', 'delete', 'patch'].includes(method)) {
          try {
            // Create API entry with tenant isolation
            const api = await database.queryOne(
              `INSERT INTO apis (tenant_id, name, endpoint, method, type, classification, environment, metadata, import_id, created_at)
               VALUES ($1, $2, $3, $4, $5, $6, $7, $8, $9, NOW())
               RETURNING *`,
              [
                tenantId,
                (details as any)?.summary || `${method.toUpperCase()} ${path}`,
                `${baseUrl}${path}`,
                method.toUpperCase(),
                'REST',
                (details as any)['x-classification'] || 'unclassified',
                'production',
                JSON.stringify({
                  description: (details as any)?.description,
                  parameters: (details as any)?.parameters || [],
                  responses: (details as any)?.responses || {},
                  tags: (details as any)?.tags || []
                }),
                importId
              ]
            )
            if (api) apis.push(api)
          } catch (dbError) {
            console.error('Failed to insert API:', dbError)
            // Continue with other APIs even if one fails
          }
        }
      }
    }

    // Log the import operation
    await database.query(
      `INSERT INTO import_logs (tenant_id, import_id, file_name, apis_imported, created_at)
       VALUES ($1, $2, $3, $4, NOW())`,
      [tenantId, importId, file.name, apis.length]
    )

    return NextResponse.json({ 
      success: true, 
      imported: apis.length, 
      import_id: importId,
      apis: apis.slice(0, 10) // Return first 10 for preview
    })

  } catch (error) {
    console.error('OpenAPI import error:', error)
    return NextResponse.json({ 
      success: false, 
      error: 'Failed to import OpenAPI specification' 
    }, { status: 500 })
  }
}
