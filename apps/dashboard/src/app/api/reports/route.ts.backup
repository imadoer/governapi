import { NextRequest, NextResponse } from 'next/server'
import { database } from '../../../infrastructure/database'

function getUserFromToken(req: NextRequest) {
  const authHeader = req.headers.get('authorization')
  if (!authHeader?.startsWith('Bearer ')) {
    return null
  }
  const token = authHeader.substring(7)
  return { userId: token, email: 'user@example.com' }
}

export async function POST(req: NextRequest) {
  try {
    const user = getUserFromToken(req)
    if (!user) {
      return NextResponse.json({ error: 'Unauthorized' }, { status: 401 })
    }

    const { report_type, date_range, filters } = await req.json()

    let reportData = {}

    if (report_type === 'security') {
      const threats = await database.queryMany(
        'SELECT * FROM threats WHERE user_id = $1 AND created_at >= $2',
        [user.userId, date_range.start]
      )
      
      reportData = {
        type: 'security',
        threats_detected: threats.length,
        high_severity: threats.filter(t => t.severity === 'HIGH').length,
        blocked_requests: threats.filter(t => t.blocked).length
      }
    } else if (report_type === 'performance') {
      const metrics = await database.queryMany(
        'SELECT * FROM performance_metrics WHERE user_id = $1 AND created_at >= $2',
        [user.userId, date_range.start]
      )
      
      reportData = {
        type: 'performance',
        avg_response_time: metrics.reduce((sum, m) => sum + m.response_time, 0) / metrics.length,
        total_requests: metrics.length,
        error_rate: metrics.filter(m => m.status >= 400).length / metrics.length * 100
      }
    }

    return NextResponse.json({ report: reportData })
  } catch (error) {
    return NextResponse.json({ error: 'Report generation failed' }, { status: 500 })
  }
}
