import { logger } from "../../../../utils/logging/logger"
import { NextRequest, NextResponse } from 'next/server'
import { database } from '../../../../infrastructure/database'

export async function GET(request: NextRequest) {
  const tenantId = request.headers.get('x-tenant-id')
  if (!tenantId) {
    return NextResponse.json({ error: 'Authentication required' }, { status: 401 })
  }

  try {
    const url = new URL(request.url)
    const timeframe = url.searchParams.get('timeframe') || '30d'
    const threatType = url.searchParams.get('type')

    // Validate timeframe
    const validTimeframes = ['24h', '7d', '30d', '90d']
    if (!validTimeframes.includes(timeframe)) {
      return NextResponse.json({ error: 'Invalid timeframe. Allowed: ' + validTimeframes.join(', ') }, { status: 400 })
    }

    // Calculate interval based on timeframe
    const intervalMap = {
      '24h': '24 hours',
      '7d': '7 days', 
      '30d': '30 days',
      '90d': '90 days'
    }

    const interval = intervalMap[timeframe as keyof typeof intervalMap]

    // Get threat trends over time
    const threatTrends = await database.queryMany(
      `SELECT 
         DATE_TRUNC('day', created_at) as date,
         COUNT(*) as total_threats,
         COUNT(CASE WHEN severity = 'CRITICAL' THEN 1 END) as critical_threats,
         COUNT(CASE WHEN severity = 'HIGH' THEN 1 END) as high_threats,
         COUNT(CASE WHEN severity = 'MEDIUM' THEN 1 END) as medium_threats,
         COUNT(CASE WHEN severity = 'LOW' THEN 1 END) as low_threats,
         COUNT(CASE WHEN status = 'blocked' THEN 1 END) as blocked_threats
       FROM threat_events 
       WHERE tenant_id = $1 AND created_at >= NOW() - INTERVAL '${interval}'
       ${threatType ? 'AND threat_type = $2' : ''}
       GROUP BY DATE_TRUNC('day', created_at)
       ORDER BY date ASC`,
      threatType ? [tenantId, threatType] : [tenantId]
    )

    // Get threat type distribution
    const threatTypeDistribution = await database.queryMany(
      `SELECT 
         threat_type,
         COUNT(*) as count,
         COUNT(CASE WHEN status = 'blocked' THEN 1 END) as blocked_count,
         AVG(risk_score) as avg_risk_score
       FROM threat_events 
       WHERE tenant_id = $1 AND created_at >= NOW() - INTERVAL '${interval}'
       GROUP BY threat_type
       ORDER BY count DESC`,
      [tenantId]
    )

    // Get source analysis
    const sourceAnalysis = await database.queryMany(
      `SELECT 
         source_ip,
         COUNT(*) as threat_count,
         COUNT(DISTINCT threat_type) as unique_threat_types,
         MAX(created_at) as last_seen,
         COUNT(CASE WHEN status = 'blocked' THEN 1 END) as blocked_count
       FROM threat_events 
       WHERE tenant_id = $1 AND created_at >= NOW() - INTERVAL '${interval}'
       GROUP BY source_ip
       ORDER BY threat_count DESC
       LIMIT 10`,
      [tenantId]
    )

    // Get threat summary statistics
    const threatSummary = await database.queryOne(
      `SELECT 
         COUNT(*) as total_threats,
         COUNT(CASE WHEN status = 'blocked' THEN 1 END) as blocked_threats,
         COUNT(CASE WHEN status = 'allowed' THEN 1 END) as allowed_threats,
         COUNT(CASE WHEN severity = 'CRITICAL' THEN 1 END) as critical_threats,
         COUNT(DISTINCT source_ip) as unique_sources,
         COUNT(DISTINCT threat_type) as unique_threat_types,
         AVG(risk_score) as avg_risk_score
       FROM threat_events 
       WHERE tenant_id = $1 AND created_at >= NOW() - INTERVAL '${interval}'`,
      [tenantId]
    )

    // Get recent high-severity threats
    const recentHighThreats = await database.queryMany(
      `SELECT 
         id, threat_type, severity, source_ip, target_endpoint, 
         risk_score, status, created_at, details
       FROM threat_events 
       WHERE tenant_id = $1 AND severity IN ('CRITICAL', 'HIGH')
       ORDER BY created_at DESC 
       LIMIT 10`,
      [tenantId]
    )

    const totalThreats = parseInt(threatSummary?.total_threats || '0')
    const blockedThreats = parseInt(threatSummary?.blocked_threats || '0')

    return NextResponse.json({
      success: true,
      threatTrends: {
        timeframe,
        summary: {
          totalThreats,
          blockedThreats,
          allowedThreats: parseInt(threatSummary?.allowed_threats || '0'),
          criticalThreats: parseInt(threatSummary?.critical_threats || '0'),
          uniqueSources: parseInt(threatSummary?.unique_sources || '0'),
          uniqueThreatTypes: parseInt(threatSummary?.unique_threat_types || '0'),
          averageRiskScore: threatSummary?.avg_risk_score ? Math.round(parseFloat(threatSummary.avg_risk_score)) : null,
          blockRate: totalThreats > 0 ? Math.round((blockedThreats / totalThreats) * 100 * 100) / 100 : 0
        },
        dailyTrends: threatTrends.map(trend => ({
          date: trend.date,
          totalThreats: parseInt(trend.total_threats || '0'),
          criticalThreats: parseInt(trend.critical_threats || '0'),
          highThreats: parseInt(trend.high_threats || '0'),
          mediumThreats: parseInt(trend.medium_threats || '0'),
          lowThreats: parseInt(trend.low_threats || '0'),
          blockedThreats: parseInt(trend.blocked_threats || '0')
        })),
        threatTypeDistribution: threatTypeDistribution.map(type => ({
          threatType: type.threat_type,
          count: parseInt(type.count || '0'),
          blockedCount: parseInt(type.blocked_count || '0'),
          averageRiskScore: type.avg_risk_score ? Math.round(parseFloat(type.avg_risk_score)) : null
        })),
        topSources: sourceAnalysis.map(source => ({
          sourceIp: source.source_ip,
          threatCount: parseInt(source.threat_count || '0'),
          uniqueThreatTypes: parseInt(source.unique_threat_types || '0'),
          lastSeen: source.last_seen,
          blockedCount: parseInt(source.blocked_count || '0')
        })),
        recentHighThreats: recentHighThreats.map(threat => ({
          id: threat.id,
          threatType: threat.threat_type,
          severity: threat.severity,
          sourceIp: threat.source_ip,
          targetEndpoint: threat.target_endpoint,
          riskScore: threat.risk_score,
          status: threat.status,
          detectedAt: threat.created_at,
          details: threat.details
        }))
      }
    })

  } catch (error) {
    logger.error('Threat trends API error:', { error: error instanceof Error ? error.message : String(error) })
    return NextResponse.json({ error: 'Failed to fetch threat trends' }, { status: 500 })
  }
}
