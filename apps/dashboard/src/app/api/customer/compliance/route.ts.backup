import { logger } from "../../../../utils/logging/logger";
import { NextRequest, NextResponse } from "next/server";
import { database } from "../../../../infrastructure/database";

export async function GET(request: NextRequest) {
  const tenantId = request.headers.get("x-tenant-id");
  if (!tenantId) {
    return NextResponse.json(
      { error: "Authentication required" },
      { status: 401 },
    );
  }

  try {
    // Get compliance framework data
    const complianceData = await database.queryMany(
      `SELECT cf.framework_name, cf.version, ccr.status, ccr.compliance_percentage, 
              ccr.last_assessment, ccr.next_assessment, ccr.findings_count
       FROM compliance_frameworks cf
       LEFT JOIN compliance_check_results ccr ON cf.id = ccr.framework_id AND ccr.tenant_id = $1
       ORDER BY cf.framework_name`,
      [tenantId],
    );

    // Get compliance violations and findings
    const complianceFindings = await database.queryMany(
      `SELECT id, framework_name, control_id, control_name, finding_type, severity, 
              status, description, remediation_steps, discovered_at, due_date
       FROM compliance_findings 
       WHERE tenant_id = $1 AND status != 'resolved'
       ORDER BY severity DESC, discovered_at DESC
       LIMIT 20`,
      [tenantId],
    );

    // Get audit history
    const auditHistory = await database.queryMany(
      `SELECT id, audit_type, framework_name, conducted_by, status, 
              findings_count, completion_date, report_url
       FROM compliance_audits 
       WHERE tenant_id = $1 
       ORDER BY completion_date DESC 
       LIMIT 10`,
      [tenantId],
    );

    // Calculate overall compliance score
    const complianceScores = complianceData
      .filter((item) => item.compliance_percentage !== null)
      .map((item) => parseFloat(item.compliance_percentage));

    const overallScore =
      complianceScores.length > 0
        ? Math.round(
            complianceScores.reduce((sum, score) => sum + score, 0) /
              complianceScores.length,
          )
        : 0;

    // Get compliance statistics
    const complianceStats = await database.queryOne(
      `SELECT 
         COUNT(CASE WHEN status = 'compliant' THEN 1 END) as compliant_controls,
         COUNT(CASE WHEN status = 'non_compliant' THEN 1 END) as non_compliant_controls,
         COUNT(CASE WHEN status = 'pending' THEN 1 END) as pending_controls,
         COUNT(*) as total_controls
       FROM compliance_check_results 
       WHERE tenant_id = $1`,
      [tenantId],
    );

    const formattedFrameworks = complianceData.map((framework) => ({
      frameworkName: framework.framework_name,
      version: framework.version,
      status: framework.status || "not_assessed",
      compliancePercentage: framework.compliance_percentage
        ? Math.round(parseFloat(framework.compliance_percentage))
        : null,
      lastAssessment: framework.last_assessment,
      nextAssessment: framework.next_assessment,
      findingsCount: parseInt(framework.findings_count || "0"),
    }));

    return NextResponse.json({
      success: true,
      compliance: {
        overallScore,
        frameworks: formattedFrameworks,
        statistics: {
          compliantControls: parseInt(
            complianceStats?.compliant_controls || "0",
          ),
          nonCompliantControls: parseInt(
            complianceStats?.non_compliant_controls || "0",
          ),
          pendingControls: parseInt(complianceStats?.pending_controls || "0"),
          totalControls: parseInt(complianceStats?.total_controls || "0"),
        },
        findings: complianceFindings.map((finding) => ({
          id: finding.id,
          frameworkName: finding.framework_name,
          controlId: finding.control_id,
          controlName: finding.control_name,
          findingType: finding.finding_type,
          severity: finding.severity,
          status: finding.status,
          description: finding.description,
          remediationSteps: finding.remediation_steps,
          discoveredAt: finding.discovered_at,
          dueDate: finding.due_date,
        })),
        auditHistory: auditHistory.map((audit) => ({
          id: audit.id,
          auditType: audit.audit_type,
          frameworkName: audit.framework_name,
          conductedBy: audit.conducted_by,
          status: audit.status,
          findingsCount: parseInt(audit.findings_count || "0"),
          completionDate: audit.completion_date,
          reportUrl: audit.report_url,
        })),
        lastUpdated: new Date().toISOString(),
      },
    });
  } catch (error) {
    logger.error("Compliance API error:", {
      error: error instanceof Error ? error.message : String(error),
    });
    return NextResponse.json(
      { error: "Failed to fetch compliance data" },
      { status: 500 },
    );
  }
}

export async function POST(request: NextRequest) {
  const tenantId = request.headers.get("x-tenant-id");
  const userId = request.headers.get("x-user-id");

  if (!tenantId) {
    return NextResponse.json(
      { error: "Authentication required" },
      { status: 401 },
    );
  }

  try {
    const { frameworkName, assessmentType = "manual" } = await request.json();

    if (!frameworkName) {
      return NextResponse.json(
        { error: "Framework name is required" },
        { status: 400 },
      );
    }

    // Validate framework exists
    const framework = await database.queryOne(
      "SELECT id FROM compliance_frameworks WHERE framework_name = $1",
      [frameworkName],
    );

    if (!framework) {
      return NextResponse.json(
        { error: "Invalid compliance framework" },
        { status: 400 },
      );
    }

    // Create compliance assessment
    const assessment = await database.queryOne(
      `INSERT INTO compliance_audits (tenant_id, framework_id, framework_name, audit_type, 
                                      status, conducted_by, started_at, created_at)
       VALUES ($1, $2, $3, $4, $5, $6, NOW(), NOW()) RETURNING *`,
      [
        tenantId,
        framework.id,
        frameworkName,
        assessmentType,
        "in_progress",
        userId || "system",
      ],
    );

    if (!assessment) {
      return NextResponse.json(
        { error: "Failed to create compliance assessment" },
        { status: 500 },
      );
    }

    return NextResponse.json({
      success: true,
      assessment: {
        id: assessment.id,
        frameworkName: assessment.framework_name,
        auditType: assessment.audit_type,
        status: assessment.status,
        startedAt: assessment.started_at,
      },
      message: "Compliance assessment initiated successfully",
    });
  } catch (error) {
    logger.error("Compliance assessment creation error:", {
      error: error instanceof Error ? error.message : String(error),
    });
    return NextResponse.json(
      { error: "Failed to create compliance assessment" },
      { status: 500 },
    );
  }
}
