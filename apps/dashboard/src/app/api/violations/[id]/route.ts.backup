import { NextRequest, NextResponse } from 'next/server'
import { database } from '../../../../infrastructure/database'

export async function PATCH(
  request: NextRequest,
  { params }: { params: Promise<{ id: string }> }
) {
  try {
    const { id } = await params
    const body = await request.json()

    // CONVERTED TO POSTGRESQL - Update violation
    const violation = await database.queryOne(
      `UPDATE violations 
       SET ${Object.keys(body).map((key, index) => `${key} = $${index + 2}`).join(', ')}
       WHERE id = $1
       RETURNING *`,
      [id, ...Object.values(body)]
    );

    if (!violation) {
      return NextResponse.json({ error: 'Violation not found' }, { status: 404 });
    }

    return NextResponse.json({ violation });

  } catch (error) {
    return NextResponse.json({ error: 'Failed to update violation' }, { status: 500 })
  }
}

export async function DELETE(
  request: NextRequest,
  { params }: { params: Promise<{ id: string }> }
) {
  try {
    const { id } = await params

    // CONVERTED TO POSTGRESQL - Delete violation
    await database.query(
      'DELETE FROM violations WHERE id = $1',
      [id]
    );

    return NextResponse.json({ success: true })

  } catch (error) {
    return NextResponse.json({ error: 'Failed to delete violation' }, { status: 500 })
  }
}
