import { NextRequest, NextResponse } from 'next/server'

interface DiscoveredAPI {
  url: string
  method: string
  status_code: number
  response_time: number
  content_type: string
  server: string
  discovered_at: string
  api_type: 'REST' | 'GraphQL' | 'SOAP' | 'Unknown'
  authentication_required: boolean
}

// Extend global type for our cache
declare global {
  var discoveredAPIs: DiscoveredAPI[] | undefined
}

async function scanNetworkRange(baseUrl: string): Promise<DiscoveredAPI[]> {
  const discovered: DiscoveredAPI[] = []
  const commonPaths = [
    '/api', '/api/v1', '/api/v2', '/api/v3',
    '/rest', '/graphql', '/soap',
    '/users', '/auth', '/login', '/status', '/health',
    '/docs', '/swagger', '/openapi.json'
  ]

  for (const path of commonPaths) {
    try {
      const url = `${baseUrl}${path}`
      const startTime = Date.now()
      
      const response = await fetch(url, {
        method: 'GET',
        // timeout: 5000,
        headers: {
          'User-Agent': 'GoverAPI-Discovery/1.0'
        }
      })
      
      const responseTime = Date.now() - startTime
      
      if (response.ok) {
        const api: DiscoveredAPI = {
          url,
          method: 'GET',
          status_code: response.status,
          response_time: responseTime,
          content_type: response.headers.get('content-type') || 'unknown',
          server: response.headers.get('server') || 'unknown',
          discovered_at: new Date().toISOString(),
          api_type: determineAPIType(response),
          authentication_required: response.headers.get('www-authenticate') !== null
        }
        discovered.push(api)
      }
    } catch (error) {
      // Skip failed requests
      continue
    }
  }

  return discovered
}

function determineAPIType(response: Response): 'REST' | 'GraphQL' | 'SOAP' | 'Unknown' {
  const contentType = response.headers.get('content-type') || ''
  
  if (contentType.includes('application/json')) {
    return 'REST'
  } else if (contentType.includes('application/soap')) {
    return 'SOAP'
  } else if (response.url.includes('graphql')) {
    return 'GraphQL'
  }
  
  return 'Unknown'
}

export async function GET(request: NextRequest) {
  try {
    const { searchParams } = new URL(request.url)
    const format = searchParams.get('format') || 'json'
    
    // Get cached discovered APIs
    const cached = global.discoveredAPIs || []
    
    const stats = {
      totalAPIs: cached.length,
      activeAPIs: cached.filter(api => api.status_code === 200).length,
      publicAPIs: cached.filter(api => !api.authentication_required).length,
      privateAPIs: cached.filter(api => api.authentication_required).length
    }

    return NextResponse.json({
      success: true,
      apis: cached,
      stats,
      timestamp: new Date().toISOString()
    })
  } catch (error) {
    console.error('Discovery GET error:', error)
    return NextResponse.json(
      { error: 'Failed to retrieve discovered APIs' },
      { status: 500 }
    )
  }
}

export async function POST(request: NextRequest) {
  try {
    const body = await request.json()
    const { target, scanType = 'shallow' } = body
    
    if (!target) {
      return NextResponse.json(
        { error: 'Target parameter is required' },
        { status: 400 }
      )
    }

    // Perform discovery scan
    const discovered = await scanNetworkRange(target)
    
    // Store discovered APIs in global cache
    if (!global.discoveredAPIs) {
      global.discoveredAPIs = []
    }
    
    const existing = global.discoveredAPIs.map((api: DiscoveredAPI) => api.url)
    const newAPIs = discovered.filter(api => !existing.includes(api.url))
    global.discoveredAPIs.push(...newAPIs)
    
    // Limit cache size
    if (global.discoveredAPIs.length > 1000) {
      global.discoveredAPIs = global.discoveredAPIs.slice(-1000)
    }

    return NextResponse.json({
      success: true,
      discovered: newAPIs.length,
      total: global.discoveredAPIs.length,
      apis: newAPIs
    })
  } catch (error) {
    console.error('Discovery POST error:', error)
    return NextResponse.json(
      { error: 'Failed to perform API discovery' },
      { status: 500 }
    )
  }
}
