import { NextRequest, NextResponse } from 'next/server'

export async function GET(request: NextRequest) {
  const headers = {
    'Content-Type': 'application/json',
    'Cache-Control': 'no-cache'
  }

  try {
    let customers = []
    let isLive = false

    // Try database connection with timeout
    try {
      const { createClient } = await import('@supabase/supabase-js')
      const supabase = createClient(
      const { data: users } = await Promise.race([
        supabase
          .from('users')
          .select(`
            id, email, first_name, last_name, created_at, last_login,
            companies (company_name, subscription_plan, subscription_status, api_key)
          `)
          .limit(50),
        new Promise((_, reject) => setTimeout(() => reject(new Error('Timeout')), 5000))
      ])
          .limit(50),
        new Promise((_, reject) => setTimeout(() => reject(new Error('Timeout')), 5000))
      
      if (users && users.length > 0) {
        customers = users.map((user: any) => ({
          key: user.id,
          id: user.id,
          company: user.companies?.company_name || `Customer ${user.id}`,
          email: user.email,
          contactName: `${user.first_name || 'Unknown'} ${user.last_name || 'User'}`,
          plan: formatPlan(user.companies?.subscription_plan || 'starter'),
          status: formatStatus(user.companies?.subscription_status || 'active'),
          monthlyRevenue: getPlanRevenue(user.companies?.subscription_plan),
          joinDate: user.created_at ? new Date(user.created_at).toLocaleDateString() : 'Unknown',
          lastActive: getTimeAgo(user.last_login),
          apiKey: user.companies?.api_key || 'Not generated'
        }))
        isLive = true
      }
    } catch (dbError) {
      console.log('Database connection failed:', (dbError as Error)?.message)
    }

    return new NextResponse(JSON.stringify({ 
      success: true, 
      customers,
      count: customers.length,
      isLive,
      message: isLive ? 'Live data from database' : 'Database temporarily unavailable - showing empty state'
    }), { headers })

  } catch (error) {
    return new NextResponse(JSON.stringify({
      success: false,
      customers: [],
      error: 'Service temporarily unavailable'
    }), { status: 200, headers })
  }
}

function formatPlan(plan: string) {
  if (!plan) return 'Starter'
  return plan.split('_').map((word: string) => 
    word.charAt(0).toUpperCase() + word.slice(1)
  ).join(' ')
}

function formatStatus(status: string) {
  if (!status) return 'Active'  
  return status.charAt(0).toUpperCase() + status.slice(1)
}

function getPlanRevenue(plan: string) {
  const revenues = { starter: 29, professional: 79, enterprise: 199, enterprise_pro: 299, enterprise_ultimate: 599 }
  return revenues[plan as keyof typeof revenues] || 29
}

function getTimeAgo(dateString: string) {
  if (!dateString) return 'Never logged in'
  const now = new Date()
  const date = new Date(dateString)
  const diffHours = Math.floor((now.getTime() - date.getTime()) / (1000 * 60 * 60))
  
  if (diffHours < 1) return 'Active now'
  if (diffHours < 24) return `${diffHours} hours ago`
  const diffDays = Math.floor(diffHours / 24)
  if (diffDays < 7) return `${diffDays} days ago`
  return `${Math.floor(diffDays / 30)} months ago`
}
