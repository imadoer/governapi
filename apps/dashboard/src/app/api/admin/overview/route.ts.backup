import { NextRequest, NextResponse } from 'next/server';
import { createClient } from '@supabase/supabase-js';
const supabase = createClient(process.env.NEXT_PUBLIC_SUPABASE_URL!, process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!);
import { database } from '../../../../infrastructure/database';

const ADMIN_API_KEY = process.env.ADMIN_API_KEY || 'admin_system_key';

export async function GET(request: NextRequest) {
  try {
    const adminKey = request.headers.get('x-admin-key') || request.headers.get('authorization');
    
    if (adminKey !== ADMIN_API_KEY) {
      return NextResponse.json({ error: 'Unauthorized' }, { status: 401 });
    }

    // Get basic tenant statistics
    const { data: tenants, error: tenantsError } = await supabase
      .from('tenants')
      .select('*')
      .order('created_at', { ascending: false });

    if (tenantsError) throw new Error(`Failed to get tenants: ${tenantsError.message}`);

    const totalCustomers = tenants?.length || 0;
    
    // Calculate monthly revenue (mock calculation)
    const monthlyRevenue = totalCustomers * 79; // Assume average $79/month

    // Get total API usage
    const { data: requests, error: requestsError } = await supabase
      .from('customer_requests')
      .select('id');

    const totalApiCalls = requests?.length || 0;

    // Get active threats
    const { data: threats, error: threatsError } = await supabase
      .from('blocked_threats')
      .select('id')
      .gt('blocked_until', new Date().toISOString());

    const activeThreats = threats?.length || 0;

    // Format recent customers
    const recentCustomers = (tenants || []).slice(0, 10).map(tenant => ({
      key: tenant.id,
      name: tenant.name,
      email: tenant.email,
      plan: 'Professional', // Mock data
      status: tenant.is_active ? 'Active' : 'Inactive',
      created_at: new Date(tenant.created_at).toLocaleDateString()
    }));

    return NextResponse.json({
      success: true,
      stats: {
        totalCustomers,
        monthlyRevenue,
        totalApiCalls,
        activeThreats
      },
      recentCustomers
    });

  } catch (error) {
    console.error('Admin overview error:', error);
    return NextResponse.json({ error: 'Failed to get admin data' }, { status: 500 });
  }
}
