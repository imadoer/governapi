import { NextRequest, NextResponse } from 'next/server';
import { database } from '../../../../infrastructure/database';
import { createClient } from '@supabase/supabase-js';
const supabase = createClient(process.env.NEXT_PUBLIC_SUPABASE_URL!, process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!);

const ADMIN_API_KEY = process.env.ADMIN_API_KEY || 'admin_system_key';

export async function GET(request: NextRequest) {
  try {
    const adminKey = request.headers.get('x-admin-key');
    if (adminKey !== ADMIN_API_KEY) {
      return NextResponse.json({ error: 'Unauthorized' }, { status: 401 });
    }

    // Get system-wide analytics
    const [requests, threats, scans, customers] = await Promise.all([
      supabase.from('customer_requests').select('*'),
      supabase.from('threat_events').select('*'),
      supabase.from('security_scans').select('*'),
      supabase.from('tenants').select('*').eq('is_active', true)
    ]);

    const totalApiCalls = requests.data?.length || 0;
    const totalThreats = threats.data?.length || 0;
    const totalScans = scans.data?.length || 0;
    const totalCustomers = customers.data?.length || 0;

    // Threat type breakdown
    const threatCounts = threats.data?.reduce((acc: any, threat) => {
      acc[threat.threat_type] = (acc[threat.threat_type] || 0) + 1;
      return acc;
    }, {}) || {};

    const topThreats = Object.entries(threatCounts)
      .map(([type, count]) => ({
        type,
        count,
        percentage: totalThreats > 0 ? Math.round(((count as number) / totalThreats) * 100) : 0
      }))
      .sort((a, b) => (b as any).count - (a as any).count)
      .slice(0, 10);

    return NextResponse.json({
      success: true,
      analytics: {
        totalApiCalls,
        totalThreats,
        totalScans,
        totalCustomers,
        topThreats,
        systemHealth: {
          uptime: 99.97,
          responseTime: 127,
          errorRate: 0.12
        }
      }
    });

  } catch (error) {
    console.error('Analytics error:', error);
    return NextResponse.json({ error: 'Failed to get analytics' }, { status: 500 });
  }
}
