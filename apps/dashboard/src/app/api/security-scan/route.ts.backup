import { NextRequest, NextResponse } from 'next/server'

interface SecurityScanResult {
  target: string
  timestamp: string
  overall_risk: 'LOW' | 'MEDIUM' | 'HIGH' | 'CRITICAL'
  vulnerabilities: Array<{
    category: string
    severity: 'LOW' | 'MEDIUM' | 'HIGH' | 'CRITICAL'
    finding: string
    description: string
    recommendation: string
  }>
  owasp_findings: Array<{
    owasp_category: string
    vulnerable: boolean
    details: string
    test_performed: string
    confidence: 'LOW' | 'MEDIUM' | 'HIGH'
  }>
  ssl_analysis: {
    certificate_valid: boolean
    tls_version: string
    cipher_strength: string
    issues: string[]
  }
  headers_analysis: {
    security_headers_present: string[]
    security_headers_missing: string[]
    recommendations: string[]
  }
}

async function triggerWebhooks(target_url: string, scanResults: SecurityScanResult) {
  try {
    await fetch(`https://governapi.com/api/webhooks/trigger`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        event_type: "security_scan",
        data: {
          target: target_url,
          vulnerability_count: scanResults.vulnerabilities?.length || 0,
          overall_risk: scanResults.overall_risk,
          severity: scanResults.overall_risk,
          timestamp: scanResults.timestamp,
          critical_vulnerabilities: scanResults.vulnerabilities?.filter(v => v.severity === 'CRITICAL').length || 0,
          high_vulnerabilities: scanResults.vulnerabilities?.filter(v => v.severity === 'HIGH').length || 0
        }
      })
    })
    console.log('Webhooks triggered successfully')
  } catch (e) {
    console.log("Webhook trigger failed:", e)
  }
}

async function performAdvancedSecurityScan(targetUrl: string): Promise<SecurityScanResult> {
  console.log('Starting advanced security scan for:', targetUrl)
  
  const vulnerabilities = []
  const owaspFindings = []
  const timestamp = new Date().toISOString()

  let response
  let responseHeaders: Headers | null = null
  let responseText = ''

  // Fixed: Use AbortController for timeout instead of timeout option
  const controller = new AbortController()
  const timeoutId = setTimeout(() => controller.abort(), 3000)

  try {
    console.log('Fetching target URL...')
    response = await fetch(targetUrl, {
      method: 'GET',
      headers: { 'User-Agent': 'GovernAPI-Security-Scanner/1.0' },
      signal: controller.signal
    })
    clearTimeout(timeoutId)
    responseHeaders = response.headers
    responseText = await response.text()
    console.log('Response received, status:', response.status)
  } catch (error) {
    clearTimeout(timeoutId)
    console.error('Failed to fetch target URL:', error)
    vulnerabilities.push({
      category: 'Connectivity',
      severity: 'HIGH',
      finding: 'API endpoint unreachable',
      description: `Target API at ${targetUrl} is not responding to requests`,
      recommendation: 'Verify API is running and network accessible'
    })

    return {
      target: targetUrl,
      timestamp,
      overall_risk: 'HIGH',
      vulnerabilities,
      owasp_findings: [],
      ssl_analysis: { certificate_valid: false, tls_version: 'N/A', cipher_strength: 'N/A', issues: ['Connection failed'] },
      headers_analysis: { security_headers_present: [], security_headers_missing: [], recommendations: [] }
    }
  }

  // OWASP Tests with proper error isolation
  try {
    console.log('Testing API1: Object Level Authorization')
    const authTestFindings = await testObjectLevelAuth(targetUrl).catch(err => {
      console.error('API1 test failed:', err)
      return {
        owasp_category: 'API1: Broken Object Level Authorization',
        vulnerable: false,
        details: 'Test failed due to error: ' + err.message,
        test_performed: 'Object level authorization testing',
        confidence: 'LOW' as const
      }
    })
    owaspFindings.push(authTestFindings)

    console.log('Testing API2: User Authentication')
    const userAuthFindings = testUserAuthentication(responseHeaders, response.status)
    owaspFindings.push(userAuthFindings)
    if (userAuthFindings.vulnerable) {
      vulnerabilities.push({
        category: 'Authentication',
        severity: 'HIGH',
        finding: 'Weak or missing authentication',
        description: userAuthFindings.details,
        recommendation: 'Implement proper API authentication (API keys, OAuth, JWT)'
      })
    }

    console.log('Testing API3: Data Exposure')
    const dataExposureFindings = testDataExposure(responseText, responseHeaders)
    owaspFindings.push(dataExposureFindings)
    if (dataExposureFindings.vulnerable) {
      vulnerabilities.push({
        category: 'Data Exposure',
        severity: 'MEDIUM',
        finding: 'Potential excessive data exposure',
        description: dataExposureFindings.details,
        recommendation: 'Review API responses and filter sensitive data'
      })
    }

    console.log('Testing API4: Rate Limiting')
    const rateLimitFindings = await testRateLimiting(targetUrl, responseHeaders).catch(err => {
      console.error('API4 test failed:', err)
      return {
        owasp_category: 'API4: Lack of Resources & Rate Limiting',
        vulnerable: false,
        details: 'Rate limiting test failed: ' + err.message,
        test_performed: 'Rate limiting analysis',
        confidence: 'LOW' as const
      }
    })
    owaspFindings.push(rateLimitFindings)
    if (rateLimitFindings.vulnerable) {
      vulnerabilities.push({
        category: 'Rate Limiting',
        severity: 'MEDIUM',
        finding: 'No rate limiting detected',
        description: rateLimitFindings.details,
        recommendation: 'Implement rate limiting to prevent abuse'
      })
    }

    console.log('Testing API5: Function Level Authorization')
    const functionAuthFindings = await testFunctionLevelAuth(targetUrl).catch(err => {
      console.error('API5 test failed:', err)
      return {
        owasp_category: 'API5: Broken Function Level Authorization',
        vulnerable: false,
        details: 'Function authorization test failed: ' + err.message,
        test_performed: 'Function level authorization testing',
        confidence: 'LOW' as const
      }
    })
    owaspFindings.push(functionAuthFindings)

  } catch (error) {
    console.error('Error during OWASP testing:', error)
    owaspFindings.push({
      owasp_category: 'Testing Error',
      vulnerable: false,
      details: 'Error occurred during security testing: ' + (error as Error).message,
      test_performed: 'Attempted OWASP security tests',
      confidence: 'LOW'
    })
  }

  // SSL/TLS Analysis
  const url = new URL(targetUrl)
  const sslAnalysis = {
    certificate_valid: url.protocol === 'https:',
    tls_version: 'TLS 1.2+',
    cipher_strength: 'Strong',
    issues: [] as string[]
  }

  if (url.protocol === 'http:') {
    sslAnalysis.issues.push('API uses insecure HTTP instead of HTTPS')
    vulnerabilities.push({
      category: 'Transport Security',
      severity: 'CRITICAL',
      finding: 'Unencrypted HTTP communication',
      description: 'API traffic is transmitted in plain text without encryption',
      recommendation: 'Implement HTTPS with valid SSL/TLS certificate'
    })
  }

  // Security Headers Analysis
  const headersAnalysis = analyzeSecurityHeaders(responseHeaders)
  headersAnalysis.security_headers_missing.forEach(header => {
    vulnerabilities.push({
      category: 'Security Headers',
      severity: 'MEDIUM',
      finding: `Missing ${header} header`,
      description: `Security header ${header} is not set`,
      recommendation: `Configure ${header} header for enhanced security`
    })
  })

  // Determine overall risk level
  const criticalCount = vulnerabilities.filter(v => v.severity === 'CRITICAL').length
  const highCount = vulnerabilities.filter(v => v.severity === 'HIGH').length
  const mediumCount = vulnerabilities.filter(v => v.severity === 'MEDIUM').length

  let overallRisk: 'LOW' | 'MEDIUM' | 'HIGH' | 'CRITICAL'
  if (criticalCount > 0) overallRisk = 'CRITICAL'
  else if (highCount > 1) overallRisk = 'HIGH'
  else if (highCount > 0 || mediumCount > 2) overallRisk = 'MEDIUM'
  else overallRisk = 'LOW'

  console.log('Scan completed. Vulnerabilities found:', vulnerabilities.length)

  return {
    target: targetUrl,
    timestamp,
    overall_risk: overallRisk,
    vulnerabilities: vulnerabilities as SecurityScanResult['vulnerabilities'],
    owasp_findings: owaspFindings as SecurityScanResult['owasp_findings'],
    ssl_analysis: sslAnalysis,
    headers_analysis: headersAnalysis
  }
}

async function testObjectLevelAuth(targetUrl: string) {
  const url = new URL(targetUrl)
  
  const testPaths = [
    url.pathname.replace(/\/\d+/, '/999999'),
    url.pathname.replace(/\/\d+/, '/1'), 
    url.pathname + '/../admin',
    url.pathname + '/admin'
  ].filter(path => path !== url.pathname) // Only test different paths

  let vulnerableResponses = 0
  
  for (const testPath of testPaths) {
    try {
      const testUrl = `${url.origin}${testPath}`
      const controller = new AbortController()
      const timeoutId = setTimeout(() => controller.abort(), 3000)
      
      const testResponse = await fetch(testUrl, { 
        method: 'GET',
        signal: controller.signal
      })
      clearTimeout(timeoutId)
      
      if (testResponse.status === 200) {
        vulnerableResponses++
      }
    } catch (e) {
      // Ignore individual test failures
    }
  }
  
  return {
    owasp_category: 'API1: Broken Object Level Authorization',
    vulnerable: vulnerableResponses > 0,
    details: vulnerableResponses > 0 ? 
      `${vulnerableResponses} unauthorized access attempts succeeded` :
      'Object-level authorization tests passed',
    test_performed: 'ID manipulation and path traversal testing',
    confidence: vulnerableResponses > 1 ? 'HIGH' : vulnerableResponses > 0 ? 'MEDIUM' : 'LOW'
  }
}

function testUserAuthentication(headers: Headers | null, status: number) {
  const authHeaders = ['authorization', 'x-api-key', 'x-auth-token', 'authentication']
  
  // Fixed: Proper header checking
  const hasAuthHeaders = headers ? authHeaders.some(header => headers.has(header)) : false
  const hasWwwAuth = headers ? headers.has('www-authenticate') : false
  
  let vulnerable = false
  let details = ''
  let confidence: 'LOW' | 'MEDIUM' | 'HIGH' = 'MEDIUM'
  
  if (status === 401 || status === 403) {
    vulnerable = false
    details = 'Endpoint properly requires authentication'
    confidence = 'HIGH'
  } else if (hasWwwAuth) {
    vulnerable = false
    details = 'Authentication challenge detected'
    confidence = 'HIGH'
  } else if (hasAuthHeaders) {
    vulnerable = false
    details = 'Authentication headers present in response'
    confidence = 'MEDIUM'
  } else if (status === 200) {
    vulnerable = true
    details = 'Endpoint accessible without authentication - may expose sensitive data'
    confidence = 'MEDIUM'
  } else {
    vulnerable = false
    details = 'Authentication status unclear from response'
    confidence = 'LOW'
  }
  
  return {
    owasp_category: 'API2: Broken User Authentication',
    vulnerable,
    details,
    test_performed: 'Authentication mechanism analysis',
    confidence
  }
}

function testDataExposure(responseText: string, headers: Headers | null) {
  const sensitivePatterns = [
    { pattern: /password/gi, name: 'password' },
    { pattern: /secret/gi, name: 'secret' },
    { pattern: /token/gi, name: 'token' },
    { pattern: /key.*:/gi, name: 'api_key' },
    { pattern: /\b\d{4}[\s-]?\d{4}[\s-]?\d{4}[\s-]?\d{4}\b/g, name: 'credit_card' },
    { pattern: /\b\d{3}-?\d{2}-?\d{4}\b/g, name: 'ssn' }
  ]
  
  let sensitiveMatches = 0
  const foundTypes = []
  
  for (const { pattern, name } of sensitivePatterns) {
    const matches = responseText.match(pattern)
    if (matches) {
      sensitiveMatches += matches.length
      foundTypes.push(name)
    }
  }
  
  const responseSize = responseText.length
  const isExcessivelyLarge = responseSize > 100000
  
  let vulnerable = sensitiveMatches > 0 || isExcessivelyLarge
  let details = ''
  
  if (sensitiveMatches > 0) {
    details = `Response contains potential sensitive data: ${foundTypes.join(', ')}`
  } else if (isExcessivelyLarge) {
    details = `Response is excessively large (${responseSize} characters)`
  } else {
    details = 'No obvious data exposure issues detected'
  }
  
  return {
    owasp_category: 'API3: Excessive Data Exposure',
    vulnerable,
    details,
    test_performed: 'Response content analysis for sensitive patterns',
    confidence: sensitiveMatches > 3 ? 'HIGH' : sensitiveMatches > 0 ? 'MEDIUM' : 'LOW'
  }
}

async function testRateLimiting(targetUrl: string, headers: Headers | null) {
  const rateLimitHeaders = [
    'x-ratelimit-limit',
    'x-rate-limit-limit', 
    'ratelimit-limit',
    'x-ratelimit-remaining',
    'retry-after'
  ]
  
  // Fixed: Proper header checking
  const hasRateLimitHeaders = headers ? rateLimitHeaders.some(header => headers.has(header)) : false
  
  let rateLimitActive = hasRateLimitHeaders
  
  if (!hasRateLimitHeaders) {
    try {
      const rapidRequests = []
      
      for (let i = 0; i < 3; i++) {
        const controller = new AbortController()
        const timeoutId = setTimeout(() => controller.abort(), 3000)
        
        rapidRequests.push(
          fetch(targetUrl, { 
            method: 'GET',
            signal: controller.signal
          }).then(response => {
            clearTimeout(timeoutId)
            return response
          }).catch(error => {
            clearTimeout(timeoutId)
            return null
          })
        )
      }
      
      const responses = await Promise.all(rapidRequests)
      const validResponses = responses.filter(r => r !== null)
      const rateLimited = validResponses.some(r => r.status === 429 || r.status === 503)
      
      rateLimitActive = rateLimited
    } catch (error) {
      // Rate limit testing failed, assume no rate limiting
    }
  }
  
  return {
    owasp_category: 'API4: Lack of Resources & Rate Limiting',
    vulnerable: !rateLimitActive,
    details: rateLimitActive ? 
      'Rate limiting detected via headers or response codes' : 
      'No rate limiting mechanisms detected',
    test_performed: 'Rate limit header analysis and rapid request testing',
    confidence: hasRateLimitHeaders ? 'HIGH' : 'MEDIUM'
  }
}

async function testFunctionLevelAuth(targetUrl: string) {
  const url = new URL(targetUrl)
  const privilegedEndpoints = [
    '/admin',
    '/config', 
    '/users',
    '/delete',
    '/api/admin',
    '/.env'
  ]
  
  let accessibleEndpoints = 0
  
  for (const endpoint of privilegedEndpoints) {
    try {
      const testUrl = `${url.origin}${endpoint}`
      const controller = new AbortController()
      const timeoutId = setTimeout(() => controller.abort(), 3000)
      
      const response = await fetch(testUrl, { 
        method: 'GET',
        signal: controller.signal
      })
      clearTimeout(timeoutId)
      
      if (response.status === 200) {
        accessibleEndpoints++
      }
    } catch (e) {
      // Ignore connection errors for individual tests
    }
  }
  
  return {
    owasp_category: 'API5: Broken Function Level Authorization',
    vulnerable: accessibleEndpoints > 0,
    details: accessibleEndpoints > 0 ? 
      `${accessibleEndpoints} potentially privileged endpoints accessible` :
      'No privileged endpoints accessible without authorization',
    test_performed: 'Privileged endpoint accessibility testing',
    confidence: accessibleEndpoints > 2 ? 'HIGH' : accessibleEndpoints > 0 ? 'MEDIUM' : 'LOW'
  }
}

function analyzeSecurityHeaders(headers: Headers | null) {
  const securityHeaders = [
    'strict-transport-security',
    'content-security-policy',
    'x-frame-options',
    'x-content-type-options',
    'x-xss-protection',
    'referrer-policy'
  ]

  const security_headers_present = []
  const security_headers_missing = []

  for (const header of securityHeaders) {
    if (headers && headers.has(header)) {
      security_headers_present.push(header)
    } else {
      security_headers_missing.push(header)
    }
  }

  return {
    security_headers_present,
    security_headers_missing,
    recommendations: security_headers_missing.map(h => `Implement ${h} header`)
  }
}

export async function POST(req: NextRequest) {
  try {
    console.log('Security scan API called')
    const { target_url } = await req.json()

    if (!target_url) {
      return NextResponse.json({ error: 'Target URL is required' }, { status: 400 })
    }

    try {
      new URL(target_url)
    } catch (error) {
      return NextResponse.json({ error: 'Invalid URL format' }, { status: 400 })
    }

    console.log('Starting advanced scan for:', target_url)
    const scanResults = await performAdvancedSecurityScan(target_url)
    // Database storage instead of global - scan results available in response
    await triggerWebhooks(target_url, scanResults)

    console.log('Scan completed successfully')
    return NextResponse.json({
      success: true,
      scan_id: `scan_${Date.now()}`,
      results: scanResults
    })

  } catch (error) {
    console.error('Security scan API error:', error)
    return NextResponse.json({
      error: 'Security scan failed',
      details: (error as Error).message
    }, { status: 500 })
  }
}
