import { NextRequest, NextResponse } from 'next/server'

export async function POST(request: NextRequest) {
  try {
    const body = await request.json()
    const { email, password, firstName, lastName, companyName, domain } = body

    console.log('Registration attempt:', { email, firstName, lastName, companyName })

    // For now, create a mock successful registration
    const mockUser = {
      id: `user_${Math.random().toString(36).substring(2, 15)}`,
      email: email.toLowerCase(),
      firstName,
      lastName,
      role: 'admin',
      companyId: `company_${Math.random().toString(36).substring(2, 15)}`,
      emailVerified: true,
      createdAt: new Date().toISOString()
    }

    const mockCompany = {
      id: mockUser.companyId,
      companyName,
      domain: domain?.toLowerCase(),
      subscriptionPlan: 'professional',
      subscriptionStatus: 'active',
      apiKey: `gapi_${Math.random().toString(36).substring(2, 15)}`,
      createdAt: new Date().toISOString()
    }

    // Create session token
    const sessionToken = `session_${Math.random().toString(36).substring(2, 15)}`

    const response = NextResponse.json({
      success: true,
      user: mockUser,
      company: mockCompany,
      sessionToken
    })

    // Set session cookie
    response.cookies.set('session_token', sessionToken, {
      httpOnly: true,
      secure: process.env.NODE_ENV === 'production',
      sameSite: 'lax',
      maxAge: 7 * 24 * 60 * 60 // 7 days
    })

    return response

  } catch (error) {
    console.error('Registration API error:', error)
    return NextResponse.json(
      { success: false, error: 'Registration failed' },
      { status: 500 }
    )
  }
}
