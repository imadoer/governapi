"use client";
import * as React from "react";
import { useState, useEffect } from "react";
import {
  Card,
  Row,
  Col,
  Typography,
  Button,
  Tag,
  Space,
  Table,
  Progress,
  Divider,
  Input,
  Select,
  Modal,
  Form,
  message,
} from "antd";
import {
  ReloadOutlined,
  SecurityScanOutlined,
  LockOutlined,
  BugOutlined,
  AlertOutlined,
  CheckCircleOutlined,
  PlayCircleOutlined,
  SearchOutlined,
} from "@ant-design/icons";

const { Title, Paragraph, Text } = Typography;
const { Option } = Select;

export function SecurityCenterPage({
  stats,
  refreshData,
  refreshing,
  blockedThreats = [],
  vulnerabilities = [],
  company,
}) {
  const [selectedThreat, setSelectedThreat] = useState(null);
  const [securityScans, setSecurityScans] = useState([]);
  const [scansLoading, setScansLoading] = useState(false);
  const [scanModalVisible, setScanModalVisible] = useState(false);
  const [searchText, setSearchText] = useState("");
  const [statusFilter, setStatusFilter] = useState("all");
  const [form] = Form.useForm();

  const threatData = blockedThreats.length > 0 ? blockedThreats : [];
  const securityEvents = stats?.securityEvents || [];

  // Fetch security scans
  const fetchSecurityScans = async () => {
    setScansLoading(true);
    try {
      const response = await fetch('/api/customer/security-scans', {
        headers: {
          'x-tenant-id': company?.id || '1',
        },
      });
      const data = await response.json();
      if (data.success) {
        setSecurityScans(data.securityScans || []);
      }
    } catch (error) {
      console.error('Failed to fetch security scans:', error);
    } finally {
      setScansLoading(false);
    }
  };

  useEffect(() => {
    fetchSecurityScans();
  }, []);

  // Start new scan
  const handleStartScan = async (values: any) => {
    try {
      const response = await fetch('/api/customer/security-scans', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-tenant-id': company?.id || '1',
        },
        body: JSON.stringify({
          url: values.url,
          scanType: values.scanType,
        }),
      });

      const data = await response.json();
      
      if (data.success) {
        message.success('Security scan started successfully');
        setScanModalVisible(false);
        form.resetFields();
        fetchSecurityScans();
      } else {
        message.error(data.error || 'Failed to start scan');
      }
    } catch (error) {
      message.error('Failed to start security scan');
      console.error('Scan start error:', error);
    }
  };

  const threatColumns = [
    {
      title: "Threat Type",
      dataIndex: "type",
      key: "type",
      render: (type, record) => (
        <Tag
          color={
            record.severity === "Critical"
              ? "red"
              : record.severity === "High"
                ? "orange"
                : "blue"
          }
        >
          {type}
        </Tag>
      ),
    },
    {
      title: "Source IP",
      dataIndex: "sourceIp",
      key: "sourceIp",
      render: (ip) => <Text code>{ip}</Text>,
    },
    {
      title: "Severity",
      dataIndex: "severity",
      key: "severity",
      render: (severity) => (
        <Tag
          color={
            severity === "Critical"
              ? "red"
              : severity === "High"
                ? "orange"
                : "blue"
          }
        >
          {severity}
        </Tag>
      ),
    },
    {
      title: "Time",
      dataIndex: "timestamp",
      key: "timestamp",
    },
    {
      title: "Status",
      dataIndex: "status",
      key: "status",
      render: (status) => <Tag color="green">{status}</Tag>,
    },
  ];

  const scanColumns = [
    {
      title: "Target",
      dataIndex: "target",
      key: "target",
      render: (target: string) => (
        <Text style={{ color: "#1890ff", fontFamily: "monospace" }}>
          {target}
        </Text>
      ),
    },
    {
      title: "Scan Type",
      dataIndex: "scanType",
      key: "scanType",
      render: (scanType: string) => (
        <Tag color="blue">{scanType?.toUpperCase()}</Tag>
      ),
    },
    {
      title: "Status",
      dataIndex: "status",
      key: "status",
      render: (status: string) => {
        const colors = {
          completed: "green",
          running: "blue",
          pending: "orange",
          failed: "red",
        };
        return <Tag color={colors[status] || "default"}>{status?.toUpperCase()}</Tag>;
      },
    },
    {
      title: "Security Score",
      dataIndex: "securityScore",
      key: "securityScore",
      render: (score: number) => (
        <Text
          strong
          style={{
            color:
              score >= 80
                ? "#52c41a"
                : score >= 60
                  ? "#faad14"
                  : "#ff4d4f",
          }}
        >
          {score || "--"}
        </Text>
      ),
    },
    {
      title: "Vulnerabilities",
      dataIndex: "vulnerabilityCount",
      key: "vulnerabilityCount",
      render: (count: number) => (
        <Tag color={count > 0 ? "red" : "green"}>{count || 0}</Tag>
      ),
    },
    {
      title: "Duration",
      dataIndex: "duration",
      key: "duration",
      render: (duration: number) => (duration ? `${duration}s` : "--"),
    },
    {
      title: "Started",
      dataIndex: "createdAt",
      key: "createdAt",
      render: (date: string) => new Date(date).toLocaleString(),
    },
  ];

  const securityScore = 87;
  const getScoreColor = (score) => {
    if (score >= 90) return "#52c41a";
    if (score >= 80) return "#1890ff";
    if (score >= 70) return "#faad14";
    return "#ff4d4f";
  };

  const filteredScans = securityScans.filter((scan) => {
    const matchesSearch =
      searchText === "" ||
      scan.target?.toLowerCase().includes(searchText.toLowerCase());
    const matchesStatus =
      statusFilter === "all" || scan.status === statusFilter;
    return matchesSearch && matchesStatus;
  });

  return (
    <div>
      <div style={{ marginBottom: 24 }}>
        <Title level={2} style={{ margin: 0, color: "#1f2937" }}>
          Security Center
        </Title>
        <Paragraph
          style={{
            marginTop: 8,
            marginBottom: 0,
            fontSize: "16px",
            color: "#6b7280",
          }}
        >
          Real-time threat monitoring and security analytics. Monitor active
          threats, view security alerts, analyze attack patterns, and manage
          your enterprise security posture with advanced threat detection and
          response capabilities.
        </Paragraph>
      </div>

      {/* Security Status Alert */}
      <Card
        style={{
          marginBottom: 24,
          background: "linear-gradient(135deg, #52c41a 0%, #389e0d 100%)",
          color: "white",
          border: "none",
        }}
      >
        <div
          style={{
            display: "flex",
            alignItems: "center",
            justifyContent: "space-between",
          }}
        >
          <div style={{ display: "flex", alignItems: "center", gap: 16 }}>
            <SecurityScanOutlined style={{ fontSize: 32, color: "white" }} />
            <div>
              <Text
                style={{ color: "white", fontSize: "18px", fontWeight: "bold" }}
              >
                Security Status: All Systems Protected
              </Text>
              <div style={{ color: "rgba(255,255,255,0.9)", marginTop: 4 }}>
                Active monitoring across {stats?.totalEndpoints || 3} endpoints
                • Last scan: 2 minutes ago
              </div>
            </div>
          </div>
          <Button
            type="primary"
            ghost
            onClick={refreshData}
            loading={refreshing}
            style={{ color: "white", borderColor: "white" }}
            icon={<ReloadOutlined />}
          >
            Refresh
          </Button>
        </div>
      </Card>

      {/* Security Scans Section */}
      <Card
        title={
          <Space>
            <SecurityScanOutlined />
            <span>Security Scans</span>
            <Tag color="blue">{securityScans.length} Total</Tag>
          </Space>
        }
        extra={
          <Button
            type="primary"
            icon={<PlayCircleOutlined />}
            onClick={() => setScanModalVisible(true)}
          >
            Start New Scan
          </Button>
        }
        style={{ marginBottom: 24 }}
      >
        <Space style={{ marginBottom: 16, width: "100%" }}>
          <Input
            placeholder="Search targets..."
            prefix={<SearchOutlined />}
            value={searchText}
            onChange={(e) => setSearchText(e.target.value)}
            style={{ width: 300 }}
          />
          <Select
            value={statusFilter}
            onChange={setStatusFilter}
            style={{ width: 150 }}
          >
            <Option value="all">All Status</Option>
            <Option value="completed">Completed</Option>
            <Option value="running">Running</Option>
            <Option value="pending">Pending</Option>
            <Option value="failed">Failed</Option>
          </Select>
          <Button
            icon={<ReloadOutlined />}
            onClick={fetchSecurityScans}
            loading={scansLoading}
          >
            Refresh
          </Button>
        </Space>

        <Table
          columns={scanColumns}
          dataSource={filteredScans}
          rowKey="id"
          loading={scansLoading}
          pagination={{ pageSize: 10 }}
        />
      </Card>

      {/* Security Metrics Dashboard */}
      <Row gutter={[16, 16]} style={{ marginBottom: 24 }}>
        <Col xs={24} sm={6}>
          <Card
            style={{
              background: "linear-gradient(135deg, #1890ff 0%, #096dd9 100%)",
              color: "white",
              border: "none",
            }}
          >
            <div style={{ display: "flex", alignItems: "center", gap: 12 }}>
              <SecurityScanOutlined style={{ fontSize: 32, color: "white" }} />
              <div>
                <div
                  style={{ fontSize: 24, fontWeight: "bold", color: "white" }}
                >
                  {securityScore}%
                </div>
                <div style={{ color: "rgba(255,255,255,0.9)" }}>
                  Security Score
                </div>
              </div>
            </div>
          </Card>
        </Col>
        <Col xs={24} sm={6}>
          <Card
            style={{
              background: "linear-gradient(135deg, #ff4d4f 0%, #cf1322 100%)",
              color: "white",
              border: "none",
            }}
          >
            <div style={{ display: "flex", alignItems: "center", gap: 12 }}>
              <LockOutlined style={{ fontSize: 32, color: "white" }} />
              <div>
                <div
                  style={{ fontSize: 24, fontWeight: "bold", color: "white" }}
                >
                  {threatData.length}
                </div>
                <div style={{ color: "rgba(255,255,255,0.9)" }}>
                  Threats Blocked Today
                </div>
              </div>
            </div>
          </Card>
        </Col>
        <Col xs={24} sm={6}>
          <Card
            style={{
              background: "linear-gradient(135deg, #52c41a 0%, #389e0d 100%)",
              color: "white",
              border: "none",
            }}
          >
            <div style={{ display: "flex", alignItems: "center", gap: 12 }}>
              <CheckCircleOutlined style={{ fontSize: 32, color: "white" }} />
              <div>
                <div
                  style={{ fontSize: 24, fontWeight: "bold", color: "white" }}
                >
                  {securityScans.filter(s => s.status === 'completed').length}
                </div>
                <div style={{ color: "rgba(255,255,255,0.9)" }}>
                  Completed Scans
                </div>
              </div>
            </div>
          </Card>
        </Col>
        <Col xs={24} sm={6}>
          <Card
            style={{
              background: "linear-gradient(135deg, #722ed1 0%, #531dab 100%)",
              color: "white",
              border: "none",
            }}
          >
            <div style={{ display: "flex", alignItems: "center", gap: 12 }}>
              <BugOutlined style={{ fontSize: 32, color: "white" }} />
              <div>
                <div
                  style={{ fontSize: 24, fontWeight: "bold", color: "white" }}
                >
                  {vulnerabilities.length}
                </div>
                <div style={{ color: "rgba(255,255,255,0.9)" }}>
                  Vulnerabilities
                </div>
              </div>
            </div>
          </Card>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        {/* Live Threat Detection */}
        <Col xs={24} lg={16}>
          <Card
            title={
              <Space>
                <Text strong style={{ fontSize: "16px" }}>
                  Live Threat Detection
                </Text>
                <Tag
                  color="red"
                  style={{ fontSize: "11px", fontWeight: "bold" }}
                >
                  LIVE
                </Tag>
              </Space>
            }
            extra={
              <Button
                onClick={refreshData}
                loading={refreshing}
                icon={<ReloadOutlined />}
                size="small"
              >
                Refresh
              </Button>
            }
          >
            <Table
              columns={threatColumns}
              dataSource={threatData}
              rowKey="id"
              size="small"
              pagination={{ pageSize: 5 }}
              onRow={(record) => ({
                onClick: () => setSelectedThreat(record),
                style: { cursor: "pointer" },
              })}
            />
          </Card>
        </Col>

        {/* Security Status & Events Panel */}
        <Col xs={24} lg={8}>
          <Card title="Protection Status" style={{ marginBottom: 16 }}>
            <div style={{ marginBottom: 20 }}>
              <div
                style={{
                  display: "flex",
                  justifyContent: "space-between",
                  marginBottom: 8,
                }}
              >
                <Text strong>Overall Security Score</Text>
                <Text strong style={{ color: getScoreColor(securityScore) }}>
                  {securityScore}%
                </Text>
              </div>
              <Progress
                percent={securityScore}
                strokeColor={getScoreColor(securityScore)}
                showInfo={false}
              />
            </div>

            <Space direction="vertical" style={{ width: "100%", gap: 12 }}>
              <div
                style={{
                  display: "flex",
                  justifyContent: "space-between",
                  alignItems: "center",
                }}
              >
                <Space>
                  <CheckCircleOutlined style={{ color: "#52c41a" }} />
                  <Text>DDoS Protection</Text>
                </Space>
                <Tag color="green">ACTIVE</Tag>
              </div>
              <div
                style={{
                  display: "flex",
                  justifyContent: "space-between",
                  alignItems: "center",
                }}
              >
                <Space>
                  <CheckCircleOutlined style={{ color: "#52c41a" }} />
                  <Text>Malware Detection</Text>
                </Space>
                <Tag color="green">ACTIVE</Tag>
              </div>
              <div
                style={{
                  display: "flex",
                  justifyContent: "space-between",
                  alignItems: "center",
                }}
              >
                <Space>
                  <CheckCircleOutlined style={{ color: "#52c41a" }} />
                  <Text>SQL Injection Filter</Text>
                </Space>
                <Tag color="green">ACTIVE</Tag>
              </div>
              <div
                style={{
                  display: "flex",
                  justifyContent: "space-between",
                  alignItems: "center",
                }}
              >
                <Space>
                  <CheckCircleOutlined style={{ color: "#52c41a" }} />
                  <Text>Real-time Scanning</Text>
                </Space>
                <Tag color="green">ACTIVE</Tag>
              </div>
            </Space>
          </Card>

          <Card title="Recent Security Events">
            <Space direction="vertical" style={{ width: "100%" }}>
              {securityEvents.map((event, index) => (
                <div key={index}>
                  <div
                    style={{
                      display: "flex",
                      alignItems: "flex-start",
                      gap: 12,
                    }}
                  >
                    <div
                      style={{
                        width: 32,
                        height: 32,
                        borderRadius: "50%",
                        background:
                          event.severity === "critical"
                            ? "#ff4d4f"
                            : event.severity === "warning"
                              ? "#faad14"
                              : event.severity === "success"
                                ? "#52c41a"
                                : "#1890ff",
                        display: "flex",
                        alignItems: "center",
                        justifyContent: "center",
                      }}
                    >
                      <AlertOutlined
                        style={{ color: "white", fontSize: "14px" }}
                      />
                    </div>
                    <div style={{ flex: 1 }}>
                      <Text strong style={{ fontSize: "13px" }}>
                        {event.title}
                      </Text>
                      <div
                        style={{
                          color: "#666",
                          fontSize: "12px",
                          marginTop: 2,
                        }}
                      >
                        {event.description}
                      </div>
                      <div
                        style={{
                          color: "#999",
                          fontSize: "11px",
                          marginTop: 4,
                        }}
                      >
                        {event.time}
                      </div>
                    </div>
                  </div>
                  {index < securityEvents.length - 1 && (
                    <Divider style={{ margin: "12px 0" }} />
                  )}
                </div>
              ))}
            </Space>
          </Card>
        </Col>
      </Row>

      {/* Start Scan Modal */}
      <Modal
        title="Start New Security Scan"
        open={scanModalVisible}
        onCancel={() => setScanModalVisible(false)}
        footer={null}
      >
        <Form form={form} layout="vertical" onFinish={handleStartScan}>
          <Form.Item
            label="Target URL"
            name="url"
            rules={[
              { required: true, message: "Please enter target URL" },
              { type: "url", message: "Please enter a valid URL" },
            ]}
          >
            <Input placeholder="https://example.com" />
          </Form.Item>
          <Form.Item
            label="Scan Type"
            name="scanType"
            initialValue="comprehensive"
          >
            <Select>
              <Option value="quick">Quick Scan</Option>
              <Option value="comprehensive">Comprehensive Scan</Option>
              <Option value="deep">Deep Scan</Option>
              <Option value="owasp_top10">OWASP Top 10</Option>
            </Select>
          </Form.Item>
          <Form.Item>
            <Space>
              <Button type="primary" htmlType="submit">
                Start Scan
              </Button>
              <Button onClick={() => setScanModalVisible(false)}>
                Cancel
              </Button>
            </Space>
          </Form.Item>
        </Form>
      </Modal>
    </div>
  );
}
