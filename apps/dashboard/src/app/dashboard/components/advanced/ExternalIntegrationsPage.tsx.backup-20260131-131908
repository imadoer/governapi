"use client";

import { useState, useEffect } from "react";
import { motion, AnimatePresence } from "framer-motion";
import {
  PlusIcon,
  ArrowPathIcon,
  CheckCircleIcon,
  XCircleIcon,
  LinkIcon,
  BoltIcon,
  BeakerIcon,
  TrashIcon,
} from "@heroicons/react/24/outline";
import { Modal, Input, Select, message, Spin, Tooltip, Button } from "antd";

interface Integration {
  id: string;
  type: string;
  name: string;
  isActive: boolean;
  lastUsed: string | null;
  createdAt: string;
}

const INTEGRATION_TYPES = [
  {
    id: "slack",
    name: "Slack",
    icon: "💬",
    color: "#4A154B",
    description: "Send security alerts to Slack channels",
    fields: ["webhook_url", "channel", "bot_token", "channel_id"],
    testEndpoint: "/api/integrations/slack",
  },
  {
    id: "jira",
    name: "Jira",
    icon: "🎫",
    color: "#0052CC",
    description: "Create issues for vulnerabilities",
    fields: ["api_token", "project_key", "instance_url"],
    testEndpoint: "/api/integrations/jira",
  },
  {
    id: "github",
    name: "GitHub",
    icon: "🐙",
    color: "#181717",
    description: "Security notifications via GitHub",
    fields: ["access_token", "repository"],
    testEndpoint: "/api/integrations/github",
  },
  {
    id: "pagerduty",
    name: "PagerDuty",
    icon: "🚨",
    color: "#06AC38",
    description: "Critical alerts to on-call teams",
    fields: ["integration_key"],
    testEndpoint: "/api/integrations/pagerduty",
  },
  {
    id: "datadog",
    name: "Datadog",
    icon: "📊",
    color: "#632CA6",
    description: "Send metrics and logs",
    fields: ["api_key", "app_key"],
    testEndpoint: "/api/integrations/datadog",
  },
  {
    id: "webhook",
    name: "Custom Webhook",
    icon: "🔗",
    color: "#6366f1",
    description: "Custom HTTP webhooks",
    fields: ["webhook_url", "secret"],
    testEndpoint: "/api/webhooks/trigger",
  },
];

export function ExternalIntegrationsPage({ companyId }: { companyId: string }) {
  const [integrations, setIntegrations] = useState<Integration[]>([]);
  const [loading, setLoading] = useState(true);
  const [isModalOpen, setIsModalOpen] = useState(false);
  const [selectedType, setSelectedType] = useState<string>("");
  const [integrationName, setIntegrationName] = useState("");
  const [credentials, setCredentials] = useState<Record<string, string>>({});
  const [submitting, setSubmitting] = useState(false);
  const [testingId, setTestingId] = useState<string | null>(null);
  const [testResult, setTestResult] = useState<any>(null);
  const [intelligence, setIntelligence] = useState<any>(null);
  const [syncing, setSyncing] = useState<string | null>(null);
  const [showTestResult, setShowTestResult] = useState(false);


  const fetchIntelligence = async () => {
    try {
      const response = await fetch("/api/customer/intelligence", {
        headers: { "x-tenant-id": companyId },
      });
      const data = await response.json();
      if (data.success) {
        setIntelligence(data);
      }
    } catch (error) {
      console.error("Failed to fetch intelligence:", error);
    }
  };

  const handleSync = async (integrationId: string) => {
    setSyncing(integrationId);
    try {
      const response = await fetch("/api/integrations/sync", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "x-tenant-id": companyId,
        },
        body: JSON.stringify({ integrationId }),
      });
      const result = await response.json();
      if (result.success) {
        message.success(result.message || "Synced!");
        fetchIntelligence();
        fetchIntegrations();
      } else {
        message.error("Sync failed");
      }
    } catch (error) {
      message.error("Failed to sync");
    } finally {
      setSyncing(null);
    }
  };

  const fetchIntegrations = async () => {
    setLoading(true);
    try {
      const response = await fetch("/api/customer/external-integrations", {
        headers: { "x-tenant-id": companyId },
      });
      const data = await response.json();

      if (data.success) {
        setIntegrations(data.integrations || []);
      }
    } catch (error) {
      console.error("Failed to fetch integrations:", error);
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    if (companyId) {
      fetchIntegrations();
      fetchIntelligence();
    }
  }, [companyId]);

  const handleAddIntegration = async () => {
    if (!selectedType || !integrationName) {
      message.error("Please fill in all required fields");
      return;
    }

    setSubmitting(true);
    try {
      const response = await fetch("/api/customer/external-integrations", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "x-tenant-id": companyId,
        },
        body: JSON.stringify({
          integrationType: selectedType,
          integrationName,
          credentials,
        }),
      });

      const data = await response.json();

      if (data.success) {
        message.success("Integration added successfully!");
        setIsModalOpen(false);
        setSelectedType("");
        setIntegrationName("");
        setCredentials({});
        fetchIntegrations();
      } else {
        message.error(data.error || "Failed to add integration");
      }
    } catch (error) {
      message.error("Failed to add integration");
    } finally {
      setSubmitting(false);
    }
  };

  const handleTestIntegration = async (integration: Integration) => {
    setTestingId(integration.id);
    try {
      const integrationType = INTEGRATION_TYPES.find(
        (t) => t.id === integration.type,
      );

      if (!integrationType?.testEndpoint) {
        message.error("Test endpoint not configured for this integration type");
        return;
      }

      // Get integration credentials from the database
      const integrationResponse = await fetch(`/api/customer/external-integrations`, {
        headers: { "x-tenant-id": companyId },
      });
      const data = await integrationResponse.json();
      const fullIntegration = data.integrations?.find((i: any) => i.id === integration.id);
      const integrationCredentials = fullIntegration?.credentials || {};

      // Test message based on type
      const testPayloads: Record<string, any> = {
        slack: {
          webhook_url: integrationCredentials.webhook_url,
          message: "🧪 Test from GovernAPI - Integration successful!",
          channel: integrationCredentials.channel || "#security-alerts",
        },
        webhook: {
          event: "test",
          message: "Test webhook from GovernAPI",
          timestamp: new Date().toISOString(),
        },
        jira: {
          summary: "GovernAPI Integration Test",
          description: "This is a test issue to verify integration",
          priority: "Low",
        },
        github: {
          title: "GovernAPI Integration Test",
          body: "Testing integration connection",
          labels: ["test"],
        },
        pagerduty: {
          event_action: "trigger",
          summary: "GovernAPI Integration Test",
          severity: "info",
        },
        datadog: {
          title: "GovernAPI Test",
          text: "Testing Datadog integration",
          tags: ["test", "governapi"],
        },
      };

      const response = await fetch(integrationType.testEndpoint, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "x-tenant-id": companyId,
        },
        body: JSON.stringify({
          integrationId: integration.id,
          ...testPayloads[integration.type],
        }),
      });

      let result;
      try {
        result = await response.json();
      } catch (e) {
        result = { 
          success: false, 
          message: "Failed to parse response",
          error: "Invalid JSON response"
        };
      }
      
      // Store result and show modal  
      setTestResult({
        success: result.success === true,
        integration: integration.name,
        message: result.message || (response.ok ? "Success" : "Failed"),
        details: result.details,
        error: result.error,
        status: response.status,
      });
      setShowTestResult(true);
      
      // Also show toast
      if (response.ok && result.success) {
        message.success(result.message || `${integration.name} test successful! ✅`);
      } else {
        message.error(result.message || `Test failed: ${result.error || "Unknown error"}`);
      }
    } catch (error) {
      setTestResult({
        success: false,
        integration: integration.name,
        message: "Failed to test integration",
        error: error instanceof Error ? error.message : String(error),
      });
      setShowTestResult(true);
      message.error("Failed to test integration");
    } finally {
      setTestingId(null);
    }
  };

  const handleDeleteIntegration = async (id: string) => {
    try {
      const response = await fetch(
        `/api/customer/external-integrations/${id}`,
        {
          method: "DELETE",
          headers: { "x-tenant-id": companyId },
        },
      );

      if (response.ok) {
        message.success("Integration deleted");
        fetchIntegrations();
      } else {
        message.error("Failed to delete integration");
      }
    } catch (error) {
      message.error("Failed to delete integration");
    }
  };

  const getIntegrationType = (type: string) => {
    return INTEGRATION_TYPES.find((t) => t.id === type) || INTEGRATION_TYPES[0];
  };

  const selectedIntegrationType = INTEGRATION_TYPES.find(
    (t) => t.id === selectedType,
  );

  if (loading) {
    return (
      <div className="flex items-center justify-center h-96">
        <Spin size="large" />
      </div>
    );
  }

  return (
    <div className="space-y-6">
      {/* Header */}
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-3xl font-bold text-white mb-2">
            External Integrations
          </h1>
          <p className="text-slate-400">
            Connect your security workflows with third-party tools
          </p>
        </div>
        <motion.button
          whileHover={{ scale: 1.02 }}
          whileTap={{ scale: 0.98 }}
          onClick={() => setIsModalOpen(true)}
          className="px-6 py-3 bg-cyan-500 hover:bg-cyan-600 text-white rounded-xl font-semibold flex items-center gap-2"
        >
          <PlusIcon className="w-5 h-5" />
          Add Integration
        </motion.button>
      </div>


      {/* Governance Snapshot */}
      {intelligence && (
        <motion.div
          initial={{ opacity: 0, y: -10 }}
          animate={{ opacity: 1, y: 0 }}
          onClick={() => window.location.href = '/dashboard/governance-intelligence'}
          className="bg-gradient-to-r from-cyan-500/10 to-blue-500/10 border border-cyan-500/30 rounded-xl p-4 cursor-pointer hover:border-cyan-400 transition-all mb-6"
        >
          <div className="flex items-center justify-between">
            <div className="flex items-center gap-6">
              <div>
                <div className="text-xs text-gray-400 mb-1">TRUST INDEX</div>
                <div className="text-2xl font-bold text-cyan-400">{intelligence.scores.trust_index}/100</div>
              </div>
              <div className="h-8 w-px bg-slate-600"></div>
              <div>
                <div className="text-xs text-gray-400 mb-1">ACTIVE INTEGRATIONS</div>
                <div className="text-2xl font-bold text-white">{intelligence.integrations_summary.active}</div>
              </div>
              <div className="h-8 w-px bg-slate-600"></div>
              <div>
                <div className="text-xs text-gray-400 mb-1">SECURITY SCORE</div>
                <div className="text-2xl font-bold text-blue-400">{intelligence.scores.security_score}/100</div>
              </div>
              <div className="h-8 w-px bg-slate-600"></div>
              <div>
                <div className="text-xs text-gray-400 mb-1">LAST SYNC</div>
                <div className="text-sm text-gray-300">
                  {intelligence.integrations_summary.last_sync 
                    ? new Date(intelligence.integrations_summary.last_sync).toLocaleTimeString()
                    : 'Never'}
                </div>
              </div>
            </div>
            <div className="flex items-center gap-2 text-cyan-400 hover:text-cyan-300">
              <span className="text-sm font-semibold">View Full Dashboard</span>
              <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </div>
          </div>
        </motion.div>
      )}

      {/* Intelligence Dashboard */}
      {intelligence && (
        <div className="mb-6 grid grid-cols-1 md:grid-cols-4 gap-4">
          <div className="bg-gradient-to-br from-blue-500/10 to-blue-600/5 border border-blue-500/20 rounded-xl p-6">
            <div className="text-sm text-gray-400 mb-2">Security Score</div>
            <div className="text-3xl font-bold text-white">{intelligence.scores.security_score}<span className="text-lg text-gray-400">/100</span></div>
            <div className="text-xs text-gray-500 mt-1">{intelligence.metrics.total_vulnerabilities} vulnerabilities</div>
          </div>
          <div className="bg-gradient-to-br from-purple-500/10 to-purple-600/5 border border-purple-500/20 rounded-xl p-6">
            <div className="text-sm text-gray-400 mb-2">Governance Score</div>
            <div className="text-3xl font-bold text-white">{intelligence.scores.governance_score}<span className="text-lg text-gray-400">/100</span></div>
            <div className="text-xs text-gray-500 mt-1">{intelligence.metrics.stale_tickets} stale tickets</div>
          </div>
          <div className="bg-gradient-to-br from-green-500/10 to-green-600/5 border border-green-500/20 rounded-xl p-6">
            <div className="text-sm text-gray-400 mb-2">Compliance Score</div>
            <div className="text-3xl font-bold text-white">{intelligence.scores.compliance_score}<span className="text-lg text-gray-400">/100</span></div>
            <div className="text-xs text-gray-500 mt-1">{intelligence.integrations_summary.active} active</div>
          </div>
          <div className="bg-gradient-to-br from-cyan-500/10 to-cyan-600/5 border border-cyan-500/20 rounded-xl p-6">
            <div className="text-sm text-gray-400 mb-2">Trust Index</div>
            <div className="text-3xl font-bold text-white">{intelligence.scores.trust_index}<span className="text-lg text-gray-400">/100</span></div>
            <div className="text-xs text-gray-500 mt-1">Overall posture</div>
          </div>
        </div>
      )}

      {/* Stats */}
      <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
        <motion.div
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          className="bg-slate-800/50 border border-slate-700 rounded-2xl p-6"
        >
          <div className="flex items-center justify-between">
            <div>
              <p className="text-sm text-slate-400">Total Integrations</p>
              <p className="text-3xl font-bold text-white mt-1">
                {integrations.length}
              </p>
            </div>
            <LinkIcon className="w-10 h-10 text-cyan-500" />
          </div>
        </motion.div>

        <motion.div
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ delay: 0.1 }}
          className="bg-slate-800/50 border border-slate-700 rounded-2xl p-6"
        >
          <div className="flex items-center justify-between">
            <div>
              <p className="text-sm text-slate-400">Active</p>
              <p className="text-3xl font-bold text-green-500 mt-1">
                {integrations.filter((i) => i.isActive).length}
              </p>
            </div>
            <CheckCircleIcon className="w-10 h-10 text-green-500" />
          </div>
        </motion.div>

        <motion.div
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ delay: 0.2 }}
          className="bg-slate-800/50 border border-slate-700 rounded-2xl p-6"
        >
          <div className="flex items-center justify-between">
            <div>
              <p className="text-sm text-slate-400">Available Types</p>
              <p className="text-3xl font-bold text-cyan-400 mt-1">
                {INTEGRATION_TYPES.length}
              </p>
            </div>
            <BoltIcon className="w-10 h-10 text-cyan-400" />
          </div>
        </motion.div>
      </div>

      {/* Available Integrations */}
      <div>
        <h2 className="text-xl font-bold text-white mb-4">
          Available Integrations
        </h2>
        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {INTEGRATION_TYPES.map((type, index) => (
            <motion.div
              key={type.id}
              initial={{ opacity: 0, scale: 0.95 }}
              animate={{ opacity: 1, scale: 1 }}
              transition={{ delay: index * 0.1 }}
              whileHover={{ scale: 1.02, y: -4 }}
              onClick={() => {
                setSelectedType(type.id);
                setIsModalOpen(true);
              }}
              className="bg-slate-800/50 border border-slate-700 rounded-2xl p-6 cursor-pointer hover:border-cyan-500/50 transition-all"
            >
              <div className="flex items-start gap-4">
                <div
                  className="text-4xl p-3 rounded-xl"
                  style={{ backgroundColor: `${type.color}20` }}
                >
                  {type.icon}
                </div>
                <div className="flex-1">
                  <h3 className="text-lg font-bold text-white mb-1">
                    {type.name}
                  </h3>
                  <p className="text-sm text-slate-400">{type.description}</p>
                  {integrations.some((i) => i.type === type.id) && (
                    <div className="mt-2 flex items-center gap-2 text-xs text-green-500">
                      <CheckCircleIcon className="w-4 h-4" />
                      Connected
                    </div>
                  )}
                </div>
              </div>
            </motion.div>
          ))}
        </div>
      </div>

      {/* Active Integrations */}
      {integrations.length > 0 && (
        <div>
          <h2 className="text-xl font-bold text-white mb-4">
            Your Integrations
          </h2>
          <div className="space-y-3">
            <AnimatePresence>
              {integrations.map((integration, index) => {
                const type = getIntegrationType(integration.type);
                const isTesting = testingId === integration.id;

                return (
                  <motion.div
                    key={integration.id}
                    initial={{ opacity: 0, x: -20 }}
                    animate={{ opacity: 1, x: 0 }}
                    exit={{ opacity: 0, x: 20 }}
                    transition={{ delay: index * 0.05 }}
                    className="bg-slate-800/50 border border-slate-700 rounded-xl p-5 hover:border-cyan-500/50 transition-all"
                  >
                    <div className="flex items-center justify-between">
                      <div className="flex items-center gap-4 flex-1">
                        <div
                          className="text-3xl p-3 rounded-xl"
                          style={{ backgroundColor: `${type.color}20` }}
                        >
                          {type.icon}
                        </div>
                        <div className="flex-1">
                          <h3 className="text-lg font-semibold text-white">
                            {integration.name}
                          </h3>
                          <div className="flex items-center gap-3 mt-1 text-sm text-slate-400">
                            <span className="capitalize">
                              {integration.type}
                            </span>
                            <span>•</span>
                            <span>
                              Added{" "}
                              {new Date(
                                integration.createdAt,
                              ).toLocaleDateString()}
                            </span>
                            {integration.lastUsed && (
                              <>
                                <span>•</span>
                                <span>
                                  Last used{" "}
                                  {new Date(
                                    integration.lastUsed,
                                  ).toLocaleDateString()}
                                </span>
                              </>
                            )}
                          </div>
                        </div>
                      </div>

                      <div className="flex items-center gap-3">
                        {integration.isActive ? (
                          <div className="flex items-center gap-2 text-green-500">
                            <CheckCircleIcon className="w-5 h-5" />
                            <span className="text-sm font-semibold">
                              Active
                            </span>
                          </div>
                        ) : (
                          <div className="flex items-center gap-2 text-slate-500">
                            <XCircleIcon className="w-5 h-5" />
                            <span className="text-sm font-semibold">
                              Inactive
                            </span>
                          </div>
                        )}

                        <Tooltip title="Sync Data">
                          <motion.button
                            whileHover={{ scale: 1.1 }}
                            whileTap={{ scale: 0.9 }}
                            onClick={() => handleSync(integration.id)}
                            disabled={syncing === integration.id}
                            className="p-2 rounded-lg bg-green-500/20 text-green-400 hover:bg-green-500/30 disabled:opacity-50 transition-colors"
                          >
                            {syncing === integration.id ? (
                              <Spin size="small" />
                            ) : (
                              <ArrowPathIcon className="w-5 h-5" />
                            )}
                          </motion.button>
                        </Tooltip>
                        <Tooltip title="Test Integration">
                          <motion.button
                            whileHover={{ scale: 1.1 }}
                            whileTap={{ scale: 0.9 }}
                            onClick={() => handleTestIntegration(integration)}
                            disabled={isTesting}
                            className="p-2 rounded-lg bg-blue-500/20 text-blue-400 hover:bg-blue-500/30 disabled:opacity-50 transition-colors"
                          >
                            {isTesting ? (
                              <Spin size="small" />
                            ) : (
                              <BeakerIcon className="w-5 h-5" />
                            )}
                          </motion.button>
                        </Tooltip>

                        <Tooltip title="Delete Integration">
                          <motion.button
                            whileHover={{ scale: 1.1 }}
                            whileTap={{ scale: 0.9 }}
                            onClick={() => {
                              console.log("Delete button clicked for:", integration.id);
                              if (window.confirm(`Are you sure you want to delete ${integration.name}?`)) {
                                console.log("Confirmed delete for:", integration.id);
                                handleDeleteIntegration(integration.id);
                              }
                            }}
                            className="p-2 rounded-lg bg-red-500/20 text-red-400 hover:bg-red-500/30 transition-colors"
                          >
                            <TrashIcon className="w-5 h-5" />
                          </motion.button>
                        </Tooltip>
                      </div>
                    </div>
                  </motion.div>
                );
              })}
            </AnimatePresence>
          </div>
        </div>
      )}

      {/* Add Integration Modal */}
      <Modal
        title="Add New Integration"
        open={isModalOpen}
        onOk={handleAddIntegration}
        onCancel={() => {
          setIsModalOpen(false);
          setSelectedType("");
          setIntegrationName("");
          setCredentials({});
        }}
        confirmLoading={submitting}
        okText="Add Integration"
        width={600}
      >
        <div className="space-y-4 mt-4">
          <div>
            <label className="block text-sm font-medium mb-2">
              Integration Type
            </label>
            <Select
              value={selectedType}
              onChange={setSelectedType}
              className="w-full"
              placeholder="Select integration type"
            >
              {INTEGRATION_TYPES.map((type) => (
                <Select.Option key={type.id} value={type.id}>
                  <div className="flex items-center gap-2">
                    <span>{type.icon}</span>
                    <span>{type.name}</span>
                  </div>
                </Select.Option>
              ))}
            </Select>
          </div>

          <div>
            <label className="block text-sm font-medium mb-2">
              Integration Name
            </label>
            <Input
              placeholder="e.g., Production Alerts"
              value={integrationName}
              onChange={(e) => setIntegrationName(e.target.value)}
            />
          </div>

          {selectedIntegrationType && (
            <div className="space-y-3">
              <div className="text-sm font-medium">Configuration</div>
              {selectedIntegrationType.fields.map((field) => (
                <div key={field}>
                  <label className="block text-sm mb-1 capitalize">
                    {field.replace("_", " ")}
                  </label>
                  <Input
                    placeholder={`Enter ${field.replace("_", " ")}`}
                    value={credentials[field] || ""}
                    onChange={(e) =>
                      setCredentials({
                        ...credentials,
                        [field]: e.target.value,
                      })
                    }
                    type={
                      field.includes("token") ||
                      field.includes("key") ||
                      field.includes("secret")
                        ? "password"
                        : "text"
                    }
                  />
                </div>
              ))}
            </div>
          )}
        </div>
      </Modal>

      {/* Test Results Modal */}
      <Modal
        title={testResult?.success ? "✅ Test Successful" : "❌ Test Failed"}
        open={showTestResult}
        onCancel={() => setShowTestResult(false)}
        footer={[
          <Button key="close" type="primary" onClick={() => setShowTestResult(false)}>
            Close
          </Button>,
        ]}
        width={600}
      >
        {testResult && (
          <div style={{ padding: "16px 0" }}>
            <div style={{ marginBottom: 16 }}>
              <strong>Integration:</strong> {testResult.integration}
            </div>
            
            <div style={{ marginBottom: 16 }}>
              <strong>Status:</strong>{" "}
              <span style={{ color: testResult.success ? "#52c41a" : "#ff4d4f" }}>
                {testResult.success ? "Success" : "Failed"}
              </span>
            </div>
            
            <div style={{ marginBottom: 16 }}>
              <strong>Message:</strong> {testResult.message}
            </div>
            
            {testResult.details && (
              <div style={{ 
                marginTop: 16, 
                padding: 12, 
                background: "#f5f5f5", 
                borderRadius: 4,
                fontSize: 12,
                fontFamily: "monospace"
              }}>
                <strong>Details:</strong>
                <pre style={{ margin: "8px 0 0 0", whiteSpace: "pre-wrap" }}>
                  {JSON.stringify(testResult.details, null, 2)}
                </pre>
              </div>
            )}
            
            {testResult.error && (
              <div style={{ 
                marginTop: 16, 
                padding: 12, 
                background: "#fff2f0", 
                border: "1px solid #ffccc7",
                borderRadius: 4,
                color: "#ff4d4f"
              }}>
                <strong>Error:</strong> {testResult.error}
              </div>
            )}
          </div>
        )}
      </Modal>

      {/* Test Results Modal */}
      <Modal
        title={testResult?.success ? "✅ Test Successful" : "❌ Test Failed"}
        open={showTestResult}
        onCancel={() => setShowTestResult(false)}
        footer={[
          <Button key="close" type="primary" onClick={() => setShowTestResult(false)}>
