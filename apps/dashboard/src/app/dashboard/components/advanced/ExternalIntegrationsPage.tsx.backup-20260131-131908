                borderRadius: 4,
                fontSize: 12,
                fontFamily: "monospace"
              }}>
                <strong>Details:</strong>
                <pre style={{ margin: "8px 0 0 0", whiteSpace: "pre-wrap" }}>
                  {JSON.stringify(testResult.details, null, 2)}
                </pre>
              </div>
            )}
            
            {testResult.error && (
              <div style={{ 
                marginTop: 16, 
                padding: 12, 
                background: "#fff2f0", 
                border: "1px solid #ffccc7",
                borderRadius: 4,
                color: "#ff4d4f"
              }}>
                <strong>Error:</strong> {testResult.error}
              </div>
            )}
          </div>
        )}
      </Modal>
    </div>
  );
