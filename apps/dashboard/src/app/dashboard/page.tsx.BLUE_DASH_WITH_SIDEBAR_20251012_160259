'use client'

import { useState, useEffect } from 'react'
import { motion, AnimatePresence } from 'framer-motion'
import { useRouter } from 'next/navigation'
import { 
  ShieldCheckIcon, 
  BoltIcon, 
  BugAntIcon, 
  ChartBarIcon,
  ExclamationTriangleIcon,
  CheckCircleIcon,
  FireIcon,
  GlobeAltIcon,
  CubeIcon,
  ClockIcon,
  DocumentChartBarIcon,
  Cog6ToothIcon,
  ArrowPathIcon,
  BellIcon,
  Bars3Icon,
  XMarkIcon,
  ChevronRightIcon,
  RocketLaunchIcon,
  KeyIcon,
  CloudArrowUpIcon,
  ShieldExclamationIcon,
  AdjustmentsHorizontalIcon,
  SignalIcon,
  BeakerIcon,
  FunnelIcon,
  ArrowDownTrayIcon
} from '@heroicons/react/24/outline'
import { 
  LineChart, 
  Line, 
  AreaChart, 
  Area, 
  BarChart,
  Bar,
  ResponsiveContainer, 
  XAxis, 
  YAxis, 
  Tooltip,
  CartesianGrid,
  PieChart,
  Pie,
  Cell
} from 'recharts'
import { message, Avatar, Dropdown, Spin, Badge, Progress, Tag } from 'antd'

// Feature Pages Components
import { SecurityScanResults } from './components/SecurityScanResults'
import { RealComplianceDashboard } from './components/RealComplianceDashboard'
import { WebhookIntegration } from './components/WebhookIntegration'
import { APIDiscovery } from './components/APIDiscovery'

const SIDEBAR_ITEMS = [
  {
    category: 'Security Operations',
    items: [
      { id: 'overview', label: 'Overview', icon: ChartBarIcon },
      { id: 'security-scans', label: 'Security Scans', icon: ShieldCheckIcon },
      { id: 'vulnerabilities', label: 'Vulnerabilities', icon: ShieldExclamationIcon },
      { id: 'threat-detection', label: 'Threat Detection', icon: ExclamationTriangleIcon },
      { id: 'threat-trends', label: 'Threat Trends', icon: SignalIcon },
      { id: 'bot-detection', label: 'Bot Protection', icon: BugAntIcon },
    ]
  },
  {
    category: 'API Management',
    items: [
      { id: 'api-discovery', label: 'API Discovery', icon: GlobeAltIcon },
      { id: 'api-endpoints', label: 'API Endpoints', icon: CubeIcon },
      { id: 'scheduled-scans', label: 'Scheduled Scans', icon: ClockIcon },
    ]
  },
  {
    category: 'Integrations',
    items: [
      { id: 'external-integrations', label: 'External Integrations', icon: CloudArrowUpIcon },
      { id: 'platform-api-keys', label: 'Platform API Keys', icon: KeyIcon },
      { id: 'webhooks', label: 'Webhooks', icon: BoltIcon },
    ]
  },
  {
    category: 'Compliance & Rules',
    items: [
      { id: 'compliance', label: 'Compliance Hub', icon: DocumentChartBarIcon },
      { id: 'custom-rules', label: 'Custom Rules', icon: AdjustmentsHorizontalIcon },
      { id: 'rate-limits', label: 'Rate Limits', icon: FunnelIcon },
    ]
  },
  {
    category: 'Monitoring',
    items: [
      { id: 'performance', label: 'Performance', icon: RocketLaunchIcon },
      { id: 'alerts', label: 'Alerts', icon: BellIcon },
      { id: 'enterprise-settings', label: 'Enterprise Settings', icon: Cog6ToothIcon },
    ]
  }
]

export default function EnterpriseDashboard() {
  const router = useRouter()
  const [user, setUser] = useState<any>(null)
  const [company, setCompany] = useState<any>(null)
  const [activeFeature, setActiveFeature] = useState('overview')
  const [sidebarCollapsed, setSidebarCollapsed] = useState(false)
  const [dashboardStats, setDashboardStats] = useState<any>(null)
  const [featureData, setFeatureData] = useState<any>({})
  const [loading, setLoading] = useState(true)

  useEffect(() => {
    if (typeof window !== 'undefined') {
      const storedUser = sessionStorage.getItem('user')
      const storedCompany = sessionStorage.getItem('company')
      
      if (storedUser && storedCompany) {
        setUser(JSON.parse(storedUser))
        setCompany(JSON.parse(storedCompany))
      } else {
        router.push('/login')
      }
    }
  }, [router])

  useEffect(() => {
    if (!company?.id) return

    const fetchDashboard = async () => {
      setLoading(true)
      try {
        const response = await fetch('/api/customer/dashboard', {
          headers: { 'x-tenant-id': company.id.toString() }
        })
        const result = await response.json()
        if (result.success) {
          setDashboardStats(result.dashboard)
        }
      } catch (err) {
        console.error(err)
      } finally {
        setLoading(false)
      }
    }

    fetchDashboard()
  }, [company])

  const fetchFeatureData = async (featureId: string) => {
    if (!company?.id) return
    
    try {
      const response = await fetch(`/api/customer/${featureId}`, {
        headers: { 'x-tenant-id': company.id.toString() }
      })
      const data = await response.json()
      setFeatureData(prev => ({ ...prev, [featureId]: data }))
    } catch (err) {
      console.error(`Error fetching ${featureId}:`, err)
    }
  }

  useEffect(() => {
    if (activeFeature !== 'overview') {
      fetchFeatureData(activeFeature)
    }
  }, [activeFeature, company])

  const handleLogout = () => {
    sessionStorage.clear()
    router.push('/login')
  }

  if (loading || !dashboardStats) {
    return (
      <div className="min-h-screen bg-gradient-to-br from-slate-950 via-blue-950 to-slate-900 flex items-center justify-center">
        <Spin size="large" />
      </div>
    )
  }

  const StatCard = ({ icon: Icon, label, value, color, trend }: any) => (
    <motion.div
      whileHover={{ scale: 1.02, boxShadow: `0 0 30px ${color}40` }}
      className="relative overflow-hidden rounded-xl p-6 backdrop-blur-xl bg-white/5 border border-white/10"
    >
      <div className="flex items-center justify-between">
        <div className={`p-3 rounded-xl`} style={{ backgroundColor: `${color}20` }}>
          <Icon className="w-6 h-6" style={{ color }} />
        </div>
        {trend && (
          <div className="text-sm font-semibold text-green-400">+{trend}%</div>
        )}
      </div>
      <div className="mt-4">
        <div className="text-3xl font-bold text-white">{value}</div>
        <div className="text-sm text-gray-400 mt-1">{label}</div>
      </div>
    </motion.div>
  )

  const renderFeaturePage = () => {
    const data = featureData[activeFeature]

    switch(activeFeature) {
      case 'overview':
        return (
          <div className="space-y-6">
            {/* Hero Stats */}
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
              <StatCard icon={ShieldCheckIcon} label="Protected Endpoints" value={dashboardStats.overview.totalApis} color="#06b6d4" trend={12} />
              <StatCard icon={BoltIcon} label="Threats Blocked" value={dashboardStats.overview.blockedThreats} color="#10b981" trend={8} />
              <StatCard icon={BugAntIcon} label="Security Scans" value={dashboardStats.overview.scansLast7Days} color="#f59e0b" />
              <StatCard icon={FireIcon} label="Critical Issues" value={dashboardStats.security.criticalVulnerabilities} color="#ef4444" />
            </div>

            {/* Security Score */}
            <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
              <div className="lg:col-span-2 p-6 rounded-xl backdrop-blur-xl bg-white/5 border border-white/10">
                <h3 className="text-xl font-bold text-white mb-4">Security Score Timeline</h3>
                <div className="h-64">
                  <ResponsiveContainer width="100%" height="100%">
                    <AreaChart data={Array.from({ length: 7 }, (_, i) => ({ 
                      day: `Day ${i+1}`, 
                      score: Math.floor(Math.random() * 20) + 80 
                    }))}>
                      <defs>
                        <linearGradient id="scoreGradient" x1="0" y1="0" x2="0" y2="1">
                          <stop offset="5%" stopColor="#06b6d4" stopOpacity={0.3}/>
                          <stop offset="95%" stopColor="#06b6d4" stopOpacity={0}/>
                        </linearGradient>
                      </defs>
                      <CartesianGrid strokeDasharray="3 3" stroke="rgba(255,255,255,0.1)" />
                      <XAxis dataKey="day" stroke="#94a3b8" />
                      <YAxis stroke="#94a3b8" />
                      <Tooltip contentStyle={{ backgroundColor: '#1e293b', border: '1px solid rgba(255,255,255,0.1)', borderRadius: '8px' }} />
                      <Area type="monotone" dataKey="score" stroke="#06b6d4" fill="url(#scoreGradient)" strokeWidth={2} />
                    </AreaChart>
                  </ResponsiveContainer>
                </div>
              </div>

              <div className="p-6 rounded-xl backdrop-blur-xl bg-white/5 border border-white/10">
                <h3 className="text-xl font-bold text-white mb-4">Overall Score</h3>
                <div className="flex items-center justify-center h-64">
                  <div className="relative">
                    <svg className="w-48 h-48 transform -rotate-90">
                      <circle cx="96" cy="96" r="88" fill="none" stroke="rgba(255,255,255,0.1)" strokeWidth="16" />
                      <motion.circle
                        cx="96"
                        cy="96"
                        r="88"
                        fill="none"
                        stroke="#06b6d4"
                        strokeWidth="16"
                        strokeLinecap="round"
                        strokeDasharray={`${2 * Math.PI * 88}`}
                        initial={{ strokeDashoffset: 2 * Math.PI * 88 }}
                        animate={{ strokeDashoffset: 2 * Math.PI * 88 * (1 - dashboardStats.security.overallScore / 100) }}
                        transition={{ duration: 2, ease: "easeOut" }}
                      />
                    </svg>
                    <div className="absolute inset-0 flex items-center justify-center">
                      <div className="text-center">
                        <div className="text-5xl font-bold text-white">{dashboardStats.security.overallScore}</div>
                        <div className="text-sm text-gray-400">Security Score</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        )

      case 'security-scans':
        return (
          <div className="space-y-6">
            <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
              <StatCard icon={ShieldCheckIcon} label="Total Scans" value={data?.statistics?.totalScans || 0} color="#06b6d4" />
              <StatCard icon={CheckCircleIcon} label="Completed" value={data?.statistics?.completedScans || 0} color="#10b981" />
              <StatCard icon={ClockIcon} label="Pending" value={data?.statistics?.pendingScans || 0} color="#f59e0b" />
            </div>
            <SecurityScanResults results={null} />
          </div>
        )

      case 'vulnerabilities':
        return (
          <div className="space-y-6">
            <div className="grid grid-cols-1 md:grid-cols-4 gap-6">
              <StatCard icon={ExclamationTriangleIcon} label="Critical" value={data?.summary?.critical || 0} color="#ef4444" />
              <StatCard icon={ExclamationTriangleIcon} label="High" value={data?.summary?.high || 0} color="#f97316" />
              <StatCard icon={ExclamationTriangleIcon} label="Medium" value={data?.summary?.medium || 0} color="#f59e0b" />
              <StatCard icon={CheckCircleIcon} label="Low" value={data?.summary?.low || 0} color="#10b981" />
            </div>
            <div className="p-6 rounded-xl backdrop-blur-xl bg-white/5 border border-white/10">
              <h3 className="text-xl font-bold text-white mb-4">Recent Vulnerabilities</h3>
              <div className="space-y-3">
                {data?.vulnerabilities?.slice(0, 5).map((vuln: any, i: number) => (
                  <div key={i} className="flex items-center justify-between p-4 rounded-lg bg-white/5 border border-white/10">
                    <div>
                      <div className="text-white font-semibold">{vuln.title}</div>
                      <div className="text-sm text-gray-400">{vuln.description}</div>
                    </div>
                    <Tag color={vuln.severity === 'CRITICAL' ? 'red' : vuln.severity === 'HIGH' ? 'orange' : 'yellow'}>
                      {vuln.severity}
                    </Tag>
                  </div>
                )) || <div className="text-gray-400 text-center py-8">No vulnerabilities found</div>}
              </div>
            </div>
          </div>
        )

      case 'bot-detection':
        return (
          <div className="space-y-6">
            <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
              <StatCard icon={BugAntIcon} label="Bots Detected" value={data?.botDetection?.totalDetected || 0} color="#8b5cf6" />
              <StatCard icon={ShieldCheckIcon} label="Bots Blocked" value={data?.botDetection?.blocked || 0} color="#10b981" />
              <StatCard icon={ChartBarIcon} label="Detection Rate" value={`${data?.botDetection?.detectionRate || 0}%`} color="#06b6d4" />
            </div>
            <div className="p-6 rounded-xl backdrop-blur-xl bg-white/5 border border-white/10">
              <h3 className="text-xl font-bold text-white mb-4">Bot Activity (24h)</h3>
              <div className="h-64">
                <ResponsiveContainer width="100%" height="100%">
                  <BarChart data={data?.botDetection?.timeline || []}>
                    <CartesianGrid strokeDasharray="3 3" stroke="rgba(255,255,255,0.1)" />
                    <XAxis dataKey="hour" stroke="#94a3b8" />
                    <YAxis stroke="#94a3b8" />
                    <Tooltip contentStyle={{ backgroundColor: '#1e293b', border: 'none', borderRadius: '8px' }} />
                    <Bar dataKey="count" fill="#8b5cf6" radius={[8, 8, 0, 0]} />
                  </BarChart>
                </ResponsiveContainer>
              </div>
            </div>
          </div>
        )

      case 'compliance':
        return <RealComplianceDashboard />

      case 'webhooks':
        return <WebhookIntegration />

      case 'api-discovery':
        return <APIDiscovery />

      case 'external-integrations':
        return (
          <div className="space-y-6">
            <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
              <StatCard icon={CloudArrowUpIcon} label="Total Integrations" value={data?.integrations?.length || 0} color="#06b6d4" />
              <StatCard icon={CheckCircleIcon} label="Active" value={data?.integrations?.filter((i: any) => i.isActive).length || 0} color="#10b981" />
              <StatCard icon={XMarkIcon} label="Inactive" value={data?.integrations?.filter((i: any) => !i.isActive).length || 0} color="#ef4444" />
            </div>
            <div className="p-6 rounded-xl backdrop-blur-xl bg-white/5 border border-white/10">
              <h3 className="text-xl font-bold text-white mb-4">Connected Integrations</h3>
              <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                {data?.integrations?.map((integration: any) => (
                  <div key={integration.id} className="p-4 rounded-lg bg-white/5 border border-white/10">
                    <div className="flex items-center justify-between mb-2">
                      <div className="text-white font-semibold">{integration.name}</div>
                      <Badge status={integration.isActive ? 'success' : 'default'} />
                    </div>
                    <div className="text-sm text-gray-400">{integration.type}</div>
                  </div>
                )) || <div className="col-span-3 text-gray-400 text-center py-8">No integrations configured</div>}
              </div>
            </div>
          </div>
        )

      case 'platform-api-keys':
        return (
          <div className="space-y-6">
            <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
              <StatCard icon={KeyIcon} label="Total Keys" value={data?.apiKeys?.length || 0} color="#06b6d4" />
              <StatCard icon={CheckCircleIcon} label="Active Keys" value={data?.apiKeys?.filter((k: any) => k.isActive).length || 0} color="#10b981" />
              <StatCard icon={ClockIcon} label="Expiring Soon" value={data?.apiKeys?.filter((k: any) => k.expiresAt).length || 0} color="#f59e0b" />
            </div>
            <div className="p-6 rounded-xl backdrop-blur-xl bg-white/5 border border-white/10">
              <div className="flex items-center justify-between mb-4">
                <h3 className="text-xl font-bold text-white">API Keys</h3>
                <button className="px-4 py-2 bg-cyan-500 hover:bg-cyan-600 text-white rounded-lg font-semibold transition-colors">
                  Create New Key
                </button>
              </div>
              <div className="space-y-3">
                {data?.apiKeys?.map((key: any) => (
                  <div key={key.id} className="flex items-center justify-between p-4 rounded-lg bg-white/5 border border-white/10">
                    <div>
                      <div className="text-white font-semibold">{key.name}</div>
                      <div className="text-sm text-gray-400 font-mono">{key.keyPrefix}...</div>
                    </div>
                    <Badge status={key.isActive ? 'success' : 'default'} text={key.isActive ? 'Active' : 'Inactive'} />
                  </div>
                )) || <div className="text-gray-400 text-center py-8">No API keys created</div>}
              </div>
            </div>
          </div>
        )

      default:
        return (
          <div className="p-6 rounded-xl backdrop-blur-xl bg-white/5 border border-white/10">
            <h3 className="text-xl font-bold text-white mb-4">{SIDEBAR_ITEMS.flatMap(g => g.items).find(i => i.id === activeFeature)?.label}</h3>
            <div className="text-gray-400">Feature page coming soon...</div>
          </div>
        )
    }
  }

  return (
    <div className="min-h-screen bg-gradient-to-br from-slate-950 via-blue-950 to-slate-900 flex">
      {/* Sidebar */}
      <motion.div
        initial={false}
        animate={{ width: sidebarCollapsed ? 80 : 280 }}
        className="relative border-r border-white/10 backdrop-blur-xl bg-black/20"
      >
        <div className="p-6">
          <div className="flex items-center justify-between mb-8">
            {!sidebarCollapsed && (
              <h1 className="text-xl font-bold bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">
                🛡️ GoverAPI
              </h1>
            )}
            <button
              onClick={() => setSidebarCollapsed(!sidebarCollapsed)}
              className="p-2 rounded-lg hover:bg-white/10 transition-colors text-gray-400"
            >
              {sidebarCollapsed ? <Bars3Icon className="w-5 h-5" /> : <XMarkIcon className="w-5 h-5" />}
            </button>
          </div>

          <div className="space-y-6">
            {SIDEBAR_ITEMS.map((group, idx) => (
              <div key={idx}>
                {!sidebarCollapsed && (
                  <div className="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3 px-3">
                    {group.category}
                  </div>
                )}
                <div className="space-y-1">
                  {group.items.map((item) => {
                    const Icon = item.icon
                    const isActive = activeFeature === item.id
                    return (
                      <motion.button
                        key={item.id}
                        onClick={() => setActiveFeature(item.id)}
                        whileHover={{ x: 4 }}
                        className={`
                          w-full flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all
                          ${isActive 
                            ? 'bg-gradient-to-r from-cyan-500/20 to-blue-500/20 border border-cyan-500/50 text-cyan-400' 
                            : 'text-gray-400 hover:bg-white/5 hover:text-white'
                          }
                        `}
                      >
                        <Icon className="w-5 h-5 flex-shrink-0" />
                        {!sidebarCollapsed && (
                          <>
                            <span className="flex-1 text-left text-sm font-medium">{item.label}</span>
                            {isActive && <ChevronRightIcon className="w-4 h-4" />}
                          </>
                        )}
                      </motion.button>
                    )
                  })}
                </div>
              </div>
            ))}
          </div>
        </div>
      </motion.div>

      {/* Main Content */}
      <div className="flex-1 flex flex-col">
        {/* Top Bar */}
        <nav className="border-b border-white/10 backdrop-blur-xl bg-black/20">
          <div className="px-8 py-4">
            <div className="flex items-center justify-between">
              <div>
                <h2 className="text-2xl font-bold text-white">
                  {SIDEBAR_ITEMS.flatMap(g => g.items).find(i => i.id === activeFeature)?.label || 'Dashboard'}
                </h2>
                <p className="text-sm text-gray-400">{company?.companyName}</p>
              </div>
              
              <div className="flex items-center space-x-4">
                <Badge dot color="#52c41a">
                  <div className="px-4 py-2 rounded-full bg-gradient-to-r from-cyan-500 to-blue-500 text-white text-sm font-bold">
                    PROFESSIONAL PLAN
                  </div>
                </Badge>
                <button className="p-2 rounded-xl hover:bg-white/10 transition-colors relative">
                  <BellIcon className="w-5 h-5 text-gray-400" />
                  <span className="absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full" />
                </button>
                <button onClick={() => fetchFeatureData(activeFeature)} className="p-2 rounded-xl hover:bg-white/10 transition-colors">
                  <ArrowPathIcon className="w-5 h-5 text-gray-400" />
                </button>
                <Dropdown
                  menu={{
                    items: [
                      { key: '1', label: <span className="text-white">{user?.firstName} {user?.lastName}</span>, disabled: true },
                      { key: '2', label: <span className="text-gray-400">{company?.companyName}</span>, disabled: true },
                      { type: 'divider' },
                      { key: '3', icon: <Cog6ToothIcon className="w-4 h-4" />, label: 'Settings' },
                      { key: '4', label: 'Logout', onClick: handleLogout, danger: true }
                    ]
                  }}
                >
                  <Avatar size={40} className="cursor-pointer bg-gradient-to-br from-cyan-500 to-blue-600 text-white font-bold">
                    {user?.firstName?.[0]}{user?.lastName?.[0]}
                  </Avatar>
                </Dropdown>
              </div>
            </div>
          </div>
        </nav>

        {/* Page Content */}
        <div className="flex-1 p-8 overflow-auto">
          <AnimatePresence mode="wait">
            <motion.div
              key={activeFeature}
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              exit={{ opacity: 0, y: -20 }}
              transition={{ duration: 0.3 }}
            >
              {renderFeaturePage()}
            </motion.div>
          </AnimatePresence>
        </div>
      </div>
    </div>
  )
}
