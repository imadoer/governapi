"use client";
import * as React from "react";
import { useState } from "react";
import {
  Card,
  Row,
  Col,
  Button,
  Typography,
  Progress,
  Tag,
  Space,
  Table,
} from "antd";
import {
  BarChartOutlined,
  LockOutlined,
  BugOutlined,
  ApiOutlined,
  ReloadOutlined,
  AlertOutlined,
  CheckCircleOutlined,
} from "@ant-design/icons";

const { Title, Text, Paragraph } = Typography;

const calculateSecurityScore = (
  vulnerabilities: any[],
  totalScans: number,
  blockedThreats: any[],
  securityScans: any[],
): number => {
  let score = 100;

  // Vulnerability Risk (40% weight)
  if (vulnerabilities && vulnerabilities.length > 0) {
    vulnerabilities.forEach((vuln) => {
      const severity = vuln.severity || vuln.cvss;
      if (
        severity === "Critical" ||
        (typeof severity === "number" && severity >= 9.0)
      ) {
        score -= 25;
      } else if (
        severity === "High" ||
        (typeof severity === "number" && severity >= 7.0)
      ) {
        score -= 15;
      } else if (
        severity === "Medium" ||
        (typeof severity === "number" && severity >= 4.0)
      ) {
        score -= 8;
      } else if (
        severity === "Low" ||
        (typeof severity === "number" && severity >= 0.1)
      ) {
        score -= 3;
      }
    });
  }

  // Security Posture (30% weight)
  if (totalScans > 0) score += 10;
  if (securityScans && securityScans.length > 0) {
    const lastScan = new Date(securityScans[0].timestamp);
    const daysSince = Math.floor(
      (Date.now() - lastScan.getTime()) / (1000 * 60 * 60 * 24),
    );
    if (daysSince > 7) score -= Math.min(daysSince - 7, 20);
  }
  score += 15; // Encryption and auth assumed active

  // Threat Response (20% weight)
  if (blockedThreats && blockedThreats.length > 0) score += 10;

  // Compliance (10% weight)
  score += 10; // Basic compliance assumed

  return Math.min(100, Math.max(0, Math.round(score)));
};

export default function Overview({
  stats,
  refreshData,
  refreshing,
  company,
  apiKeys = [],
  blockedThreats = [],
  botEvents = [],
  apiEndpoints = [],
  vulnerabilities = [],
  securityScans = [],
  performanceMetrics = {},
}) {
  const [timeRange, setTimeRange] = useState("24h");

  // Calculate meaningful insights from real data
  const totalEndpoints = apiEndpoints.length || stats?.totalEndpoints || 0;
  const totalThreatsBlocked = blockedThreats.length || stats?.totalThreats || 0;
  const totalScans = stats?.totalScans || securityScans.length || 0;
  const totalRequests = stats?.totalRequests || 0;

  // Calculate security score based on actual data
  const securityScore = stats?.avgSecurityScore || calculateSecurityScore(
    vulnerabilities,
    totalScans,
    blockedThreats,
    securityScans,
  );

  const getScoreColor = (score) => {
    if (score >= 90) return "#52c41a";
    if (score >= 80) return "#1890ff";
    if (score >= 70) return "#faad14";
    return "#ff4d4f";
  };

  // Recent activity from real data
  const recentActivity = [];

  if (totalThreatsBlocked > 0) {
    recentActivity.push({
      type: "threat",
      title: "Threat Blocked",
      description: `${totalThreatsBlocked} security threats intercepted and blocked`,
      time: "Recent",
      severity: "high",
    });
  }

  if (totalScans > 0) {
    recentActivity.push({
      type: "scan",
      title: "Security Scan Completed",
      description: `${totalEndpoints} API endpoints scanned successfully`,
      time: "Recent",
      severity: "info",
    });
  }

  if (apiKeys.length > 0) {
    recentActivity.push({
      type: "api",
      title: "API Activity",
      description: `${apiKeys.length} active API keys managing access`,
      time: "Ongoing",
      severity: "info",
    });
  }

  // API performance insights
  const apiHealthColumns = [
    {
      title: "Endpoint",
      dataIndex: "path",
      key: "path",
      render: (path) => <Text code>{path || "/api/example"}</Text>,
    },
    {
      title: "Status",
      dataIndex: "status",
      key: "status",
      render: () => <Tag color="green">Healthy</Tag>,
    },
    {
      title: "Response Time",
      dataIndex: "responseTime",
      key: "responseTime",
      render: (_, record) => <Text>{record.responseTime || "N/A"}ms</Text>,
    },
    {
      title: "Requests/Day",
      dataIndex: "requests",
      key: "requests",
      render: (requests) => <Text>{requests || 0}</Text>,
    },
  ];

  const endpointData = apiEndpoints.slice(0, 5).map((endpoint, index) => ({
    key: index,
    path: endpoint.path || `/api/endpoint-${index + 1}`,
    status: endpoint.status || "healthy",
    responseTime: endpoint.responseTime || 0,
    requests: endpoint.requests || 0,
  }));

  return (
    <div>
      {/* Header with Company Info */}
      <div style={{ marginBottom: 32 }}>
        <div
          style={{
            display: "flex",
            justifyContent: "space-between",
            alignItems: "flex-start",
            marginBottom: 16,
          }}
        >
          <div>
            <Title
              level={1}
              style={{ margin: 0, color: "#1f2937", fontSize: "32px" }}
            >
              API Security Dashboard
            </Title>
            <Text style={{ fontSize: "16px", color: "#6b7280" }}>
              {company?.company_name || "Demo Company"} •{" "}
              {company?.subscription_plan?.toUpperCase() || "PROFESSIONAL"} Plan
            </Text>
          </div>
          <Space>
            <Button
              onClick={refreshData}
              loading={refreshing}
              icon={<ReloadOutlined />}
            >
              Refresh Data
            </Button>
          </Space>
        </div>

        <Card
          style={{
            background: "linear-gradient(135deg, #667eea 0%, #764ba2 100%)",
            color: "white",
            border: "none",
            marginBottom: 16,
          }}
        >
          <Row align="middle">
            <Col xs={24} md={18}>
              <Title level={4} style={{ color: "white", marginBottom: 4 }}>
                Enterprise Security Overview
              </Title>
              <Text
                style={{ color: "rgba(255,255,255,0.9)", fontSize: "14px" }}
              >
                Protecting {totalEndpoints} endpoints, blocked{" "}
                {totalThreatsBlocked} threats • {securityScore}% security score
              </Text>
            </Col>
            <Col xs={24} md={6} style={{ textAlign: "center" }}>
              <div
                style={{ fontSize: "32px", fontWeight: "bold", color: "white" }}
              >
                {securityScore}%
              </div>
              <Text
                style={{ color: "rgba(255,255,255,0.9)", fontSize: "12px" }}
              >
                Security Score
              </Text>
            </Col>
          </Row>
        </Card>
      </div>

      {/* Key Metrics Grid */}
      <Row gutter={[24, 24]} style={{ marginBottom: 32 }}>
        <Col xs={12} lg={6}>
          <Card>
            <div style={{ textAlign: "center" }}>
              <ApiOutlined
                style={{ fontSize: 32, color: "#1890ff", marginBottom: 8 }}
              />
              <div
                style={{
                  fontSize: "28px",
                  fontWeight: "bold",
                  color: "#1890ff",
                }}
              >
                {totalEndpoints}
              </div>
              <Text type="secondary">Protected Endpoints</Text>
              <Progress
                percent={Math.min(100, totalEndpoints * 20)}
                strokeColor="#1890ff"
                showInfo={false}
                size="small"
                style={{ marginTop: 8 }}
              />
            </div>
          </Card>
        </Col>

        <Col xs={12} lg={6}>
          <Card>
            <div style={{ textAlign: "center" }}>
              <LockOutlined
                style={{ fontSize: 32, color: "#ff4d4f", marginBottom: 8 }}
              />
              <div
                style={{
                  fontSize: "28px",
                  fontWeight: "bold",
                  color: "#ff4d4f",
                }}
              >
                {totalThreatsBlocked}
              </div>
              <Text type="secondary">Threats Blocked</Text>
              <Progress
                percent={Math.min(100, totalThreatsBlocked * 25)}
                strokeColor="#ff4d4f"
                showInfo={false}
                size="small"
                style={{ marginTop: 8 }}
              />
            </div>
          </Card>
        </Col>

        <Col xs={12} lg={6}>
          <Card>
            <div style={{ textAlign: "center" }}>
              <BugOutlined
                style={{ fontSize: 32, color: "#52c41a", marginBottom: 8 }}
              />
              <div
                style={{
                  fontSize: "28px",
                  fontWeight: "bold",
                  color: "#52c41a",
                }}
              >
                {totalScans}
              </div>
              <Text type="secondary">Security Scans</Text>
              <Progress
                percent={100}
                strokeColor="#52c41a"
                showInfo={false}
                size="small"
                style={{ marginTop: 8 }}
              />
            </div>
          </Card>
        </Col>

        <Col xs={12} lg={6}>
          <Card>
            <div style={{ textAlign: "center" }}>
              <BarChartOutlined
                style={{ fontSize: 32, color: "#722ed1", marginBottom: 8 }}
              />
              <div
                style={{
                  fontSize: "28px",
                  fontWeight: "bold",
                  color: "#722ed1",
                }}
              >
                {totalRequests.toLocaleString()}
              </div>
              <Text type="secondary">API Requests</Text>
              <Progress
                percent={75}
                strokeColor="#722ed1"
                showInfo={false}
                size="small"
                style={{ marginTop: 8 }}
              />
            </div>
          </Card>
        </Col>
      </Row>

      {/* Main Dashboard Content */}
      <Row gutter={[24, 24]}>
        <Col xs={24} lg={16}>
          <Card
            title="API Health Status"
            extra={<Tag color="green">All Systems Operational</Tag>}
          >
            <Table
              columns={apiHealthColumns}
              dataSource={endpointData}
              pagination={false}
              size="small"
            />
          </Card>
        </Col>

        <Col xs={24} lg={8}>
          <Card title="Security Health" style={{ marginBottom: 24 }}>
            <div style={{ textAlign: "center", marginBottom: 20 }}>
              <Progress
                type="circle"
                percent={securityScore}
                strokeColor={getScoreColor(securityScore)}
                width={100}
              />
              <div style={{ marginTop: 12 }}>
                <Text
                  strong
                  style={{
                    fontSize: "16px",
                    color: getScoreColor(securityScore),
                  }}
                >
                  {securityScore >= 90
                    ? "Excellent"
                    : securityScore >= 80
                      ? "Good"
                      : "Needs Attention"}
                </Text>
              </div>
            </div>

            <Space direction="vertical" style={{ width: "100%" }}>
              <div
                style={{
                  display: "flex",
                  alignItems: "center",
                  justifyContent: "space-between",
                }}
              >
                <Space>
                  <CheckCircleOutlined style={{ color: "#52c41a" }} />
                  <Text>Threat Detection</Text>
                </Space>
                <Tag color="green">Active</Tag>
              </div>
              <div
                style={{
                  display: "flex",
                  alignItems: "center",
                  justifyContent: "space-between",
                }}
              >
                <Space>
                  <CheckCircleOutlined style={{ color: "#52c41a" }} />
                  <Text>API Monitoring</Text>
                </Space>
                <Tag color="green">Active</Tag>
              </div>
              <div
                style={{
                  display: "flex",
                  alignItems: "center",
                  justifyContent: "space-between",
                }}
              >
                <Space>
                  <CheckCircleOutlined style={{ color: "#52c41a" }} />
                  <Text>Rate Limiting</Text>
                </Space>
                <Tag color="green">Active</Tag>
              </div>
            </Space>
          </Card>

          <Card title="Recent Activity">
            <Space direction="vertical" style={{ width: "100%" }}>
              {recentActivity.length > 0 ? (
                recentActivity.map((activity, index) => (
                  <div
                    key={index}
                    style={{
                      padding: 12,
                      background:
                        activity.severity === "high" ? "#fff2e8" : "#f6ffed",
                      borderRadius: 8,
                      border: `1px solid ${activity.severity === "high" ? "#ffd591" : "#b7eb8f"}`,
                    }}
                  >
                    <Space>
                      <AlertOutlined
                        style={{
                          color:
                            activity.severity === "high"
                              ? "#fa8c16"
                              : "#52c41a",
                        }}
                      />
                      <div>
                        <Text strong>{activity.title}</Text>
                        <div
                          style={{
                            fontSize: "12px",
                            color: "#666",
                            marginTop: 2,
                          }}
                        >
                          {activity.description}
                        </div>
                        <Text type="secondary" style={{ fontSize: "11px" }}>
                          {activity.time}
                        </Text>
                      </div>
                    </Space>
                  </div>
                ))
              ) : (
                <Text type="secondary">No recent activity</Text>
              )}
            </Space>
          </Card>
        </Col>
      </Row>
    </div>
  );
}
