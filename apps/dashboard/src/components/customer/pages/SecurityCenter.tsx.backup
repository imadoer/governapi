'use client'
import React, { useState } from 'react'
import { Card, Row, Col, Typography, Button, Tag, Space, Table, Progress, Divider } from 'antd'
import { ReloadOutlined, SecurityScanOutlined, LockOutlined, BugOutlined, AlertOutlined, CheckCircleOutlined } from '@ant-design/icons'

const { Title, Paragraph, Text } = Typography

export default function SecurityCenter({ stats, refreshData, refreshing, blockedThreats = [], vulnerabilities = [] }) {
  const [selectedThreat, setSelectedThreat] = useState(null)

  const threatData = [
    { id: '1', type: 'SQL Injection', sourceIp: '192.168.1.100', severity: 'Critical', timestamp: '2024-10-07 14:30', status: 'Blocked' },
    { id: '2', type: 'XSS Attack', sourceIp: '10.0.0.15', severity: 'High', timestamp: '2024-10-07 11:45', status: 'Blocked' },
    { id: '3', type: 'Rate Limit Exceeded', sourceIp: '172.16.0.5', severity: 'Medium', timestamp: '2024-10-07 10:20', status: 'Blocked' },
    { id: '4', type: 'Bot Attack', sourceIp: '203.45.67.89', severity: 'High', timestamp: '2024-10-07 09:15', status: 'Blocked' },
    { id: '5', type: 'DDoS Attempt', sourceIp: '45.123.67.12', severity: 'Critical', timestamp: '2024-10-07 08:00', status: 'Blocked' }
  ]

  const securityEvents = [
    { title: 'DDoS Attack Mitigated', description: 'Large-scale attack from 50+ IPs blocked automatically', time: '5 minutes ago', severity: 'critical' },
    { title: 'Vulnerability Scan Complete', description: 'No critical vulnerabilities detected in API endpoints', time: '1 hour ago', severity: 'info' },
    { title: 'Rate Limit Policy Updated', description: 'New rate limiting rules applied to protect against abuse', time: '3 hours ago', severity: 'warning' },
    { title: 'SSL Certificate Renewed', description: 'Security certificate automatically renewed for 1 year', time: '1 day ago', severity: 'success' }
  ]

  const threatColumns = [
    {
      title: 'Threat Type',
      dataIndex: 'type',
      key: 'type',
      render: (type, record) => (
        <Tag color={record.severity === 'Critical' ? 'red' : record.severity === 'High' ? 'orange' : 'blue'}>
          {type}
        </Tag>
      )
    },
    {
      title: 'Source IP',
      dataIndex: 'sourceIp',
      key: 'sourceIp',
      render: (ip) => <Text code>{ip}</Text>
    },
    {
      title: 'Severity',
      dataIndex: 'severity',
      key: 'severity',
      render: (severity) => (
        <Tag color={severity === 'Critical' ? 'red' : severity === 'High' ? 'orange' : 'blue'}>
          {severity}
        </Tag>
      )
    },
    {
      title: 'Time',
      dataIndex: 'timestamp',
      key: 'timestamp'
    },
    {
      title: 'Status',
      dataIndex: 'status',
      key: 'status',
      render: (status) => <Tag color="green">{status}</Tag>
    }
  ]

  const securityScore = 87
  const getScoreColor = (score) => {
    if (score >= 90) return '#52c41a'
    if (score >= 80) return '#1890ff'
    if (score >= 70) return '#faad14'
    return '#ff4d4f'
  }

  return (
    <div>
      <div style={{ marginBottom: 24 }}>
        <Title level={2} style={{ margin: 0, color: '#1f2937' }}>
          Security Center
        </Title>
        <Paragraph style={{ marginTop: 8, marginBottom: 0, fontSize: '16px', color: '#6b7280' }}>
          Real-time threat monitoring and security analytics. Monitor active threats, view security alerts, 
          analyze attack patterns, and manage your enterprise security posture with advanced threat detection and response capabilities.
        </Paragraph>
      </div>

      {/* Security Status Alert */}
      <Card style={{ 
        marginBottom: 24, 
        background: 'linear-gradient(135deg, #52c41a 0%, #389e0d 100%)', 
        color: 'white',
        border: 'none'
      }}>
        <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
          <div style={{ display: 'flex', alignItems: 'center', gap: 16 }}>
            <SecurityScanOutlined style={{ fontSize: 32, color: 'white' }} />
            <div>
              <Text style={{ color: 'white', fontSize: '18px', fontWeight: 'bold' }}>
                Security Status: All Systems Protected
              </Text>
              <div style={{ color: 'rgba(255,255,255,0.9)', marginTop: 4 }}>
                Active monitoring across {stats?.totalEndpoints || 3} endpoints • Last scan: 2 minutes ago
              </div>
            </div>
          </div>
          <Button 
            type="primary" 
            ghost 
            onClick={refreshData} 
            loading={refreshing}
            style={{ color: 'white', borderColor: 'white' }}
            icon={<ReloadOutlined />}
          >
            Refresh
          </Button>
        </div>
      </Card>

      {/* Security Metrics Dashboard */}
      <Row gutter={[16, 16]} style={{ marginBottom: 24 }}>
        <Col xs={24} sm={6}>
          <Card style={{ background: 'linear-gradient(135deg, #1890ff 0%, #096dd9 100%)', color: 'white', border: 'none' }}>
            <div style={{ display: 'flex', alignItems: 'center', gap: 12 }}>
              <SecurityScanOutlined style={{ fontSize: 32, color: 'white' }} />
              <div>
                <div style={{ fontSize: 24, fontWeight: 'bold', color: 'white' }}>{securityScore}%</div>
                <div style={{ color: 'rgba(255,255,255,0.9)' }}>Security Score</div>
              </div>
            </div>
          </Card>
        </Col>
        <Col xs={24} sm={6}>
          <Card style={{ background: 'linear-gradient(135deg, #ff4d4f 0%, #cf1322 100%)', color: 'white', border: 'none' }}>
            <div style={{ display: 'flex', alignItems: 'center', gap: 12 }}>
              <LockOutlined style={{ fontSize: 32, color: 'white' }} />
              <div>
                <div style={{ fontSize: 24, fontWeight: 'bold', color: 'white' }}>{threatData.length}</div>
                <div style={{ color: 'rgba(255,255,255,0.9)' }}>Threats Blocked Today</div>
              </div>
            </div>
          </Card>
        </Col>
        <Col xs={24} sm={6}>
          <Card style={{ background: 'linear-gradient(135deg, #52c41a 0%, #389e0d 100%)', color: 'white', border: 'none' }}>
            <div style={{ display: 'flex', alignItems: 'center', gap: 12 }}>
              <CheckCircleOutlined style={{ fontSize: 32, color: 'white' }} />
              <div>
                <div style={{ fontSize: 24, fontWeight: 'bold', color: 'white' }}>8</div>
                <div style={{ color: 'rgba(255,255,255,0.9)' }}>Active Protections</div>
              </div>
            </div>
          </Card>
        </Col>
        <Col xs={24} sm={6}>
          <Card style={{ background: 'linear-gradient(135deg, #722ed1 0%, #531dab 100%)', color: 'white', border: 'none' }}>
            <div style={{ display: 'flex', alignItems: 'center', gap: 12 }}>
              <BugOutlined style={{ fontSize: 32, color: 'white' }} />
              <div>
                <div style={{ fontSize: 24, fontWeight: 'bold', color: 'white' }}>{vulnerabilities.length}</div>
                <div style={{ color: 'rgba(255,255,255,0.9)' }}>Vulnerabilities</div>
              </div>
            </div>
          </Card>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        {/* Live Threat Detection */}
        <Col xs={24} lg={16}>
          <Card 
            title={
              <Space>
                <Text strong style={{ fontSize: '16px' }}>Live Threat Detection</Text>
                <Tag color="red" style={{ fontSize: '11px', fontWeight: 'bold' }}>LIVE</Tag>
              </Space>
            }
            extra={<Button onClick={refreshData} loading={refreshing} icon={<ReloadOutlined />} size="small">Refresh</Button>}
          >
            <Table
              columns={threatColumns}
              dataSource={threatData}
              rowKey="id"
              size="small"
              pagination={{ pageSize: 5 }}
              onRow={(record) => ({
                onClick: () => setSelectedThreat(record),
                style: { cursor: 'pointer' }
              })}
            />
          </Card>
        </Col>

        {/* Security Status & Events Panel */}
        <Col xs={24} lg={8}>
          <Card title="Protection Status" style={{ marginBottom: 16 }}>
            <div style={{ marginBottom: 20 }}>
              <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 8 }}>
                <Text strong>Overall Security Score</Text>
                <Text strong style={{ color: getScoreColor(securityScore) }}>{securityScore}%</Text>
              </div>
              <Progress
                percent={securityScore}
                strokeColor={getScoreColor(securityScore)}
                showInfo={false}
              />
            </div>
            
            <Space direction="vertical" style={{ width: '100%', gap: 12 }}>
              <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                <Space>
                  <CheckCircleOutlined style={{ color: '#52c41a' }} />
                  <Text>DDoS Protection</Text>
                </Space>
                <Tag color="green">ACTIVE</Tag>
              </div>
              <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                <Space>
                  <CheckCircleOutlined style={{ color: '#52c41a' }} />
                  <Text>Malware Detection</Text>
                </Space>
                <Tag color="green">ACTIVE</Tag>
              </div>
              <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                <Space>
                  <CheckCircleOutlined style={{ color: '#52c41a' }} />
                  <Text>SQL Injection Filter</Text>
                </Space>
                <Tag color="green">ACTIVE</Tag>
              </div>
              <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                <Space>
                  <CheckCircleOutlined style={{ color: '#52c41a' }} />
                  <Text>Real-time Scanning</Text>
                </Space>
                <Tag color="green">ACTIVE</Tag>
              </div>
            </Space>
          </Card>

          <Card title="Recent Security Events">
            <Space direction="vertical" style={{ width: '100%' }}>
              {securityEvents.map((event, index) => (
                <div key={index}>
                  <div style={{ display: 'flex', alignItems: 'flex-start', gap: 12 }}>
                    <div style={{
                      width: 32,
                      height: 32,
                      borderRadius: '50%',
                      background: event.severity === 'critical' ? '#ff4d4f' : event.severity === 'warning' ? '#faad14' : event.severity === 'success' ? '#52c41a' : '#1890ff',
                      display: 'flex',
                      alignItems: 'center',
                      justifyContent: 'center'
                    }}>
                      <AlertOutlined style={{ color: 'white', fontSize: '14px' }} />
                    </div>
                    <div style={{ flex: 1 }}>
                      <Text strong style={{ fontSize: '13px' }}>{event.title}</Text>
                      <div style={{ color: '#666', fontSize: '12px', marginTop: 2 }}>
                        {event.description}
                      </div>
                      <div style={{ color: '#999', fontSize: '11px', marginTop: 4 }}>
                        {event.time}
                      </div>
                    </div>
                  </div>
                  {index < securityEvents.length - 1 && <Divider style={{ margin: '12px 0' }} />}
                </div>
              ))}
            </Space>
          </Card>
        </Col>
      </Row>
    </div>
  )
}
