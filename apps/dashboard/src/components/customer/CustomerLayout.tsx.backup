'use client'
import React, { useState } from 'react'
import { Layout, Menu, Avatar, Dropdown, Typography, Space, Button, Tag } from 'antd'
import {
  BarChartOutlined, KeyOutlined, SecurityScanOutlined, LockOutlined,
  RobotOutlined, FileTextOutlined, MonitorOutlined, BugOutlined,
  GlobalOutlined, CodeOutlined, BellOutlined, ThunderboltOutlined,
  LineChartOutlined, CreditCardOutlined, ExportOutlined, SettingOutlined,
  UserOutlined, LogoutOutlined, DashboardOutlined, TeamOutlined, MenuFoldOutlined, MenuUnfoldOutlined
} from '@ant-design/icons'

const { Header, Sider, Content } = Layout
const { Title, Text } = Typography

export default function CustomerLayout({ user, company, currentPage, onMenuClick, onLogout, menuItems, loading, children }) {
  const [collapsed, setCollapsed] = useState(false)

  const iconMap = {
    DashboardOutlined, KeyOutlined, SecurityScanOutlined, LockOutlined,
    RobotOutlined, FileTextOutlined, MonitorOutlined, BugOutlined,
    GlobalOutlined, CodeOutlined, BellOutlined, ThunderboltOutlined,
    LineChartOutlined, CreditCardOutlined, ExportOutlined, SettingOutlined
  }

  const menuItemsFormatted = menuItems.map(item => ({
    key: item.key,
    icon: iconMap[item.icon] || <DashboardOutlined />,
    label: item.label,
    style: {
      margin: '4px 8px',
      borderRadius: '12px',
      height: '48px',
      lineHeight: '48px',
      color: currentPage === item.key ? '#fff' : '#64748b',
      background: currentPage === item.key ? 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)' : 'transparent',
      fontWeight: currentPage === item.key ? '600' : '500',
      boxShadow: currentPage === item.key ? '0 4px 12px rgba(102, 126, 234, 0.3)' : 'none',
      transition: 'all 0.3s ease'
    }
  }))

  const userMenu = {
    items: [
      { key: 'profile', label: 'Profile', icon: <UserOutlined /> },
      { key: 'settings', label: 'Settings', icon: <SettingOutlined /> },
      { type: 'divider' },
      { key: 'logout', label: 'Logout', icon: <LogoutOutlined />, onClick: onLogout }
    ]
  }

  return (
    <Layout style={{ 
      minHeight: '100vh',
      background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)'
    }}>
      <Sider
        trigger={null}
        collapsible
        collapsed={collapsed}
        style={{
          background: 'rgba(255, 255, 255, 0.95)',
          backdropFilter: 'blur(10px)',
          borderRight: '1px solid rgba(255, 255, 255, 0.2)',
          boxShadow: '2px 0 20px rgba(0, 0, 0, 0.1)'
        }}
        width={280}
      >
        <div style={{
          padding: collapsed ? '20px 12px' : '24px 24px',
          borderBottom: '1px solid rgba(0, 0, 0, 0.06)',
          textAlign: 'center',
          background: 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
          color: 'white'
        }}>
          <Title level={collapsed ? 5 : 3} style={{ 
            margin: 0, 
            color: '#fff',
            fontWeight: '700',
            letterSpacing: '-0.5px'
          }}>
            {collapsed ? 'GA' : 'GoverAPI'}
          </Title>
          {!collapsed && (
            <Text style={{ 
              fontSize: '13px', 
              color: 'rgba(255, 255, 255, 0.8)',
              fontWeight: '500'
            }}>
              Enterprise Security Platform
            </Text>
          )}
        </div>
        
        <Menu
          mode="inline"
          selectedKeys={[currentPage]}
          items={menuItemsFormatted}
          onClick={({ key }) => onMenuClick(key)}
          style={{
            border: 'none',
            background: 'transparent',
            padding: '16px 0',
            height: 'calc(100% - 100px)',
            overflow: 'auto'
          }}
        />
      </Sider>
      
      <Layout>
        <Header style={{
          padding: '0 32px',
          background: 'rgba(255, 255, 255, 0.95)',
          backdropFilter: 'blur(10px)',
          borderBottom: '1px solid rgba(0, 0, 0, 0.06)',
          display: 'flex',
          justifyContent: 'space-between',
          alignItems: 'center',
          boxShadow: '0 2px 20px rgba(0, 0, 0, 0.08)'
        }}>
          <Button
            type="text"
            icon={collapsed ? <MenuUnfoldOutlined /> : <MenuFoldOutlined />}
            onClick={() => setCollapsed(!collapsed)}
            style={{ 
              fontSize: '18px', 
              width: 48, 
              height: 48,
              borderRadius: '12px',
              background: 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
              color: 'white',
              border: 'none',
              boxShadow: '0 4px 12px rgba(102, 126, 234, 0.3)'
            }}
          />
          
          <Space size="large">
            {company && (
              <Space>
                <Tag style={{
                  background: 'linear-gradient(135deg, #11998e 0%, #38ef7d 100%)',
                  color: 'white',
                  border: 'none',
                  borderRadius: '20px',
                  padding: '4px 16px',
                  fontWeight: '600',
                  fontSize: '12px'
                }}>
                  {company.subscription_plan?.toUpperCase() || 'PROFESSIONAL'} PLAN
                </Tag>
              </Space>
            )}
            <Dropdown menu={userMenu} placement="bottomRight">
              <Space style={{ 
                cursor: 'pointer',
                background: 'rgba(102, 126, 234, 0.1)',
                padding: '8px 16px',
                borderRadius: '24px',
                transition: 'all 0.3s ease'
              }}>
                <Avatar 
                  style={{
                    background: 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)'
                  }}
                  icon={<UserOutlined />} 
                />
                <Text style={{ fontWeight: '600', color: '#1e293b' }}>
                  {user?.firstName || 'Demo User'}
                </Text>
              </Space>
            </Dropdown>
          </Space>
        </Header>
        
        <Content style={{
          margin: '24px',
          padding: '32px',
          background: 'rgba(255, 255, 255, 0.8)',
          backdropFilter: 'blur(10px)',
          borderRadius: '24px',
          minHeight: 280,
          overflow: 'auto',
          boxShadow: '0 8px 40px rgba(0, 0, 0, 0.12)',
          border: '1px solid rgba(255, 255, 255, 0.2)'
        }}>
          {loading ? (
            <div style={{ 
              textAlign: 'center', 
              padding: '80px',
              background: 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
              borderRadius: '16px',
              color: 'white'
            }}>
              <div style={{ fontSize: '18px', fontWeight: '600' }}>Loading Security Dashboard...</div>
            </div>
          ) : (
            children
          )}
        </Content>
      </Layout>
    </Layout>
  )
}
