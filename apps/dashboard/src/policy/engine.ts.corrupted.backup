/**
 * Policy Engine
 * Real-time policy evaluation, rule matching, decision caching
 */

import { 
  TenantId, 
  PolicyId, 
  RuleId,
  EndpointId,
  Policy,
  PolicyRule,
  PolicyEvaluationContext,
  PolicyDecision,
  PolicyAction,
  PolicyCondition,
  RiskLevel,
  Millis,
  JsonValue,
  SystemError
} from '../core/types';
import { database } from '../infrastructure/database';
// import { logger } from "../infrastructure/monitoring"; // Disabled
import { environmentConfig } from '../config/environment';

export interface CachedDecision {
  readonly decision: PolicyDecision;
  readonly cachedAt: Millis;
  readonly ttl: Millis;
}

export interface PolicyExecutionResult {
  readonly decision: PolicyDecision;
  readonly executionTime: number;
  readonly rulesEvaluated: number;
  readonly cacheHit: boolean;
}

export interface RuleEvaluationResult {
  readonly ruleId: RuleId;
  readonly matched: boolean;
  readonly action: PolicyAction;
  readonly reason: string;
  readonly executionTime: number;
}

export interface PolicyEngineStats {
  readonly evaluationsPerSecond: number;
  readonly cacheHitRate: number;
  readonly averageExecutionTime: number;
  readonly activeRules: number;
  readonly policyViolations: number;
}

class PolicyExecutionEngine {
  private static instance: PolicyExecutionEngine;
  private decisionCache = new Map<string, CachedDecision>();
  private activePolicies = new Map<TenantId, Map<PolicyId, Policy>>();
  private evaluationStats = {
    totalEvaluations: 0,
    cacheHits: 0,
    totalExecutionTime: 0,
    violations: 0
  };

  private constructor() {
    this.startCacheCleanup();
  }

  static getInstance(): PolicyExecutionEngine {
    if (!PolicyExecutionEngine.instance) {
      PolicyExecutionEngine.instance = new PolicyExecutionEngine();
    }
    return PolicyExecutionEngine.instance;
  }

  async evaluatePolicy(
    tenantId: TenantId,
    context: PolicyEvaluationContext
  ): Promise<PolicyExecutionResult> {
    const startTime = Date.now() as Millis;

    try {
Generate cache key
      const cacheKey = this.generateCacheKey(tenantId, context);
      
Check cache first
      const cached = this.getCachedDecision(cacheKey);
      if (cached) {
        this.evaluationStats.totalEvaluations++;
        this.evaluationStats.cacheHits++;
        
        // recordPolicyMetrics(
          tenantId,
          'cached' as PolicyId,
          cached.action,
          'cached',
          Date.now() as Millis - startTime
        ; // recordPolicyMetrics call removed

        return {
          decision: cached,
          executionTime: Date.now() as Millis - startTime,
          rulesEvaluated: 0,
          cacheHit: true
        };
      }

Load active policies for tenant
      await this.loadActivePolicies(tenantId);
      const policies = this.activePolicies.get(tenantId) || new Map();

      if (policies.size === 0) {
        const defaultDecision = this.createDefaultDecision();
        this.cacheDecision(cacheKey, defaultDecision);
        
        return {
          decision: defaultDecision,
          executionTime: Date.now() as Millis - startTime,
          rulesEvaluated: 0,
          cacheHit: false
        };
      }

Evaluate all applicable policies
      const results: RuleEvaluationResult[] = [];
      let finalDecision = this.createDefaultDecision();
      let highestPriorityAction: PolicyAction = 'ALLOW';
      let highestPriority = -1;

      for (const [policyId, policy] of Array.from(policies)) {
        const policyResults = await this.evaluatePolicyRules(
          tenantId,
          policy,
          context
        );
        
        results.push(...policyResults);

        // Determine the action based on rule priority
        for (const result of policyResults) {
          if (result.matched) {
            const rule = policy.rules.find((r: any) => r.id === result.ruleId);
            if (rule && rule.priority > highestPriority) {
              highestPriority = rule.priority;
              highestPriorityAction = result.action;
              
              finalDecision = {
                allowed: result.action === 'ALLOW',
                action: result.action,
                appliedRules: [result.ruleId],
                reason: result.reason,
                riskScore: this.calculateRiskScore(result.action, rule.severity),
                requiresAudit: this.requiresAudit(result.action, rule.severity),
                throttleDelay: result.action === 'THROTTLE' ? this.calculateThrottleDelay(rule) : undefined,
                metadata: {
                  policyId,
                  ruleId: result.ruleId,
                  evaluatedAt: Date.now() as Millis,
                  executionTime: Date.now() as Millis - startTime
                }
              };
            }
          }
        }
      }

Apply policy combination logic for multiple matches
      if (results.filter(r => r.matched).length > 1) {
        finalDecision = this.combinePolicyDecisions(results, policies);
      }

Cache the decision
      this.cacheDecision(cacheKey, finalDecision);

Update statistics
      this.evaluationStats.totalEvaluations++;
      this.evaluationStats.totalExecutionTime += Date.now() as Millis - startTime;
      
      if (!finalDecision.allowed) {
        this.evaluationStats.violations++;
      }

Record metrics
recordPolicyMetrics(
        tenantId,
        'combined' as PolicyId,
        finalDecision.action,
        results.filter(r => r.matched).map(r => r.ruleId).join(','),
        Date.now() as Millis - startTime,
        !finalDecision.allowed
      ; // recordPolicyMetrics call removed

      return {
        decision: finalDecision,
        executionTime: Date.now() as Millis - startTime,
        rulesEvaluated: results.length,
        cacheHit: false
      };

    } catch (error) {
      console.error('Policy evaluation failed', (error as Error), {
        tenant_id: tenantId,
        context: {
          endpoint_id: context.endpointId,
          method: context.requestMethod,
          source_ip: context.sourceIP
        }
      });

Return safe default on error
      const errorDecision: PolicyDecision = {
        allowed: false,
        action: 'DENY',
        appliedRules: [],
        reason: 'Policy evaluation error',
        riskScore: 100,
        requiresAudit: true,
        metadata: { error: (error as Error).message }
      };

      return {
        decision: errorDecision,
        executionTime: Date.now() as Millis - startTime,
        rulesEvaluated: 0,
        cacheHit: false
      };
    }
  }

  private async evaluatePolicyRules(
    tenantId: TenantId,
    policy: Policy,
    context: PolicyEvaluationContext
  ): Promise<RuleEvaluationResult[]> {
    const results: RuleEvaluationResult[] = [];

    // Sort rules by priority (highest first)
    const sortedRules = [...policy.rules].sort((a, b) => b.priority - a.priority);

    for (const rule of sortedRules) {
      if (!rule.enabled) continue;

      const ruleStartTime = Date.now() as Millis;
      
      try {
        const matched = await this.evaluateRule(rule, context);
        
        results.push({
          ruleId: rule.id,
          matched,
          action: rule.action,
          reason: matched ? `Rule '${rule.name}' matched` : `Rule '${rule.name}' did not match`,
          executionTime: Date.now() as Millis - ruleStartTime
        });

        // Early termination for DENY rules (security first)
        if (matched && rule.action === 'DENY') {
          console.info('Policy DENY rule matched, terminating evaluation', {
            tenant_id: tenantId,
            policy_id: policy.id,
            rule_id: rule.id,
            context: {
              endpoint_id: context.endpointId,
              source_ip: context.sourceIP
            }
          });
          break;
        }

      } catch (error) {
        console.error('Rule evaluation failed', (error as Error), {
          tenant_id: tenantId,
          policy_id: policy.id,
          rule_id: rule.id
        });

        // Fail safe - treat as non-match
        results.push({
          ruleId: rule.id,
          matched: false,
          action: rule.action,
          reason: `Rule evaluation error: ${(error as Error).message}`,
          executionTime: Date.now() as Millis - ruleStartTime
        });
      }
    }

    return results;
  }

  private async evaluateRule(rule: PolicyRule, context: PolicyEvaluationContext): Promise<boolean> {
    switch (rule.condition) {
      case 'IP_WHITELIST':
        return this.evaluateIPWhitelist(rule.conditionValue, context.sourceIP);
        
      case 'DATA_CLASSIFICATION':
        return this.evaluateDataClassification(rule.conditionValue, context);
        
      case 'REQUEST_RATE':
        return await this.evaluateRequestRate(rule.conditionValue, context);
        
      case 'TIME_WINDOW':
        return this.evaluateTimeWindow(rule.conditionValue);
        
      case 'AUTH_REQUIRED':
        return this.evaluateAuthRequired(rule.conditionValue, context);
        
      case 'RISK_THRESHOLD':
        return await this.evaluateRiskThreshold(rule.conditionValue, context);
        
      default:
        console.warn('Unknown policy condition', { condition: rule.condition });
        return false;
    }
  }

  private evaluateIPWhitelist(conditionValue: JsonValue, sourceIP: string): boolean {
    if (typeof conditionValue !== 'object' || !conditionValue || Array.isArray(conditionValue)) {
      return false;
    }

    const config = conditionValue as { allowedIPs?: string[]; deniedIPs?: string[] };
    
    // Check denied IPs first
    if (config.deniedIPs?.includes(sourceIP)) {
      return false;
    }

    // If allowedIPs is specified, IP must be in the list
    if (config.allowedIPs && config.allowedIPs.length > 0) {
      return config.allowedIPs.includes(sourceIP) || 
             this.isIPInRange(sourceIP, config.allowedIPs);
    }

    return true; // Default allow if no specific rules
  }

  private isIPInRange(ip: string, ranges: string[]): boolean {
    for (const range of ranges) {
      if (range.includes('/')) {
        // CIDR notation
        if (this.isIPInCIDR(ip, range)) {
          return true;
        }
      } else if (range.includes('-')) {
        // IP range notation
        if (this.isIPInIPRange(ip, range)) {
          return true;
        }
      }
    }
    return false;
  }

  private isIPInCIDR(ip: string, cidr: string): boolean {
    // Simplified CIDR check (production would use proper IP library)
    const [network, prefixLength] = cidr.split('/');
    const prefix = parseInt(prefixLength);
    
    // Convert IPs to integers for comparison
    const ipInt = this.ipToInt(ip);
    const networkInt = this.ipToInt(network);
    const mask = (0xffffffff << (32 - prefix)) & 0xffffffff;
    
    return (ipInt & mask) === (networkInt & mask);
  }

  private isIPInIPRange(ip: string, range: string): boolean {
    const [startIP, endIP] = range.split('-');
    const ipInt = this.ipToInt(ip.trim());
    const startInt = this.ipToInt(startIP.trim());
    const endInt = this.ipToInt(endIP.trim());
    
    return ipInt >= startInt && ipInt <= endInt;
  }

  private ipToInt(ip: string): number {
    return ip.split('.').reduce((acc, octet) => acc * 256 + parseInt(octet), 0);
  }

  private evaluateDataClassification(conditionValue: JsonValue, context: PolicyEvaluationContext): boolean {
    if (typeof conditionValue !== 'object' || !conditionValue || Array.isArray(conditionValue)) {
      return false;
    }

    const config = conditionValue as { 
      allowedClassifications?: string[]; 
      deniedClassifications?: string[] 
    };

    // This would need to be enhanced to get actual data classification of the endpoint
    // For now, we'll use a placeholder implementation
    const endpointClassification = 'INTERNAL'; // Would be fetched from endpoint metadata

    if (config.deniedClassifications?.includes(endpointClassification)) {
      return true; // Rule matches (should be denied)
    }

    if (config.allowedClassifications && config.allowedClassifications.length > 0) {
      return !config.allowedClassifications.includes(endpointClassification);
    }

    return false;
  }

  private async evaluateRequestRate(conditionValue: JsonValue, context: PolicyEvaluationContext): Promise<boolean> {
    if (typeof conditionValue !== 'object' || !conditionValue || Array.isArray(conditionValue)) {
      return false;
    }

    const config = conditionValue as { 
      maxRequests: number; 
      windowMinutes: number; 
      perIP?: boolean;
      perEndpoint?: boolean;
    };

    try {
Get recent request count from database
      const windowStart = Date.now() as Millis - (config.windowMinutes * 60 * 1000);
      
This would query actual usage metrics from database
For now, return false (rate limit not exceeded)
      const recentRequestCount = 0; // Would be: await database.getRequestCount(...)
      
      return recentRequestCount > config.maxRequests;
    } catch (error) {
      console.error('Request rate evaluation failed', (error as Error));
      return false;
    }
  }

  private evaluateTimeWindow(conditionValue: JsonValue): boolean {
    if (typeof conditionValue !== 'object' || !conditionValue || Array.isArray(conditionValue)) {
      return false;
    }

    const config = conditionValue as {
      allowedHours?: number[];
      deniedHours?: number[];
      timezone?: string;
    };

    const now = new Date();
    const currentHour = now.getHours();

    // Check denied hours first
    if (config.deniedHours?.includes(currentHour)) {
      return true; // Rule matches (should be blocked)
    }

    // If allowed hours specified, current hour must be in the list
    if (config.allowedHours && config.allowedHours.length > 0) {
      return !config.allowedHours.includes(currentHour);
    }

    return false;
  }

  private evaluateAuthRequired(conditionValue: JsonValue, context: PolicyEvaluationContext): boolean {
    const required = conditionValue === true;
    const hasAuth = !!context.authContext;
    
    // Rule matches if auth is required but not present
    return required && !hasAuth;
  }

  private async evaluateRiskThreshold(conditionValue: JsonValue, context: PolicyEvaluationContext): Promise<boolean> {
    if (typeof conditionValue !== 'number') {
      return false;
    }

    const threshold = conditionValue as number;
    
    // Calculate current risk score based on context
    const riskScore = this.calculateContextRiskScore(context);
    
    return riskScore > threshold;
  }

  private calculateContextRiskScore(context: PolicyEvaluationContext): number {
    let riskScore = 0;

    // IP-based risk (simplified)
    if (context.sourceIP.startsWith('10.') || 
        context.sourceIP.startsWith('192.168.') || 
        context.sourceIP.startsWith('172.')) {
      riskScore += 10; // Internal network
    } else {
      riskScore += 30; // External network
    }

    // Method-based risk
    const riskMethods = ['POST', 'PUT', 'DELETE', 'PATCH'];
    if (riskMethods.includes(context.requestMethod)) {
      riskScore += 20;
    }

    // Path-based risk
    if (context.requestPath.includes('/admin')) riskScore += 40;
    if (context.requestPath.includes('/api/')) riskScore += 10;
    if (context.requestPath.includes('/delete')) riskScore += 30;

    // Auth context
    if (!context.authContext) {
      riskScore += 25;
    }

    // Time-based risk (outside business hours)
    const hour = new Date().getHours();
    if (hour < 6 || hour > 22) {
      riskScore += 15;
    }

    return Math.min(100, riskScore);
  }

  private combinePolicyDecisions(
    results: RuleEvaluationResult[], 
    policies: Map<PolicyId, Policy>
  ): PolicyDecision {
    const matchedResults = results.filter(r => r.matched);
    
    // Priority order: DENY > REQUIRE_AUTH > THROTTLE > LOG > ALLOW
    const actionPriority = {
      'DENY': 5,
      'REQUIRE_AUTH': 4,
      'THROTTLE': 3,
      'LOG': 2,
      'ALLOW': 1
    };

    // Find highest priority action
    const highestPriorityResult = matchedResults.reduce((highest, current) => {
      return actionPriority[current.action] > actionPriority[highest.action] ? current : highest;
    });

    const appliedRules = matchedResults.map(r => r.ruleId);
    const combinedReasons = matchedResults.map(r => r.reason).join('; ');

    return {
      allowed: highestPriorityResult.action === 'ALLOW' || highestPriorityResult.action === 'LOG',
      action: highestPriorityResult.action,
      appliedRules,
      reason: combinedReasons,
      riskScore: this.calculateCombinedRiskScore(matchedResults, policies),
      requiresAudit: matchedResults.some(r => r.action !== 'ALLOW'),
      throttleDelay: highestPriorityResult.action === 'THROTTLE' ? 1000 as Millis : undefined,
      metadata: {
        rulesMatched: matchedResults.length,
        evaluatedAt: Date.now() as Millis
      }
    };
  }

  private calculateCombinedRiskScore(
    results: RuleEvaluationResult[], 
    policies: Map<PolicyId, Policy>
  ): number {
    let maxRiskScore = 0;

    for (const result of results) {
      for (const [, policy] of Array.from(policies)) {
        const rule = policy.rules.find((r: any) => r.id === result.ruleId);
        if (rule) {
          const ruleRisk = this.calculateRiskScore(result.action, rule.severity);
          maxRiskScore = Math.max(maxRiskScore, ruleRisk);
        }
      }
    }

    return maxRiskScore;
  }

  private calculateRiskScore(action: PolicyAction, severity: RiskLevel): number {
    const baseScores = {
      'ALLOW': 10,
      'LOG': 20,
      'THROTTLE': 40,
      'REQUIRE_AUTH': 60,
      'DENY': 80
    };

    const severityMultipliers = {
      'LOW': 1.0,
      'MEDIUM': 1.25,
      'HIGH': 1.5,
      'CRITICAL': 2.0
    };

    return Math.min(100, baseScores[action] * severityMultipliers[severity]);
  }

  private requiresAudit(action: PolicyAction, severity: RiskLevel): boolean {
    return action !== 'ALLOW' || severity === 'HIGH' || severity === 'CRITICAL';
  }

  private calculateThrottleDelay(rule: PolicyRule): Millis {
    // Extract throttle configuration from rule metadata
    const metadata = rule.conditionValue as any;
    const delayMs = metadata?.throttleDelayMs || 1000;
    
    return Math.max(100, Math.min(30000, delayMs)) as Millis; // 100ms to 30s
  }

  private createDefaultDecision(): PolicyDecision {
    const config = environmentConfig.getConfig();
    const defaultAction = config.policy.defaultAction;

    return {
      allowed: defaultAction === 'ALLOW',
      action: defaultAction as PolicyAction,
      appliedRules: [],
      reason: `No policies matched, using default action: ${defaultAction}`,
      riskScore: defaultAction === 'ALLOW' ? 10 : 50,
      requiresAudit: defaultAction === 'DENY',
      metadata: { defaultPolicy: true }
    };
  }

  private async loadActivePolicies(tenantId: TenantId): Promise<void> {
    try {
Check if policies are already cached and recent
      const cached = this.activePolicies.get(tenantId);
      if (cached && cached.size > 0) {
        return; // Use cached policies
      }

Load active policies from database
      const { endpoints: searchResults } = await database.findAPIEndpoints(
        tenantId, 
        { active: true }, 
        { limit: 1000, offset: 0 }
      );

This is a placeholder - actual implementation would query policies table
      const policies = new Map<PolicyId, Policy>();
      
For now, create a default policy structure
In production, this would load from the policies table
      console.debug('Loaded active policies', {
        tenant_id: tenantId,
        policy_count: policies.size
      });

      this.activePolicies.set(tenantId, policies);
    } catch (error) {
      console.error('Failed to load active policies', (error as Error), { tenant_id: tenantId });
      this.activePolicies.set(tenantId, new Map());
    }
  }

  private generateCacheKey(tenantId: TenantId, context: PolicyEvaluationContext): string {
    // Create cache key from relevant context fields
    return `${tenantId}:${context.endpointId}:${context.requestMethod}:${context.sourceIP}:${!!context.authContext}`;
  }

  private getCachedDecision(cacheKey: string): PolicyDecision | null {
    const cached = this.decisionCache.get(cacheKey);
    if (!cached) return null;

    const now = Date.now() as Millis;
    if (now > cached.cachedAt + cached.ttl) {
      this.decisionCache.delete(cacheKey);
      return null;
    }

    return cached.decision;
  }

  private cacheDecision(cacheKey: string, decision: PolicyDecision): void {
    const config = environmentConfig.getConfig();
    const ttl = config.policy.cacheExpirationMs;

    const cached: CachedDecision = {
      decision,
      cachedAt: Date.now() as Millis as Millis,
      ttl: ttl as Millis
    };

    this.decisionCache.set(cacheKey, cached);

    // Limit cache size
    if (this.decisionCache.size > 10000) {
      const oldestKey = this.decisionCache.keys().next().value;
      if (oldestKey) this.decisionCache.delete(oldestKey);
    }
  }

  private startCacheCleanup(): void {
    setInterval(() => {
      const now = Date.now() as Millis;
      const expiredKeys: string[] = [];

      for (const [key, cached] of Array.from(this.decisionCache.entries())) {
        if (now > cached.cachedAt + cached.ttl) {
          expiredKeys.push(key);
        }
      }

      for (const key of expiredKeys) {
        this.decisionCache.delete(key);
      }

      if (expiredKeys.length > 0) {
        console.debug('Cleaned up policy cache', { 
          expired_entries: expiredKeys.length,
          cache_size: this.decisionCache.size 
        });
      }
    }, 60000); // Cleanup every minute
  }

  // Policy management methods
  async reloadPolicies(tenantId: TenantId): Promise<void> {
    this.activePolicies.delete(tenantId);
    await this.loadActivePolicies(tenantId);
    
    // Clear cache for this tenant
    for (const [key] of Array.from(this.decisionCache.entries())) {
      if (key.startsWith(tenantId)) {
        this.decisionCache.delete(key);
      }
    }

    console.info('Policies reloaded', { tenant_id: tenantId });
  }

  getEngineStats(): PolicyEngineStats {
    const now = Date.now() as Millis;
    const runtimeSeconds = (now - (this.evaluationStats.totalEvaluations > 0 ? 
      now - this.evaluationStats.totalExecutionTime : now)) / 1000;

    return {
      evaluationsPerSecond: this.evaluationStats.totalEvaluations / Math.max(1, runtimeSeconds),
      cacheHitRate: this.evaluationStats.totalEvaluations > 0 ? 
        this.evaluationStats.cacheHits / this.evaluationStats.totalEvaluations : 0,
      averageExecutionTime: this.evaluationStats.totalEvaluations > 0 ?
        this.evaluationStats.totalExecutionTime / this.evaluationStats.totalEvaluations : 0,
      activeRules: Array.from(this.activePolicies.values())
        .reduce((sum, policies) => sum + Array.from(policies.values())
          .reduce((ruleSum, policy) => ruleSum + policy.rules.filter(r => r.enabled).length, 0), 0),
      policyViolations: this.evaluationStats.violations
    };
  }

  clearCache(): void {
    this.decisionCache.clear();
    this.activePolicies.clear();
    console.info('Policy engine cache cleared');
  }

  // Batch evaluation for performance testing
  async evaluateBatch(
    tenantId: TenantId,
    contexts: PolicyEvaluationContext[]
  ): Promise<PolicyExecutionResult[]> {
    const results: PolicyExecutionResult[] = [];
    const batchSize = 50;

    for (let i = 0; i < contexts.length; i += batchSize) {
      const batch = contexts.slice(i, i + batchSize);
      
      const batchPromises = batch.map(context => 
        this.evaluatePolicy(tenantId, context)
      );

      const batchResults = await Promise.allSettled(batchPromises);
      
      for (const result of batchResults) {
        if (result.status === 'fulfilled') {
          results.push(result.value);
        } else {
          console.error('Batch policy evaluation failed', result.reason);
          results.push({
            decision: this.createDefaultDecision(),
            executionTime: 0,
            rulesEvaluated: 0,
            cacheHit: false
          });
        }
      }
    }

    return results;
  }
}

// Rule condition validators
export class PolicyConditionValidator {
  static validateIPWhitelist(value: JsonValue): boolean {
    if (typeof value !== 'object' || !value || Array.isArray(value)) {
      return false;
    }

    const config = value as any;
    
    if (config.allowedIPs && !Array.isArray(config.allowedIPs)) {
      return false;
    }
    
    if (config.deniedIPs && !Array.isArray(config.deniedIPs)) {
      return false;
    }

    return true;
  }

  static validateRequestRate(value: JsonValue): boolean {
    if (typeof value !== 'object' || !value || Array.isArray(value)) {
      return false;
    }

    const config = value as any;
    
    return typeof config.maxRequests === 'number' && 
           typeof config.windowMinutes === 'number' &&
           config.maxRequests > 0 && 
           config.windowMinutes > 0;
  }

  static validateTimeWindow(value: JsonValue): boolean {
    if (typeof value !== 'object' || !value || Array.isArray(value)) {
      return false;
    }

    const config = value as any;
    
    if (config.allowedHours && (!Array.isArray(config.allowedHours) || 
        !config.allowedHours.every((h: any) => typeof h === 'number' && h >= 0 && h <= 23))) {
      return false;
    }

    if (config.deniedHours && (!Array.isArray(config.deniedHours) || 
        !config.deniedHours.every((h: any) => typeof h === 'number' && h >= 0 && h <= 23))) {
      return false;
    }

    return true;
  }

  static validateRiskThreshold(value: JsonValue): boolean {
    return typeof value === 'number' && value >= 0 && value <= 100;
  }
}

// Export main components
export const policyExecutionEngine = PolicyExecutionEngine.getInstance();

// Main policy evaluation functions
export async function evaluatePolicy(
  tenantId: TenantId,
  context: PolicyEvaluationContext
): Promise<PolicyExecutionResult> {
  return policyExecutionEngine.evaluatePolicy(tenantId, context);
}

export async function reloadTenantPolicies(tenantId: TenantId): Promise<void> {
  return policyExecutionEngine.reloadPolicies(tenantId);
}

export function getPolicyEngineStats(): PolicyEngineStats {
  return policyExecutionEngine.getEngineStats();
}

export function clearPolicyCache(): void {
  policyExecutionEngine.clearCache();
}

// Policy testing utilities
export async function testPolicyRule(
  rule: PolicyRule,
  testCases: Array<{
    context: PolicyEvaluationContext;
    expectedMatch: boolean;
  }>
): Promise<Array<{ success: boolean; actualMatch: boolean; expectedMatch: boolean }>> {
  const results: Array<{ success: boolean; actualMatch: boolean; expectedMatch: boolean }> = [];
  
  const engine = PolicyExecutionEngine.getInstance();
  
  for (const testCase of testCases) {
    try {
      const actualMatch = await (engine as any).evaluateRule(rule, testCase.context);
      results.push({
        success: actualMatch === testCase.expectedMatch,
        actualMatch,
        expectedMatch: testCase.expectedMatch
      });
    } catch (error) {
      results.push({
        success: false,
        actualMatch: false,
        expectedMatch: testCase.expectedMatch
      });
    }
  }

  return results;
}
