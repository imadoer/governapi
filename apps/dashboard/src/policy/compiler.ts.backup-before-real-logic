/**
 * Policy Compiler
 * YAML-to-executable policy compilation, validation, versioning
 */

import * as yaml from 'js-yaml';
import { 
  TenantId, 
  PolicyId, 
  RuleId,
  Policy,
  PolicyRule,
  PolicyAction,
  PolicyCondition,
  RiskLevel,
  JsonValue,
  validatePolicyRule
} from '../core/types';
import { database } from '../infrastructure/database';
import { logger } from '../infrastructure/monitoring';
import { PolicyConditionValidator } from './engine';

export interface PolicyDefinition {
  readonly name: string;
  readonly description: string;
  readonly version: string;
  readonly rules: readonly RuleDefinition[];
  readonly metadata?: JsonValue;
}

export interface RuleDefinition {
  readonly name: string;
  readonly description?: string;
  readonly condition: PolicyCondition;
  readonly conditionValue: JsonValue;
  readonly action: PolicyAction;
  readonly severity: RiskLevel;
  readonly priority?: number;
  readonly enabled?: boolean;
  readonly tags?: readonly string[];
}

export interface CompilationResult {
  readonly success: boolean;
  readonly policy?: Policy;
  readonly errors: readonly CompilationError[];
  readonly warnings: readonly string[];
  readonly compilationTime: number;
}

export interface CompilationError {
  readonly type: 'SYNTAX' | 'VALIDATION' | 'LOGIC' | 'DEPENDENCY';
  readonly message: string;
  readonly line?: number;
  readonly column?: number;
  readonly ruleName?: string;
}

export interface PolicyTemplate {
  readonly name: string;
  readonly description: string;
  readonly category: string;
  readonly template: PolicyDefinition;
  readonly parameters: readonly TemplateParameter[];
}

export interface TemplateParameter {
  readonly name: string;
  readonly type: 'string' | 'number' | 'boolean' | 'array';
  readonly required: boolean;
  readonly defaultValue?: any;
  readonly description?: string;
  readonly validation?: JsonValue;
}

class PolicyCompiler {
  private static instance: PolicyCompiler;
  private templates = new Map<string, PolicyTemplate>();

  private constructor() {
    this.initializeBuiltinTemplates();
  }

  static getInstance(): PolicyCompiler {
    if (!PolicyCompiler.instance) {
      PolicyCompiler.instance = new PolicyCompiler();
    }
    return PolicyCompiler.instance;
  }

  async compileFromYAML(
    tenantId: TenantId,
    yamlContent: string,
    policyId?: PolicyId
  ): Promise<CompilationResult> {
    const startTime = Date.now();
    const errors: CompilationError[] = [];
    const warnings: string[] = [];

    try {
      logger.info('Starting policy compilation', { 
        tenant_id: tenantId, 
        policy_id: policyId 
      });

      // Parse YAML
      let policyDef: PolicyDefinition;
      try {
        policyDef = yaml.load(yamlContent) as PolicyDefinition;
      } catch (yamlError) {
        errors.push({
          type: 'SYNTAX',
          message: `YAML parsing failed: ${yamlError.message}`,
          line: this.extractLineNumber(yamlError.message),
          column: this.extractColumnNumber(yamlError.message)
        });
        
        return {
          success: false,
          errors,
          warnings,
          compilationTime: Date.now() - startTime
        };
      }

      // Validate policy definition structure
      const structureErrors = this.validatePolicyStructure(policyDef);
      errors.push(...structureErrors);

      if (errors.length > 0) {
        return {
          success: false,
          errors,
          warnings,
          compilationTime: Date.now() - startTime
        };
      }

      // Compile to executable policy
      const policy = await this.compilePolicyDefinition(tenantId, policyDef, policyId);

      // Validate compiled policy
      const validationErrors = await this.validateCompiledPolicy(policy);
      errors.push(...validationErrors);

      // Generate warnings for potential issues
      const policyWarnings = this.generateWarnings(policyDef);
      warnings.push(...policyWarnings);

      const success = errors.length === 0;
      
      logger.info('Policy compilation completed', {
        tenant_id: tenantId,
        policy_id: policy.id,
        success,
        errors: errors.length,
        warnings: warnings.length,
        compilation_time_ms: Date.now() - startTime
      });

      return {
        success,
        policy: success ? policy : undefined,
        errors,
        warnings,
        compilationTime: Date.now() - startTime
      };

    } catch (error) {
      logger.error('Policy compilation failed', error, { 
        tenant_id: tenantId,
        policy_id: policyId 
      });

      errors.push({
        type: 'LOGIC',
        message: `Compilation failed: ${error.message}`
      });

      return {
        success: false,
        errors,
        warnings,
        compilationTime: Date.now() - startTime
      };
    }
  }

  async compileFromTemplate(
    tenantId: TenantId,
    templateName: string,
    parameters: Record<string, any>,
    policyId?: PolicyId
  ): Promise<CompilationResult> {
    try {
      const template = this.templates.get(templateName);
      if (!template) {
        return {
          success: false,
          errors: [{
            type: 'VALIDATION',
            message: `Template '${templateName}' not found`
          }],
          warnings: [],
          compilationTime: 0
        };
      }

      // Validate parameters
      const paramErrors = this.validateTemplateParameters(template, parameters);
      if (paramErrors.length > 0) {
        return {
          success: false,
          errors: paramErrors,
          warnings: [],
          compilationTime: 0
        };
      }

      // Substitute parameters in template
      const instantiatedPolicy = this.instantiateTemplate(template, parameters);

      // Convert to YAML and compile
      const yamlContent = yaml.dump(instantiatedPolicy);
      return this.compileFromYAML(tenantId, yamlContent, policyId);

    } catch (error) {
      logger.error('Template-based compilation failed', error, {
        tenant_id: tenantId,
        template_name: templateName
      });

      return {
        success: false,
        errors: [{
          type: 'LOGIC',
          message: `Template compilation failed: ${error.message}`
        }],
        warnings: [],
        compilationTime: 0
      };
    }
  }

  private validatePolicyStructure(policyDef: any): CompilationError[] {
    const errors: CompilationError[] = [];

    // Validate required fields
    if (!policyDef.name || typeof policyDef.name !== 'string') {
      errors.push({
        type: 'VALIDATION',
        message: 'Policy name is required and must be a string'
      });
    }

    if (!policyDef.version || typeof policyDef.version !== 'string') {
      errors.push({
        type: 'VALIDATION',
        message: 'Policy version is required and must be a string'
      });
    }

    if (!policyDef.rules || !Array.isArray(policyDef.rules)) {
      errors.push({
        type: 'VALIDATION',
        message: 'Policy rules are required and must be an array'
      });
      return errors;
    }

    if (policyDef.rules.length === 0) {
      errors.push({
        type: 'VALIDATION',
        message: 'Policy must contain at least one rule'
      });
    }

    // Validate each rule
    policyDef.rules.forEach((rule: any, index: number) => {
      const ruleErrors = this.validateRuleDefinition(rule, index);
      errors.push(...ruleErrors);
    });

    return errors;
  }

  private validateRuleDefinition(rule: any, index: number): CompilationError[] {
    const errors: CompilationError[] = [];
    const rulePrefix = `Rule ${index + 1} (${rule.name || 'unnamed'})`;

    // Required fields
    if (!rule.name || typeof rule.name !== 'string') {
      errors.push({
        type: 'VALIDATION',
        message: `${rulePrefix}: name is required and must be a string`,
        ruleName: rule.name
      });
    }

    if (!rule.condition) {
      errors.push({
        type: 'VALIDATION',
        message: `${rulePrefix}: condition is required`,
        ruleName: rule.name
      });
    } else if (!this.isValidCondition(rule.condition)) {
      errors.push({
        type: 'VALIDATION',
        message: `${rulePrefix}: invalid condition '${rule.condition}'`,
        ruleName: rule.name
      });
    }

    if (rule.conditionValue === undefined) {
      errors.push({
        type: 'VALIDATION',
        message: `${rulePrefix}: conditionValue is required`,
        ruleName: rule.name
      });
    } else if (!this.validateConditionValue(rule.condition, rule.conditionValue)) {
      errors.push({
        type: 'VALIDATION',
        message: `${rulePrefix}: invalid conditionValue for condition '${rule.condition}'`,
        ruleName: rule.name
      });
    }

    if (!rule.action) {
      errors.push({
        type: 'VALIDATION',
        message: `${rulePrefix}: action is required`,
        ruleName: rule.name
      });
    } else if (!this.isValidAction(rule.action)) {
      errors.push({
        type: 'VALIDATION',
        message: `${rulePrefix}: invalid action '${rule.action}'`,
        ruleName: rule.name
      });
    }

    if (!rule.severity) {
      errors.push({
        type: 'VALIDATION',
        message: `${rulePrefix}: severity is required`,
        ruleName: rule.name
      });
    } else if (!this.isValidSeverity(rule.severity)) {
      errors.push({
        type: 'VALIDATION',
        message: `${rulePrefix}: invalid severity '${rule.severity}'`,
        ruleName: rule.name
      });
    }

    // Optional fields validation
    if (rule.priority !== undefined && (typeof rule.priority !== 'number' || rule.priority < 0)) {
      errors.push({
        type: 'VALIDATION',
        message: `${rulePrefix}: priority must be a non-negative number`,
        ruleName: rule.name
      });
    }

    if (rule.enabled !== undefined && typeof rule.enabled !== 'boolean') {
      errors.push({
        type: 'VALIDATION',
        message: `${rulePrefix}: enabled must be a boolean`,
        ruleName: rule.name
      });
    }

    return errors;
  }

  private isValidCondition(condition: string): condition is PolicyCondition {
    const validConditions: PolicyCondition[] = [
      'IP_WHITELIST', 'DATA_CLASSIFICATION', 'REQUEST_RATE', 
      'TIME_WINDOW', 'AUTH_REQUIRED', 'RISK_THRESHOLD'
    ];
    return validConditions.includes(condition as PolicyCondition);
  }

  private isValidAction(action: string): action is PolicyAction {
    const validActions: PolicyAction[] = [
      'ALLOW', 'DENY', 'LOG', 'THROTTLE', 'REQUIRE_AUTH'
    ];
    return validActions.includes(action as PolicyAction);
  }

  private isValidSeverity(severity: string): severity is RiskLevel {
    const validSeverities: RiskLevel[] = ['LOW', 'MEDIUM', 'HIGH', 'CRITICAL'];
    return validSeverities.includes(severity as RiskLevel);
  }

  private validateConditionValue(condition: PolicyCondition, value: JsonValue): boolean {
    switch (condition) {
      case 'IP_WHITELIST':
        return PolicyConditionValidator.validateIPWhitelist(value);
      case 'REQUEST_RATE':
        return PolicyConditionValidator.validateRequestRate(value);
      case 'TIME_WINDOW':
        return PolicyConditionValidator.validateTimeWindow(value);
      case 'RISK_THRESHOLD':
        return PolicyConditionValidator.validateRiskThreshold(value);
      case 'AUTH_REQUIRED':
        return typeof value === 'boolean';
      case 'DATA_CLASSIFICATION':
        return typeof value === 'object' && value !== null;
      default:
        return false;
    }
  }

  private async compilePolicyDefinition(
    tenantId: TenantId,
    policyDef: PolicyDefinition,
    policyId?: PolicyId
  ): Promise<Policy> {
    const generatedPolicyId = policyId || 
      `${tenantId}:policy:${policyDef.name.toLowerCase().replace(/\s+/g, '-')}` as PolicyId;

    // Compile rules
    const compiledRules: PolicyRule[] = policyDef.rules.map((ruleDef, index) => {
      const ruleId = `${generatedPolicyId}:rule:${index}` as RuleId;
      
      return {
        id: ruleId,
        policyId: generatedPolicyId,
        tenantId,
        name: ruleDef.name,
        description: ruleDef.description || '',
        condition: ruleDef.condition,
        conditionValue: ruleDef.conditionValue,
        action: ruleDef.action,
        severity: ruleDef.severity,
        enabled: ruleDef.enabled !== undefined ? ruleDef.enabled : true,
        priority: ruleDef.priority !== undefined ? ruleDef.priority : 0,
        createdAt: new Date(),
        createdBy: 'policy:compiler'
      };
    });

    // Create compiled policy
    const compiledPolicy: Policy = {
      id: generatedPolicyId,
      tenantId,
      name: policyDef.name,
      description: policyDef.description || '',
      version: policyDef.version,
      rules: compiledRules,
      active: false, // Policies start inactive until explicitly deployed
      createdAt: new Date(),
      createdBy: 'policy:compiler',
      compiledPolicy: {
        originalDefinition: policyDef,
        compiledAt: Date.now(),
        compiler: 'policy-compiler-v1.0'
      }
    };

    return compiledPolicy;
  }

  private async validateCompiledPolicy(policy: Policy): Promise<CompilationError[]> {
    const errors: CompilationError[] = [];

    try {
      // Validate rule priorities don't conflict
      const priorities = new Map<number, string[]>();
      
      for (const rule of policy.rules) {
        if (!priorities.has(rule.priority)) {
          priorities.set(rule.priority, []);
        }
        priorities.get(rule.priority)!.push(rule.name);
      }

      // Check for conflicting priorities with conflicting actions
      for (const [priority, ruleNames] of priorities) {
        if (ruleNames.length > 1) {
          const rulesAtPriority = policy.rules.filter(r => r.priority === priority);
          const actions = new Set(rulesAtPriority.map(r => r.action));
          
          if (actions.has('ALLOW') && actions.has('DENY')) {
            errors.push({
              type: 'LOGIC',
              message: `Conflicting actions at priority ${priority}: ${ruleNames.join(', ')}`
            });
          }
        }
      }

      // Validate rule conditions using existing validators
      for (const rule of policy.rules) {
        const validationErrors = validatePolicyRule(rule);
        for (const error of validationErrors) {
          errors.push({
            type: 'VALIDATION',
            message: error,
            ruleName: rule.name
          });
        }
      }

      // Check for logical inconsistencies
      const logicErrors = this.validatePolicyLogic(policy);
      errors.push(...logicErrors);

    } catch (error) {
      errors.push({
        type: 'LOGIC',
        message: `Policy validation failed: ${error.message}`
      });
    }

    return errors;
  }

  private validatePolicyLogic(policy: Policy): CompilationError[] {
    const errors: CompilationError[] = [];

    // Check for unreachable rules
    const sortedRules = [...policy.rules].sort((a, b) => b.priority - a.priority);
    
    for (let i = 0; i < sortedRules.length; i++) {
      const currentRule = sortedRules[i];
      
      // If there's a higher priority DENY rule that matches everything,
      // lower priority rules might be unreachable
      for (let j = 0; j < i; j++) {
        const higherRule = sortedRules[j];
        
        if (higherRule.action === 'DENY' && 
            this.ruleCoversRule(higherRule, currentRule)) {
          errors.push({
            type: 'LOGIC',
            message: `Rule '${currentRule.name}' may be unreachable due to higher priority rule '${higherRule.name}'`,
            ruleName: currentRule.name
          });
        }
      }
    }

    // Check for redundant rules
    for (let i = 0; i < policy.rules.length; i++) {
      for (let j = i + 1; j < policy.rules.length; j++) {
        const rule1 = policy.rules[i];
        const rule2 = policy.rules[j];
        
        if (this.rulesAreEquivalent(rule1, rule2)) {
          errors.push({
            type: 'LOGIC',
            message: `Rules '${rule1.name}' and '${rule2.name}' are equivalent`,
            ruleName: rule1.name
          });
        }
      }
    }

    return errors;
  }

  private ruleCoversRule(coveringRule: PolicyRule, coveredRule: PolicyRule): boolean {
    // Simplified logic - in practice this would be more sophisticated
    return coveringRule.condition === coveredRule.condition &&
           coveringRule.priority >= coveredRule.priority &&
           JSON.stringify(coveringRule.conditionValue) === JSON.stringify(coveredRule.conditionValue);
  }

  private rulesAreEquivalent(rule1: PolicyRule, rule2: PolicyRule): boolean {
    return rule1.condition === rule2.condition &&
           rule1.action === rule2.action &&
           rule1.priority === rule2.priority &&
           JSON.stringify(rule1.conditionValue) === JSON.stringify(rule2.conditionValue);
  }

  private generateWarnings(policyDef: PolicyDefinition): string[] {
    const warnings: string[] = [];

    // Check for common issues
    if (policyDef.rules.length > 20) {
      warnings.push('Policy has many rules (>20) which may impact performance');
    }

    // Check for rules without descriptions
    const rulesWithoutDescription = policyDef.rules.filter(r => !r.description);
    if (rulesWithoutDescription.length > 0) {
      warnings.push(`${rulesWithoutDescription.length} rules missing descriptions`);
    }

    // Check for all rules at same priority
    const priorities = policyDef.rules.map(r => r.priority || 0);
    const uniquePriorities = new Set(priorities);
    
    if (uniquePriorities.size === 1 && policyDef.rules.length > 1) {
      warnings.push('All rules have same priority, consider using different priorities for clearer ordering');
    }

    // Check for overly permissive rules
    const allowAllRules = policyDef.rules.filter(r => 
      r.action === 'ALLOW' && r.condition === 'IP_WHITELIST' && 
      JSON.stringify(r.conditionValue).includes('0.0.0.0/0')
    );
    
    if (allowAllRules.length > 0) {
      warnings.push('Found overly permissive ALLOW rules that match all IPs');
    }

    return warnings;
  }

  private extractLineNumber(errorMessage: string): number | undefined {
    const lineMatch = errorMessage.match(/line (\d+)/);
    return lineMatch ? parseInt(lineMatch[1]) : undefined;
  }

  private extractColumnNumber(errorMessage: string): number | undefined {
    const columnMatch = errorMessage.match(/column (\d+)/);
    return columnMatch ? parseInt(columnMatch[1]) : undefined;
  }

