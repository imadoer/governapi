  private validateTemplateParameters(
    template: PolicyTemplate,
    parameters: Record<string, any>
  ): CompilationError[] {
    const errors: CompilationError[] = [];

    // Check required parameters
    for (const param of template.parameters) {
      if (param.required && !(param.name in parameters)) {
        errors.push({
          type: 'VALIDATION',
          message: `Required parameter '${param.name}' is missing`
        });
      }
    }

    // Validate parameter types
    for (const [name, value] of Object.entries(parameters)) {
      const paramDef = template.parameters.find(p => p.name === name);
      if (!paramDef) {
        errors.push({
          type: 'VALIDATION',
          message: `Unknown parameter '${name}'`
        });
        continue;
      }

      if (!this.validateParameterType(value, paramDef.type)) {
        errors.push({
          type: 'VALIDATION',
          message: `Parameter '${name}' must be of type ${paramDef.type}`
        });
      }
    }

    return errors;
  }

  private validateParameterType(value: any, expectedType: string): boolean {
    switch (expectedType) {
      case 'string':
        return typeof value === 'string';
      case 'number':
        return typeof value === 'number';
      case 'boolean':
        return typeof value === 'boolean';
      case 'array':
        return Array.isArray(value);
      default:
        return false;
    }
  }

  private instantiateTemplate(
    template: PolicyTemplate,
    parameters: Record<string, any>
  ): PolicyDefinition {
    // Create parameter map with defaults
    const paramMap = new Map<string, any>();
    
    for (const param of template.parameters) {
      paramMap.set(param.name, parameters[param.name] ?? param.defaultValue);
    }

    // Convert template to JSON, substitute parameters, then parse back
    let templateJson = JSON.stringify(template.template);
    
    for (const [name, value] of paramMap) {
      const placeholder = `{{${name}}}`;
      const replacement = JSON.stringify(value).replace(/^"|"$/g, ''); // Remove quotes for string values
      templateJson = templateJson.replace(new RegExp(placeholder, 'g'), replacement);
    }

    return JSON.parse(templateJson) as PolicyDefinition;
  }

  // Template management methods
  addTemplate(template: PolicyTemplate): void {
    this.templates.set(template.name.toLowerCase().replace(/\s+/g, '-'), template);
    logger.info('Policy template added', { template_name: template.name });
  }

  getTemplate(name: string): PolicyTemplate | undefined {
    return this.templates.get(name);
  }

  listTemplates(): PolicyTemplate[] {
    return Array.from(this.templates.values());
  }

  // Utility methods
  async deployPolicy(tenantId: TenantId, policy: Policy): Promise<void> {
    try {
      // Store compiled policy in database
      await database.createPolicy({
        ...policy,
        active: true,
        deployedAt: Date.now()
      });

      logger.info('Policy deployed', {
        tenant_id: tenantId,
        policy_id: policy.id,
        rule_count: policy.rules.length
      });
    } catch (error) {
      logger.error('Policy deployment failed', error, {
        tenant_id: tenantId,
        policy_id: policy.id
      });
      throw error;
    }
  }

  generateYAMLFromPolicy(policy: Policy): string {
    const policyDef: PolicyDefinition = {
      name: policy.name,
      description: policy.description,
      version: policy.version,
      rules: policy.rules.map(rule => ({
        name: rule.name,
        description: rule.description,
        condition: rule.condition,
        conditionValue: rule.conditionValue,
        action: rule.action,
        severity: rule.severity,
        priority: rule.priority,
        enabled: rule.enabled
      })),
      metadata: policy.compiledPolicy
    };

    return yaml.dump(policyDef, { 
      indent: 2,
      lineWidth: 120,
      noRefs: true 
    });
  }
}

// Export main components
export const policyCompiler = PolicyCompiler.getInstance();

// Main compilation functions
export async function compilePolicy(
  tenantId: TenantId,
  yamlContent: string,
  policyId?: PolicyId
): Promise<CompilationResult> {
  return policyCompiler.compileFromYAML(tenantId, yamlContent, policyId);
}

export async function compilePolicyFromTemplate(
  tenantId: TenantId,
  templateName: string,
  parameters: Record<string, any>,
  policyId?: PolicyId
): Promise<CompilationResult> {
  return policyCompiler.compileFromTemplate(tenantId, templateName, parameters, policyId);
}

export function getPolicyTemplates(): PolicyTemplate[] {
  return policyCompiler.listTemplates();
}

export function getPolicyTemplate(name: string): PolicyTemplate | undefined {
  return policyCompiler.getTemplate(name);
}

export async function deployCompiledPolicy(tenantId: TenantId, policy: Policy): Promise<void> {
  return policyCompiler.deployPolicy(tenantId, policy);
}

export function policyToYAML(policy: Policy): string {
  return policyCompiler.generateYAMLFromPolicy(policy);
}
